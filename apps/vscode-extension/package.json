{
    "name": "book-language",
    "displayName": "Book Language (Promptbook)",
    "version": "0.0.1",
    "publisher": "Promptbook",
    "description": "Syntax highlighting and snippets for the Book language — the DSL used to define AI agents in Promptbook",
    "author": "Pavol Hejný <pavol@ptbk.io> (https://www.pavolhejny.com/)",
    "contributors": [
        "Pavol Hejný <pavol@ptbk.io> (https://www.pavolhejny.com/)"
    ],
    "private": false,
    "engines": {
        "vscode": "^1.77.0"
    },
    "license": "BUSL-1.1",
    "icon": "./icons/book-icon.png",
    "galleryBanner": {
        "color": "#244EA8",
        "theme": "dark"
    },
    "preview": true,
    "pricing": "Free",
    "homepage": "https://ptbk.io/",
    "repository": {
        "type": "git",
        "url": "https://github.com/webgptorg/promptbook"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "book",
        "promptbook",
        "ai",
        "llm",
        "agent",
        "language-model",
        "openai",
        "anthropic",
        "chatgpt"
    ],
    "activationEvents": [
        "onLanguage:book"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "book",
                "aliases": [
                    "Book",
                    "BOOK"
                ],
                "extensions": [
                    ".book",
                    ".book.md"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/book-icon.png",
                    "dark": "./icons/book-icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "book",
                "scopeName": "text.book",
                "path": "./syntaxes/book.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "book",
                "path": "./snippets/book.json"
            }
        ]
    },
    "scripts": {
        "compile": "tsc -p ./",
        "vscode:prepublish": "npm run compile"
    },
    "devDependencies": {
        "@types/node": "22.0.0",
        "@types/vscode": "1.77.0",
        "@vscode/vsce": "3.2.2",
        "typescript": "5.7.3"
    }
}
