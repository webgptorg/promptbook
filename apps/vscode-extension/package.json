{
    "displayName": "Book Language",
    "name": "book-language",
    "version": "0.112.0",
    "publisher": "Promptbook",
    "description": "Syntax highlighting for the Book language — the AI agent definition format used by Promptbook",
    "author": "Pavol Hejný <pavol@ptbk.io> (https://www.pavolhejny.com/)",
    "contributors": [
        "Pavol Hejný <pavol@ptbk.io> (https://www.pavolhejny.com/)",
        "Jiří Jahn <jiri@ptbk.io> (https://www.ptbk.io/)"
    ],
    "private": false,
    "engines": {
        "vscode": "^1.85.0"
    },
    "license": "BUSL-1.1",
    "icon": "./icons/book-icon.png",
    "galleryBanner": {
        "color": "#007ACC",
        "theme": "dark"
    },
    "preview": true,
    "pricing": "Free",
    "homepage": "https://ptbk.io/",
    "repository": {
        "type": "git",
        "url": "https://github.com/webgptorg/promptbook"
    },
    "categories": [
        "Programming Languages"
    ],
    "keywords": [
        "ai",
        "llm",
        "prompt",
        "book",
        "book-language",
        "promptbook",
        "agent",
        "syntax-highlighting",
        "language-model",
        "chatgpt",
        "openai",
        "anthropic",
        "gemini"
    ],
    "main": "./out/extension.js",
    "activationEvents": [],
    "contributes": {
        "languages": [
            {
                "id": "book",
                "aliases": [
                    "Book",
                    "BOOK",
                    "Book Language"
                ],
                "extensions": [
                    ".book",
                    ".book.md",
                    ".ptbk",
                    ".ptbk.md"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/book-icon.png",
                    "dark": "./icons/book-icon.png"
                }
            }
        ],
        "grammars": [
            {
                "language": "book",
                "scopeName": "text.book",
                "path": "./syntaxes/book.tmLanguage.json"
            }
        ]
    },
    "scripts": {
        "compile": "tsc",
        "build": "npm run compile && vsce package --out book-language.vsix",
        "vscode:prepublish": "npm run compile"
    },
    "devDependencies": {
        "@types/vscode": "1.85.0",
        "@types/node": "20.0.0",
        "@vscode/vsce": "3.2.2",
        "typescript": "5.7.3"
    },
    "funding": [
        {
            "type": "individual",
            "url": "https://buymeacoffee.com/hejny"
        },
        {
            "type": "github",
            "url": "https://github.com/webgptorg/promptbook"
        }
    ]
}
