{
    "compilerOptions": {
        "target": "ES2018",
        "lib": ["ES2018"],
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./out",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": ["src"],
    "exclude": ["node_modules", ".vscode-test"]
}
