{
    "compilerOptions": {
        "target": "ES2019",
        "lib": ["ES2019"],
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "out",
        "rootDir": "src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "declaration": false,
        "sourceMap": true
    },
    "include": ["src"],
    "exclude": ["node_modules", "out"]
}
