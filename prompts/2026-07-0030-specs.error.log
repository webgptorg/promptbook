{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TmwoUxR6kKui2yBX5bJQUq","type":"tool_result","content":"1\timport type { string_agent_url, string_book } from '../../../../src/_packages/types.index'; // <- [🚾]\n2\timport type { AgentReferenceResolver } from '../../../../src/book-2.0/agent-source/AgentReferenceResolver';\n3\timport { padBook } from '../../../../src/book-2.0/agent-source/padBook';\n4\timport { isVoidPseudoAgentReference } from '../../../../src/book-2.0/agent-source/pseudoAgentReferences';\n5\timport { validateBook } from '../../../../src/book-2.0/agent-source/string_book';\n6\timport { ParseError } from '../../../../src/errors/ParseError';\n7\timport { UnexpectedError } from '../../../../src/errors/UnexpectedError';\n8\timport { spaceTrim } from '../../../../src/utils/organization/spaceTrim';\n9\timport { isValidAgentUrl } from '../../../../src/utils/validators/url/isValidAgentUrl';\n10\timport {\n11\t    DEFAULT_FEDERATED_AGENT_IMPORT_CONFIGURATION,\n12\t    type FederatedAgentImportConfiguration,\n13\t} from '../constants/federatedAgentImport';\n14\timport {\n15\t    type AgentReferenceResolutionIssue,\n16\t    consumeAgentReferenceResolutionIssues,\n17\t} from './agentReferenceResolver/AgentReferenceResolutionIssue';\n18\timport { type ImportAgentOptions } from './importAgent';\n19\timport { importAgentWithFallback } from './importAgentWithFallback';\n20\t\n21\t/**\n22\t * Gets the corpus of an agent source (removes title and trailing status)\n23\t *\n24\t * @param agentSource The agent source\n25\t * @returns The agent source corpus\n26\t */\n27\tfunction getAgentSourceCorpus(agentSource: string_book): string {\n28\t    // Remove trailing OPEN or CLOSED if present\n29\t    const agentSourceWithoutStatus = agentSource.replace(/\\n?(OPEN|CLOSED)\\s*$/i, '') as string_book;\n30\t    // <- TODO: [🈲] Simple and encapsulated way to get book corpus\n31\t\n32\t    // Remove the first line (title) from agent source\n33\t    const agentSourceCorpus = spaceTrim(agentSourceWithoutStatus.replace(/^.*$/m, ''));\n34\t    // <- TODO: [🈲] Simple and encapsulated way to get book corpus\n35\t\n36\t    return agentSourceCorpus;\n37\t}\n38\t\n39\t/**\n40\t * Formats a resolver issue into a visible NOTE line in resolved agent source.\n41\t *\n42\t * @param issue - Tracked missing-reference issue.\n43\t * @returns Single-line NOTE statement.\n44\t */\n45\tfunction formatResolutionIssueAsNote(issue: AgentReferenceResolutionIssue): string {\n46\t    const commitmentType = issue.commitmentType === 'IMPORTS' ? 'IMPORT' : issue.commitmentType;\n47\t\n48\t    if (commitmentType === 'FROM') {\n49\t        return `NOTE Referenced agent \"${issue.reference}\" in FROM commitment was not found. Inheritance skipped.`;\n50\t    }\n51\t\n52\t    if (commitmentType === 'IMPORT') {\n53\t        return `NOTE Referenced agent \"${issue.reference}\" in IMPORT commitment was not found. Import skipped.`;\n54\t    }\n55\t\n56\t    if (commitmentType === 'TEAM') {\n57\t        return `NOTE Referenced agent \"${issue.reference}\" in TEAM commitment was not found. Teammate disabled.`;\n58\t    }\n59\t\n60\t    return `NOTE Referenced agent \"${issue.reference}\" in ${commitmentType} commitment was not found.`;\n61\t}\n62\t\n63\t/**\n64\t * Appends NOTE lines for unresolved references while avoiding duplicates.\n65\t *\n66\t * @param targetChunks - Output chunks being assembled for the resolved book.\n67\t * @param issues - Missing-reference issues to materialize into NOTE lines.\n68\t */\n69\tfunction appendResolutionIssueNotes(\n70\t    targetChunks: Array<string>,\n71\t    issues: ReadonlyArray<AgentReferenceResolutionIssue>,\n72\t): void {\n73\t    const seenIssueKeys = new Set<string>();\n74\t\n75\t    for (const issue of issues) {\n76\t        const key = `${issue.commitmentType}:${issue.reference}`.toLowerCase();\n77\t        if (seenIssueKeys.has(key)) {\n78\t            continue;\n79\t        }\n80\t\n81\t        seenIssueKeys.add(key);\n82\t        targetChunks.push(formatResolutionIssueAsNote(issue), '');\n83\t    }\n84\t}\n85\t\n86\t/**\n87\t * Inserts NOTE lines right after the title line in a book.\n88\t *\n89\t * @param agentSource - Original agent source.\n90\t * @param notes - NOTE lines to insert.\n91\t * @returns Updated book with notes placed after the title.\n92\t */\n93\tfunction insertNotesAfterTitle(agentSource: string_book, notes: ReadonlyArray<string>): string_book {\n94\t    if (notes.length === 0) {\n95\t        return agentSource;\n96\t    }\n97\t\n98\t    const sourceLines = spaceTrim(agentSource).split(/\\r?\\n/);\n99\t    const titleLine = sourceLines[0] || '';\n100\t    const restLines = sourceLines.slice(1);\n101\t    const nextLines = [titleLine, '', ...notes, '', ...restLines];\n102\t\n103\t    return padBook(validateBook(nextLines.join('\\n')));\n104\t}\n105\t\n106\t/**\n107\t * Returns the last explicit single-line commitment content for one commitment type.\n108\t *\n109\t * This lightweight parser is intentionally limited to the subset needed by\n110\t * inheritance resolution so it stays safe to bundle into the Next.js proxy path.\n111\t *\n112\t * @param agentSource - Raw book source.\n113\t * @param commitmentType - Commitment keyword to search for.\n114\t * @returns Trimmed commitment content, empty string for a blank explicit commitment, or `undefined` when absent.\n115\t */\n116\tfunction getLastSingleLineCommitmentContent(agentSource: string_book, commitmentType: 'FROM'): string | undefined {\n117\t    const commitmentPrefix = `${commitmentType} `;\n118\t    const lines = agentSource.split(/\\r?\\n/);\n119\t    let hasSeenTitle = false;\n120\t    let isInsideCodeBlock = false;\n121\t    let matchedContent: string | undefined;\n122\t\n123\t    for (const line of lines) {\n124\t        const trimmedLine = line.trim();\n125\t\n126\t        if (!hasSeenTitle) {\n127\t            if (!trimmedLine) {\n128\t                continue;\n129\t            }\n130\t\n131\t            hasSeenTitle = true;\n132\t            continue;\n133\t        }\n134\t\n135\t        if (trimmedLine.startsWith('```')) {\n136\t            isInsideCodeBlock = !isInsideCodeBlock;\n137\t            continue;\n138\t        }\n139\t\n140\t        if (isInsideCodeBlock) {\n141\t            continue;\n142\t        }\n143\t\n144\t        if (trimmedLine === commitmentType) {\n145\t            matchedContent = '';\n146\t            continue;\n147\t        }\n148\t\n149\t        if (trimmedLine.startsWith(commitmentPrefix)) {\n150\t            matchedContent = trimmedLine.slice(commitmentPrefix.length).trim();\n151\t        }\n152\t    }\n153\t\n154\t    return matchedContent;\n155\t}\n156\t\n157\t/**\n158\t * Resolves the effective `FROM` parent URL using only lightweight commitment parsing.\n159\t *\n160\t * @param rawAgentSource - Original source used for diagnostics.\n161\t * @param agentReferenceResolver - Optional compact-reference resolver.\n162\t * @returns Valid parent URL, explicit `null` for `FROM VOID`/blank `FROM`, or `undefined` when `FROM` is absent.\n163\t */\n164\tasync function resolveParentAgentUrlFromCommitments(\n165\t    rawAgentSource: string_book,\n166\t    agentReferenceResolver?: AgentReferenceResolver,\n167\t): Promise<string_agent_url | null | undefined> {\n168\t    const explicitFromContent = getLastSingleLineCommitmentContent(rawAgentSource, 'FROM');\n169\t\n170\t    if (explicitFromContent === undefined) {\n171\t        return undefined;\n172\t    }\n173\t\n174\t    let resolvedParentReference = explicitFromContent.trim();\n175\t\n176\t    if (agentReferenceResolver && resolvedParentReference) {\n177\t        resolvedParentReference = (\n178\t            await agentReferenceResolver.resolveCommitmentContent('FROM', resolvedParentReference)\n179\t        ).trim();\n180\t    }\n181\t\n182\t    if (!resolvedParentReference || isVoidPseudoAgentReference(resolvedParentReference)) {\n183\t        return null;\n184\t    }\n185\t\n186\t    if (!isValidAgentUrl(resolvedParentReference)) {\n187\t        throw new ParseError(\n188\t            spaceTrim(\n189\t                (block) => `\n190\t                    Invalid parent agent URL in FROM \"${resolvedParentReference}\" commitment:\n191\t\n192\t                    \\`\\`\\`book\n193\t                    ${block(rawAgentSource)}\n194\t                    \\`\\`\\`\n195\t            \n196\t                `,\n197\t            ),\n198\t        );\n199\t    }\n200\t\n201\t    return resolvedParentReference as string_agent_url;\n202\t}\n203\t\n204\t/**\n205\t * Shared options for resolving one agent source with inheritance and imports applied.\n206\t */\n207\ttype ResolveInheritedAgentSourceOptions = ImportAgentOptions & {\n208\t    /**\n209\t     * The URL of the Adam agent to use as the default ancestor\n210\t     *\n211\t     * @default 'https://core.ptbk.io/agents/adam'\n212\t     */\n213\t    readonly adamAgentUrl?: string_agent_url;\n214\t    /**\n215\t     * Custom resolver used to expand compact agent references.\n216\t     */\n217\t    readonly agentReferenceResolver?: AgentReferenceResolver;\n218\t    /**\n219\t     * Canonical URL of the currently resolved agent.\n220\t     */\n221\t    readonly currentAgentUrl?: string_agent_url;\n222\t    /**\n223\t     * Additional equivalent URLs that should be treated as the current agent while detecting cycles.\n224\t     */\n225\t    readonly currentAgentAliases?: ReadonlyArray<string_agent_url>;\n226\t    /**\n227\t     * Already visited agent URLs in the current resolution stack.\n228\t     */\n229\t    readonly inheritancePath?: ReadonlyArray<string_agent_url>;\n230\t    /**\n231\t     * Retry configuration used for federated imported-agent loading.\n232\t     */\n233\t    readonly federatedAgentImportConfiguration?: FederatedAgentImportConfiguration;\n234\t    /**\n235\t     * Optional same-instance source importer used before falling back to HTTP import.\n236\t     */\n237\t    readonly agentSourceImporter?: AgentSourceImporter;\n238\t};\n239\t\n240\t/**\n241\t * Context passed to a custom agent source importer.\n242\t */\n243\texport type AgentSourceImporterContext = {\n244\t    /**\n245\t     * Commitment that requested the imported source.\n246\t     */\n247\t    readonly commitmentType: 'FROM' | 'IMPORT';\n248\t\n249\t    /**\n250\t     * Import options propagated from the current resolution pass.\n251\t     */\n252\t    readonly importAgentOptions: ImportAgentOptions;\n253\t\n254\t    /**\n255\t     * Retry configuration used by the default HTTP importer.\n256\t     */\n257\t    readonly federatedAgentImportConfiguration: FederatedAgentImportConfiguration;\n258\t};\n259\t\n260\t/**\n261\t * Imports one agent source before the resolver falls back to the default HTTP importer.\n262\t *\n263\t * Return `null` when the importer does not own the given URL.\n264\t */\n265\texport type AgentSourceImporter = (\n266\t    agentUrl: string_agent_url,\n267\t    context: AgentSourceImporterContext,\n268\t) => Promise<string_book | null>;\n269\t\n270\t/**\n271\t * Parent inheritance state derived before rewriting the source body.\n272\t */\n273\ttype ResolvedParentAgentContext = {\n274\t    /**\n275\t     * Effective parent URL after resolving explicit `FROM`, `FROM VOID`, or implicit Adam fallback.\n276\t     */\n277\t    readonly parentAgentUrl: string_agent_url | null;\n278\t\n279\t    /**\n280\t     * Parent source body without title/status, ready to be embedded into the child source.\n281\t     */\n282\t    readonly parentAgentSourceCorpus: string | null;\n283\t\n284\t    /**\n285\t     * Unresolved compact-reference issues captured while resolving `FROM`.\n286\t     */\n287\t    readonly fromResolutionIssues: Array<AgentReferenceResolutionIssue>;\n288\t};\n289\t\n290\t/**\n291\t * Shared import settings reused for parent and imported-agent loading.\n292\t */\n293\ttype AgentImportContext = {\n294\t    /**\n295\t     * Adam agent URL used as the implicit default ancestor.\n296\t     */\n297\t    readonly adamAgentUrl: string_agent_url;\n298\t\n299\t    /**\n300\t     * Resolver used to expand compact references in commitments.\n301\t     */\n302\t    readonly agentReferenceResolver?: AgentReferenceResolver;\n303\t\n304\t    /**\n305\t     * Retry policy used for federated imports.\n306\t     */\n307\t    readonly federatedAgentImportConfiguration: FederatedAgentImportConfiguration;\n308\t\n309\t    /**\n310\t     * Import options propagated to downstream agent loading.\n311\t     */\n312\t    readonly importAgentOptions: ImportAgentOptions;\n313\t\n314\t    /**\n315\t     * Optional importer for same-instance agent sources.\n316\t     */\n317\t    readonly agentSourceImporter?: AgentSourceImporter;\n318\t\n319\t    /**\n320\t     * Original resolution options used for cycle detection.\n321\t     */\n322\t    readonly resolutionOptions?: ResolveInheritedAgentSourceOptions;\n323\t};\n324\t\n325\t/**\n326\t * Result of rewriting the source line by line before final validation.\n327\t */\n328\ttype ResolvedAgentSourceBuild = {\n329\t    /**\n330\t     * Rewritten source lines.\n331\t     */\n332\t    readonly agentSourceChunks: Array<string>;\n333\t\n334\t    /**\n335\t     * Whether one explicit `FROM ...` line was materialized during rewriting.\n336\t     */\n337\t    readonly isFromResolved: boolean;\n338\t\n339\t    /**\n340\t     * Remaining unresolved `FROM` issues that still need to be turned into NOTE lines.\n341\t     */\n342\t    readonly fromResolutionIssues: Array<AgentReferenceResolutionIssue>;\n343\t};\n344\t\n345\t/**\n346\t * Result of handling one explicit `FROM ...` line.\n347\t */\n348\ttype ResolvedFromCommitmentLine = {\n349\t    /**\n350\t     * Output lines produced for the `FROM` commitment.\n351\t     */\n352\t    readonly agentSourceChunks: Array<string>;\n353\t\n354\t    /**\n355\t     * Remaining `FROM` issues after the line was handled.\n356\t     */\n357\t    readonly fromResolutionIssues: Array<AgentReferenceResolutionIssue>;\n358\t};\n359\t\n360\t/**\n361\t * Normalizes agent URLs used for cycle detection and lineage reporting.\n362\t *\n363\t * @param agentUrl - Raw agent URL.\n364\t * @returns URL without trailing slashes.\n365\t */\n366\tfunction normalizeAgentUrl(agentUrl: string_agent_url): string_agent_url {\n367\t    return agentUrl.replace(/\\/+$/g, '') as string_agent_url;\n368\t}\n369\t\n370\t/**\n371\t * Builds the current resolution lineage ending with the agent being resolved now.\n372\t *\n373\t * @param options - Resolution options with current agent metadata.\n374\t * @returns Ordered lineage without empty values.\n375\t */\n376\tfunction createResolutionLineage(options?: ResolveInheritedAgentSourceOptions): Array<string_agent_url> {\n377\t    const lineage = [...(options?.inheritancePath || [])];\n378\t\n379\t    if (options?.currentAgentUrl) {\n380\t        lineage.push(options.currentAgentUrl);\n381\t    }\n382\t\n383\t    for (const alias of options?.currentAgentAliases || []) {\n384\t        lineage.push(alias);\n385\t    }\n386\t\n387\t    return [...new Set(lineage.map(normalizeAgentUrl))];\n388\t}\n389\t\n390\t/**\n391\t * Creates the shared import context used throughout one resolution pass.\n392\t *\n393\t * @param options - Resolution options passed to `resolveInheritedAgentSource`.\n394\t * @returns Normalized shared import context.\n395\t */\n396\tfunction createAgentImportContext(options?: ResolveInheritedAgentSourceOptions): AgentImportContext {\n397\t    return {\n398\t        adamAgentUrl: options?.adamAgentUrl || 'https://core.ptbk.io/agents/adam',\n399\t        agentReferenceResolver: options?.agentReferenceResolver,\n400\t        federatedAgentImportConfiguration:\n401\t            options?.federatedAgentImportConfiguration || DEFAULT_FEDERATED_AGENT_IMPORT_CONFIGURATION,\n402\t        importAgentOptions: {\n403\t            recursionLevel: options?.recursionLevel || 0,\n404\t            inheritancePath: createResolutionLineage(options),\n405\t        },\n406\t        agentSourceImporter: options?.agentSourceImporter,\n407\t        resolutionOptions: options,\n408\t    };\n409\t}\n410\t\n411\t/**\n412\t * Computes the effective parent URL after applying explicit `FROM` and Adam fallback rules.\n413\t *\n414\t * @param resolvedParentAgentUrl - Parent URL derived from lightweight commitment parsing.\n415\t * @param hasExplicitFromCommitment - Whether the source explicitly declared `FROM`.\n416\t * @param adamAgentUrl - Default Adam ancestor URL.\n417\t * @param currentAgentUrl - Canonical URL of the source being resolved.\n418\t * @param agentSource - Raw source used for unexpected diagnostics.\n419\t * @returns Effective parent URL or `null` when inheritance is disabled.\n420\t */\n421\tfunction determineParentAgentUrl(\n422\t    resolvedParentAgentUrl: string_agent_url | null | undefined,\n423\t    hasExplicitFromCommitment: boolean,\n424\t    adamAgentUrl: string_agent_url,\n425\t    currentAgentUrl?: string_agent_url,\n426\t    agentSource?: string_book,\n427\t): string_agent_url | null {\n428\t    if (isValidAgentUrl(resolvedParentAgentUrl)) {\n429\t        return resolvedParentAgentUrl as string_agent_url;\n430\t    }\n431\t\n432\t    if (resolvedParentAgentUrl === null && hasExplicitFromCommitment) {\n433\t        return null;\n434\t    }\n435\t\n436\t    if (resolvedParentAgentUrl === undefined || resolvedParentAgentUrl === null) {\n437\t        return currentAgentUrl && normalizeAgentUrl(currentAgentUrl) === normalizeAgentUrl(adamAgentUrl)\n438\t            ? null\n439\t            : adamAgentUrl;\n440\t    }\n441\t\n442\t    throw new ParseError(\n443\t        spaceTrim(\n444\t            (block) => `\n445\t                Invalid parent agent URL in FROM \"${resolvedParentAgentUrl}\" commitment:\n446\t\n447\t                \\`\\`\\`book\n448\t                ${block(agentSource || '')}\n449\t                \\`\\`\\`\n450\t            `,\n451\t        ),\n452\t    );\n453\t}\n454\t\n455\t/**\n456\t * Imports one referenced agent and returns only its body content ready to be embedded as a NOTE block.\n457\t *\n458\t * @param agentUrl - Canonical referenced agent URL.\n459\t * @param commitmentType - Commitment that introduced the reference.\n460\t * @param context - Shared import context for the current resolution pass.\n461\t * @returns Imported source body without title/status.\n462\t */\n463\tasync function importAgentCorpus(\n464\t    agentUrl: string_agent_url,\n465\t    commitmentType: 'FROM' | 'IMPORT',\n466\t    context: AgentImportContext,\n467\t): Promise<string> {\n468\t    assertNoResolutionCycle(agentUrl, commitmentType, context.resolutionOptions);\n469\t\n470\t    const locallyImportedAgentSource = context.agentSourceImporter\n471\t        ? await context.agentSourceImporter(agentUrl, {\n472\t              commitmentType,\n473\t              importAgentOptions: context.importAgentOptions,\n474\t              federatedAgentImportConfiguration: context.federatedAgentImportConfiguration,\n475\t          })\n476\t        : null;\n477\t    const importedAgentSource =\n478\t        locallyImportedAgentSource ??\n479\t        (await importAgentWithFallback(\n480\t            agentUrl,\n481\t            context.importAgentOptions,\n482\t            context.federatedAgentImportConfiguration,\n483\t        ));\n484\t\n485\t    return getAgentSourceCorpus(importedAgentSource as string_book);\n486\t}\n487\t\n488\t/**\n489\t * Resolves the effective parent state before the source body is rewritten.\n490\t *\n491\t * @param agentSource - Raw child agent source.\n492\t * @param context - Shared import context for the current resolution pass.\n493\t * @returns Parent URL, imported parent body, and unresolved `FROM` issues.\n494\t */\n495\tasync function resolveParentAgentContext(\n496\t    agentSource: string_book,\n497\t    context: AgentImportContext,\n498\t): Promise<ResolvedParentAgentContext> {\n499\t    const explicitFromContent = getLastSingleLineCommitmentContent(agentSource, 'FROM');\n500\t    const hasExplicitFromCommitment = explicitFromContent !== undefined;\n501\t    const resolvedParentAgentUrl = await resolveParentAgentUrlFromCommitments(\n502\t        agentSource,\n503\t        context.agentReferenceResolver,\n504\t    );\n505\t    const fromResolutionIssues = consumeAgentReferenceResolutionIssues(context.agentReferenceResolver).filter(\n506\t        (issue) => issue.commitmentType === 'FROM',\n507\t    );\n508\t    const parentAgentUrl = determineParentAgentUrl(\n509\t        resolvedParentAgentUrl,\n510\t        hasExplicitFromCommitment,\n511\t        context.adamAgentUrl,\n512\t        context.resolutionOptions?.currentAgentUrl,\n513\t        agentSource,\n514\t    );\n515\t    const parentAgentSourceCorpus = parentAgentUrl ? await importAgentCorpus(parentAgentUrl, 'FROM', context) : null;\n516\t\n517\t    return {\n518\t        parentAgentUrl,\n519\t        parentAgentSourceCorpus,\n520\t        fromResolutionIssues,\n521\t    };\n522\t}\n523\t\n524\t/**\n525\t * Formats one embedded agent body into the NOTE block used by inheritance/import resolution.\n526\t *\n527\t * @param noteLine - First NOTE line describing the embedded source.\n528\t * @param sourceCorpus - Imported source body to embed.\n529\t * @returns Multi-line NOTE block.\n530\t */\n531\tfunction createEmbeddedAgentSourceNote(noteLine: string, sourceCorpus: string): string {\n532\t    return spaceTrim(\n533\t        (block) => `\n534\t\n535\t            ${noteLine}\n536\t            ${block(sourceCorpus)}\n537\t\n538\t            NOTE ===========\n539\t    `,\n540\t    );\n541\t}\n542\t\n543\t/**\n544\t * Resolves one `IMPORT ...` line into embedded source or leaves non-agent imports untouched.\n545\t *\n546\t * @param line - Current source line.\n547\t * @param context - Shared import context for the current resolution pass.\n548\t * @returns Output lines replacing the original line.\n549\t */\n550\tasync function resolveImportCommitmentLine(line: string, context: AgentImportContext): Promise<Array<string>> {\n551\t    const rawImportedUrlOrPath = line.trim().substring('IMPORT '.length).trim();\n552\t    let importedUrlOrPath = rawImportedUrlOrPath;\n553\t    let importResolutionIssues: Array<AgentReferenceResolutionIssue> = [];\n554\t\n555\t    if (context.agentReferenceResolver && rawImportedUrlOrPath) {\n556\t        try {\n557\t            importedUrlOrPath = await context.agentReferenceResolver.resolveCommitmentContent(\n558\t                'IMPORT',\n559\t                rawImportedUrlOrPath,\n560\t            );\n561\t        } catch (error) {\n562\t            console.warn('[AgentReferenceResolver] Failed to resolve IMPORT commitment references:', error);\n563\t        } finally {\n564\t            importResolutionIssues = consumeAgentReferenceResolutionIssues(context.agentReferenceResolver).filter(\n565\t                (issue) => issue.commitmentType === 'IMPORT' || issue.commitmentType === 'IMPORTS',\n566\t            );\n567\t        }\n568\t    }\n569\t\n570\t    const resolvedChunks: Array<string> = [];\n571\t    appendResolutionIssueNotes(resolvedChunks, importResolutionIssues);\n572\t\n573\t    if (!importedUrlOrPath) {\n574\t        return resolvedChunks;\n575\t    }\n576\t\n577\t    if (!isValidAgentUrl(importedUrlOrPath)) {\n578\t        resolvedChunks.push(line);\n579\t        return resolvedChunks;\n580\t    }\n581\t\n582\t    const importedAgentUrl = importedUrlOrPath as string_agent_url;\n583\t    const importedAgentSourceCorpus = await importAgentCorpus(importedAgentUrl, 'IMPORT', context);\n584\t\n585\t    resolvedChunks.push(\n586\t        createEmbeddedAgentSourceNote(`NOTE Imported from ${importedAgentUrl}`, importedAgentSourceCorpus),\n587\t        '', // <- Note: Add an extra newline for separation\n588\t    );\n589\t\n590\t    return resolvedChunks;\n591\t}\n592\t\n593\t/**\n594\t * Resolves one explicit `FROM ...` line into inherited content or fallback NOTE lines.\n595\t *\n596\t * @param line - Current source line.\n597\t * @param agentSource - Full source used for duplicate-`FROM` diagnostics.\n598\t * @param isFromResolved - Whether a previous `FROM ...` line was already handled.\n599\t * @param parentContext - Effective parent state computed earlier in the resolution.\n600\t * @returns Output lines and remaining `FROM` issues.\n601\t */\n602\tfunction resolveFromCommitmentLine(\n603\t    line: string,\n604\t    agentSource: string_book,\n605\t    isFromResolved: boolean,\n606\t    parentContext: ResolvedParentAgentContext,\n607\t): ResolvedFromCommitmentLine {\n608\t    if (isFromResolved) {\n609\t        throw new UnexpectedError(\n610\t            spaceTrim(\n611\t                (block) => `\n612\t                    Multiple \\`FROM\\` commitments found in agent source:\n613\t\n614\t                    \\`\\`\\`book\n615\t                    ${block(agentSource)}\n616\t                    \\`\\`\\`\n617\t                `,\n618\t            ),\n619\t        );\n620\t    }\n621\t\n622\t    if (parentContext.parentAgentUrl === null) {\n623\t        const agentSourceChunks = [line];\n624\t\n625\t        if (parentContext.fromResolutionIssues.length > 0) {\n626\t            appendResolutionIssueNotes(agentSourceChunks, parentContext.fromResolutionIssues);\n627\t        }\n628\t\n629\t        return {\n630\t            agentSourceChunks,\n631\t            fromResolutionIssues: [],\n632\t        };\n633\t    }\n634\t\n635\t    if (parentContext.parentAgentSourceCorpus) {\n636\t        return {\n637\t            agentSourceChunks: [\n638\t                createEmbeddedAgentSourceNote(\n639\t                    `NOTE Inherited FROM ${parentContext.parentAgentUrl}`,\n640\t                    parentContext.parentAgentSourceCorpus,\n641\t                ),\n642\t                '', // <- Note: Add an extra newline for separation\n643\t            ],\n644\t            fromResolutionIssues: parentContext.fromResolutionIssues,\n645\t        };\n646\t    }\n647\t\n648\t    return {\n649\t        agentSourceChunks: [\n650\t            `NOTE Parent agent \"${parentContext.parentAgentUrl}\" was not found or could not be loaded. Inheritance skipped.`,\n651\t            '',\n652\t        ],\n653\t        fromResolutionIssues: parentContext.fromResolutionIssues,\n654\t    };\n655\t}\n656\t\n657\t/**\n658\t * Rewrites the source body line by line while delegating each branching step to a focused helper.\n659\t *\n660\t * @param agentSource - Raw child agent source.\n661\t * @param context - Shared import context for the current resolution pass.\n662\t * @param parentContext - Effective parent state computed earlier in the resolution.\n663\t * @returns Rewritten chunks plus final `FROM` bookkeeping.\n664\t */\n665\tasync function resolveAgentSourceBuild(\n666\t    agentSource: string_book,\n667\t    context: AgentImportContext,\n668\t    parentContext: ResolvedParentAgentContext,\n669\t): Promise<ResolvedAgentSourceBuild> {\n670\t    const agentSourceChunks = spaceTrim(agentSource).split(/\\r?\\n/);\n671\t    const resolvedAgentSourceChunks: Array<string> = [];\n672\t    let isFromResolved = false;\n673\t    let fromResolutionIssues = parentContext.fromResolutionIssues;\n674\t    // <- TODO: [🈲] Simple and encapsulated way to split book into commitments\n675\t\n676\t    for (const line of agentSourceChunks) {\n677\t        if (line.trim().startsWith('IMPORT ')) {\n678\t            resolvedAgentSourceChunks.push(...(await resolveImportCommitmentLine(line, context)));\n679\t            continue;\n680\t        }\n681\t\n682\t        if (line.trim().startsWith('FROM ')) {\n683\t            const resolvedFromCommitment = resolveFromCommitmentLine(\n684\t                line,\n685\t                agentSource,\n686\t                isFromResolved,\n687\t                {\n688\t                    ...parentContext,\n689\t                    fromResolutionIssues,\n690\t                },\n691\t            );\n692\t\n693\t            resolvedAgentSourceChunks.push(...resolvedFromCommitment.agentSourceChunks);\n694\t            fromResolutionIssues = resolvedFromCommitment.fromResolutionIssues;\n695\t            isFromResolved = true;\n696\t            continue;\n697\t        }\n698\t\n699\t        resolvedAgentSourceChunks.push(line);\n700\t    }\n701\t    // <- TODO: [🈲] Simple and encapsulated way to split book into commitments\n702\t\n703\t    return {\n704\t        agentSourceChunks: resolvedAgentSourceChunks,\n705\t        isFromResolved,\n706\t        fromResolutionIssues,\n707\t    };\n708\t}\n709\t\n710\t/**\n711\t * Materializes the implicit Adam inheritance block when no explicit `FROM ...` was present.\n712\t *\n713\t * @param build - Current rewritten source build.\n714\t * @param parentContext - Effective parent state computed earlier in the resolution.\n715\t * @param adamAgentUrl - Default Adam ancestor URL.\n716\t * @returns Updated source build with implicit Adam inheritance applied when needed.\n717\t */\n718\tfunction applyImplicitAdamInheritance(\n719\t    build: ResolvedAgentSourceBuild,\n720\t    parentContext: ResolvedParentAgentContext,\n721\t    adamAgentUrl: string_agent_url,\n722\t): ResolvedAgentSourceBuild {\n723\t    if (build.isFromResolved || parentContext.parentAgentUrl !== adamAgentUrl) {\n724\t        return build;\n725\t    }\n726\t\n727\t    const titleLine = build.agentSourceChunks[0] || '';\n728\t    const restLines = build.agentSourceChunks.slice(1);\n729\t    const agentSourceChunks = [titleLine, ''];\n730\t\n731\t    if (parentContext.parentAgentSourceCorpus) {\n732\t        agentSourceChunks.push(\n733\t            createEmbeddedAgentSourceNote(\n734\t                `NOTE Inherited Adam FROM ${parentContext.parentAgentUrl}`,\n735\t                parentContext.parentAgentSourceCorpus,\n736\t            ),\n737\t            ...restLines,\n738\t        );\n739\t    } else {\n740\t        agentSourceChunks.push(\n741\t            `NOTE Default parent agent \"${parentContext.parentAgentUrl}\" was not found or could not be loaded. Inheritance skipped.`,\n742\t            '',\n743\t            ...restLines,\n744\t        );\n745\t    }\n746\t\n747\t    return {\n748\t        ...build,\n749\t        agentSourceChunks,\n750\t    };\n751\t}\n752\t\n753\t/**\n754\t * Validates and pads the resolved source, then inserts any deferred unresolved-`FROM` notes.\n755\t *\n756\t * @param build - Final rewritten source build.\n757\t * @returns Valid resolved book.\n758\t */\n759\tfunction finalizeResolvedAgentSource(build: ResolvedAgentSourceBuild): string_book {\n760\t    const resolvedAgentSource = padBook(validateBook(build.agentSourceChunks.join('\\n')));\n761\t\n762\t    if (build.fromResolutionIssues.length === 0) {\n763\t        return resolvedAgentSource;\n764\t    }\n765\t\n766\t    const unresolvedFromNotes = build.fromResolutionIssues.map(formatResolutionIssueAsNote);\n767\t    return insertNotesAfterTitle(resolvedAgentSource, unresolvedFromNotes);\n768\t}\n769\t\n770\t/**\n771\t * Throws when a `FROM`/`IMPORT` edge would create an inheritance cycle.\n772\t *\n773\t * @param referenceUrl - Next referenced agent URL.\n774\t * @param commitmentType - Commitment that introduced the reference.\n775\t * @param options - Current resolution options.\n776\t */\n777\tfunction assertNoResolutionCycle(\n778\t    referenceUrl: string_agent_url,\n779\t    commitmentType: 'FROM' | 'IMPORT',\n780\t    options?: ResolveInheritedAgentSourceOptions,\n781\t): void {\n782\t    const normalizedReferenceUrl = normalizeAgentUrl(referenceUrl);\n783\t    const lineage = createResolutionLineage(options);\n784\t    const cycleStartIndex = lineage.findIndex((visitedUrl) => visitedUrl === normalizedReferenceUrl);\n785\t\n786\t    if (cycleStartIndex === -1) {\n787\t        return;\n788\t    }\n789\t\n790\t    const cycleChain = [...lineage.slice(cycleStartIndex), normalizedReferenceUrl]\n791\t        .map((visitedUrl) => `- \\`${visitedUrl}\\``)\n792\t        .join('\\n');\n793\t\n794\t    throw new ParseError(\n795\t        spaceTrim(\n796\t            (block) => `\n797\t                Cyclic \\`${commitmentType}\\` reference detected while resolving agent source.\n798\t\n799\t                Resolution chain:\n800\t                ${block(cycleChain)}\n801\t            `,\n802\t        ),\n803\t    );\n804\t}\n805\t\n806\t/**\n807\t * Resolves agent source with inheritance (FROM commitment)\n808\t *\n809\t * It recursively fetches the parent agent source and merges it with the current source.\n810\t *\n811\t * @param agentSource The initial agent source\n812\t * @returns The resolved agent source with inheritance applied\n813\t */\n814\texport async function resolveInheritedAgentSource(\n815\t    agentSource: string_book,\n816\t    options?: ResolveInheritedAgentSourceOptions,\n817\t): Promise<string_book> {\n818\t    const context = createAgentImportContext(options);\n819\t    const parentContext = await resolveParentAgentContext(agentSource, context);\n820\t    const resolvedBuild = await resolveAgentSourceBuild(agentSource, context, parentContext);\n821\t    const finalizedBuild = applyImplicitAdamInheritance(resolvedBuild, parentContext, context.adamAgentUrl);\n822\t\n823\t    return finalizeResolvedAgentSource(finalizedBuild);\n824\t}\n825\t\n826\t// TODO: [🈲] Create a function that can manipulate books by modifying commitments, splitting the book up into commitments or syntactic tokens, and editing or deleting these via object methods.\n827\t// TODO: [🐱‍🚀][⏩] This function should be in `/src` and exported from `@promptbook/core`\n828\t"}]},"parent_tool_use_id":null,"session_id":"5fcf42d8-e79f-4895-8760-3d62c1e26adf","uuid":"36c5393f-da59-4154-8d3e-94f269bbc497","timestamp":"2026-07-07T15:24:19.596Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\me\\work\\ai\\promptbook\\apps\\agents-server\\src\\utils\\resolveInheritedAgentSource.ts","content":"import type { string_agent_url, string_book } from '../../../../src/_packages/types.index'; // <- [🚾]\nimport type { AgentReferenceResolver } from '../../../../src/book-2.0/agent-source/AgentReferenceResolver';\nimport { padBook } from '../../../../src/book-2.0/agent-source/padBook';\nimport { isVoidPseudoAgentReference } from '../../../../src/book-2.0/agent-source/pseudoAgentReferences';\nimport { validateBook } from '../../../../src/book-2.0/agent-source/string_book';\nimport { ParseError } from '../../../../src/errors/ParseError';\nimport { UnexpectedError } from '../../../../src/errors/UnexpectedError';\nimport { spaceTrim } from '../../../../src/utils/organization/spaceTrim';\nimport { isValidAgentUrl } from '../../../../src/utils/validators/url/isValidAgentUrl';\nimport {\n    DEFAULT_FEDERATED_AGENT_IMPORT_CONFIGURATION,\n    type FederatedAgentImportConfiguration,\n} from '../constants/federatedAgentImport';\nimport {\n    type AgentReferenceResolutionIssue,\n    consumeAgentReferenceResolutionIssues,\n} from './agentReferenceResolver/AgentReferenceResolutionIssue';\nimport { type ImportAgentOptions } from './importAgent';\nimport { importAgentWithFallback } from './importAgentWithFallback';\n\n/**\n * Gets the corpus of an agent source (removes title and trailing status)\n *\n * @param agentSource The agent source\n * @returns The agent source corpus\n */\nfunction getAgentSourceCorpus(agentSource: string_book): string {\n    // Remove trailing OPEN or CLOSED if present\n    const agentSourceWithoutStatus = agentSource.replace(/\\n?(OPEN|CLOSED)\\s*$/i, '') as string_book;\n    // <- TODO: [🈲] Simple and encapsulated way to get book corpus\n\n    // Remove the first line (title) from agent source\n    const agentSourceCorpus = spaceTrim(agentSourceWithoutStatus.replace(/^.*$/m, ''));\n    // <- TODO: [🈲] Simple and encapsulated way to get book corpus\n\n    return agentSourceCorpus;\n}\n\n/**\n * Formats a resolver issue into a visible NOTE line in resolved agent source.\n *\n * @param issue - Tracked missing-reference issue.\n * @returns Single-line NOTE statement.\n */\nfunction formatResolutionIssueAsNote(issue: AgentReferenceResolutionIssue): string {\n    const commitmentType = issue.commitmentType === 'IMPORTS' ? 'IMPORT' : issue.commitmentType;\n\n    if (commitmentType === 'FROM') {\n        return `NOTE Referenced agent \"${issue.reference}\" in FROM commitment was not found. Inheritance skipped.`;\n    }\n\n    if (commitmentType === 'IMPORT') {\n        return `NOTE Referenced agent \"${issue.reference}\" in IMPORT commitment was not found. Import skipped.`;\n    }\n\n    if (commitmentType === 'TEAM') {\n        return `NOTE Referenced agent \"${issue.reference}\" in TEAM commitment was not found. Teammate disabled.`;\n    }\n\n    return `NOTE Referenced agent \"${issue.reference}\" in ${commitmentType} commitment was not found.`;\n}\n\n/**\n * Appends NOTE lines for unresolved references while avoiding duplicates.\n *\n * @param targetChunks - Output chunks being assembled for the resolved book.\n * @param issues - Missing-reference issues to materialize into NOTE lines.\n */\nfunction appendResolutionIssueNotes(\n    targetChunks: Array<string>,\n    issues: ReadonlyArray<AgentReferenceResolutionIssue>,\n): void {\n    const seenIssueKeys = new Set<string>();\n\n    for (const issue of issues) {\n        const key = `${issue.commitmentType}:${issue.reference}`.toLowerCase();\n        if (seenIssueKeys.has(key)) {\n            continue;\n        }\n\n        seenIssueKeys.add(key);\n        targetChunks.push(formatResolutionIssueAsNote(issue), '');\n    }\n}\n\n/**\n * Inserts NOTE lines right after the title line in a book.\n *\n * @param agentSource - Original agent source.\n * @param notes - NOTE lines to insert.\n * @returns Updated book with notes placed after the title.\n */\nfunction insertNotesAfterTitle(agentSource: string_book, notes: ReadonlyArray<string>): string_book {\n    if (notes.length === 0) {\n        return agentSource;\n    }\n\n    const sourceLines = spaceTrim(agentSource).split(/\\r?\\n/);\n    const titleLine = sourceLines[0] || '';\n    const restLines = sourceLines.slice(1);\n    const nextLines = [titleLine, '', ...notes, '', ...restLines];\n\n    return padBook(validateBook(nextLines.join('\\n')));\n}\n\n/**\n * Returns the last explicit single-line commitment content for one commitment type.\n *\n * This lightweight parser is intentionally limited to the subset needed by\n * inheritance resolution so it stays safe to bundle into the Next.js proxy path.\n *\n * @param agentSource - Raw book source.\n * @param commitmentType - Commitment keyword to search for.\n * @returns Trimmed commitment content, empty string for a blank explicit commitment, or `undefined` when absent.\n */\nfunction getLastSingleLineCommitmentContent(agentSource: string_book, commitmentType: 'FROM'): string | undefined {\n    const commitmentPrefix = `${commitmentType} `;\n    const lines = agentSource.split(/\\r?\\n/);\n    let hasSeenTitle = false;\n    let isInsideCodeBlock = false;\n    let matchedContent: string | undefined;\n\n    for (const line of lines) {\n        const trimmedLine = line.trim();\n\n        if (!hasSeenTitle) {\n            if (!trimmedLine) {\n                continue;\n            }\n\n            hasSeenTitle = true;\n            continue;\n        }\n\n        if (trimmedLine.startsWith('```')) {\n            isInsideCodeBlock = !isInsideCodeBlock;\n            continue;\n        }\n\n        if (isInsideCodeBlock) {\n            continue;\n        }\n\n        if (trimmedLine === commitmentType) {\n            matchedContent = '';\n            continue;\n        }\n\n        if (trimmedLine.startsWith(commitmentPrefix)) {\n            matchedContent = trimmedLine.slice(commitmentPrefix.length).trim();\n        }\n    }\n\n    return matchedContent;\n}\n\n/**\n * Resolves the effective `FROM` parent URL using only lightweight commitment parsing.\n *\n * @param rawAgentSource - Original source used for diagnostics.\n * @param agentReferenceResolver - Optional compact-reference resolver.\n * @returns Valid parent URL, explicit `null` for `FROM VOID`/blank `FROM`, or `undefined` when `FROM` is absent.\n */\nasync function resolveParentAgentUrlFromCommitments(\n    rawAgentSource: string_book,\n    agentReferenceResolver?: AgentReferenceResolver,\n): Promise<string_agent_url | null | undefined> {\n    const explicitFromContent = getLastSingleLineCommitmentContent(rawAgentSource, 'FROM');\n\n    if (explicitFromContent === undefined) {\n        return undefined;\n    }\n\n    let resolvedParentReference = explicitFromContent.trim();\n\n    if (agentReferenceResolver && resolvedParentReference) {\n        resolvedParentReference = (\n            await agentReferenceResolver.resolveCommitmentContent('FROM', resolvedParentReference)\n        ).trim();\n    }\n\n    if (!resolvedParentReference || isVoidPseudoAgentReference(resolvedParentReference)) {\n        return null;\n    }\n\n    if (!isValidAgentUrl(resolvedParentReference)) {\n        throw new ParseError(\n            spaceTrim(\n                (block) => `\n                    Invalid parent agent URL in FROM \"${resolvedParentReference}\" commitment:\n\n                    \\`\\`\\`book\n                    ${block(rawAgentSource)}\n                    \\`\\`\\`\n            \n                `,\n            ),\n        );\n    }\n\n    return resolvedParentReference as string_agent_url;\n}\n\n/**\n * Shared options for resolving one agent source with inheritance and imports applied.\n */\ntype ResolveInheritedAgentSourceOptions = ImportAgentOptions & {\n    /**\n     * The URL of the Adam agent to use as the default ancestor\n     *\n     * @default 'https://core.ptbk.io/agents/adam'\n     */\n    readonly adamAgentUrl?: string_agent_url;\n    /**\n     * Custom resolver used to expand compact agent references.\n     */\n    readonly agentReferenceResolver?: AgentReferenceResolver;\n    /**\n     * Canonical URL of the currently resolved agent.\n     */\n    readonly currentAgentUrl?: string_agent_url;\n    /**\n     * Additional equivalent URLs that should be treated as the current agent while detecting cycles.\n     */\n    readonly currentAgentAliases?: ReadonlyArray<string_agent_url>;\n    /**\n     * Already visited agent URLs in the current resolution stack.\n     */\n    readonly inheritancePath?: ReadonlyArray<string_agent_url>;\n    /**\n     * Retry configuration used for federated imported-agent loading.\n     */\n    readonly federatedAgentImportConfiguration?: FederatedAgentImportConfiguration;\n    /**\n     * Optional same-instance source importer used before falling back to HTTP import.\n     */\n    readonly agentSourceImporter?: AgentSourceImporter;\n};\n\n/**\n * Context passed to a custom agent source importer.\n */\nexport type AgentSourceImporterContext = {\n    /**\n     * Commitment that requested the imported source.\n     */\n    readonly commitmentType: 'FROM' | 'IMPORT';\n\n    /**\n     * Import options propagated from the current resolution pass.\n     */\n    readonly importAgentOptions: ImportAgentOptions;\n\n    /**\n     * Retry configuration used by the default HTTP importer.\n     */\n    readonly federatedAgentImportConfiguration: FederatedAgentImportConfiguration;\n};\n\n/**\n * Imports one agent source before the resolver falls back to the default HTTP importer.\n *\n * Return `null` when the importer does not own the given URL.\n */\nexport type AgentSourceImporter = (\n    agentUrl: string_agent_url,\n    context: AgentSourceImporterContext,\n) => Promise<string_book | null>;\n\n/**\n * Parent inheritance state derived before rewriting the source body.\n */\ntype ResolvedParentAgentContext = {\n    /**\n     * Effective parent URL after resolving explicit `FROM`, `FROM VOID`, or implicit Adam fallback.\n     */\n    readonly parentAgentUrl: string_agent_url | null;\n\n    /**\n     * Parent source body without title/status, ready to be embedded into the child source.\n     */\n    readonly parentAgentSourceCorpus: string | null;\n\n    /**\n     * Unresolved compact-reference issues captured while resolving `FROM`.\n     */\n    readonly fromResolutionIssues: Array<AgentReferenceResolutionIssue>;\n};\n\n/**\n * Shared import settings reused for parent and imported-agent loading.\n */\ntype AgentImportContext = {\n    /**\n     * Adam agent URL used as the implicit default ancestor.\n     */\n    readonly adamAgentUrl: string_agent_url;\n\n    /**\n     * Resolver used to expand compact references in commitments.\n     */\n    readonly agentReferenceResolver?: AgentReferenceResolver;\n\n    /**\n     * Retry policy used for federated imports.\n     */\n    readonly federatedAgentImportConfiguration: FederatedAgentImportConfiguration;\n\n    /**\n     * Import options propagated to downstream agent loading.\n     */\n    readonly importAgentOptions: ImportAgentOptions;\n\n    /**\n     * Optional importer for same-instance agent sources.\n     */\n    readonly agentSourceImporter?: AgentSourceImporter;\n\n    /**\n     * Original resolution options used for cycle detection.\n     */\n    readonly resolutionOptions?: ResolveInheritedAgentSourceOptions;\n};\n\n/**\n * Result of rewriting the source line by line before final validation.\n */\ntype ResolvedAgentSourceBuild = {\n    /**\n     * Rewritten source lines.\n     */\n    readonly agentSourceChunks: Array<string>;\n\n    /**\n     * Whether one explicit `FROM ...` line was materialized during rewriting.\n     */\n    readonly isFromResolved: boolean;\n\n    /**\n     * Remaining unresolved `FROM` issues that still need to be turned into NOTE lines.\n     */\n    readonly fromResolutionIssues: Array<AgentReferenceResolutionIssue>;\n};\n\n/**\n * Result of handling one explicit `FROM ...` line.\n */\ntype ResolvedFromCommitmentLine = {\n    /**\n     * Output lines produced for the `FROM` commitment.\n     */\n    readonly agentSourceChunks: Array<string>;\n\n    /**\n     * Remaining `FROM` issues after the line was handled.\n     */\n    readonly fromResolutionIssues: Array<AgentReferenceResolutionIssue>;\n};\n\n/**\n * Normalizes agent URLs used for cycle detection and lineage reporting.\n *\n * @param agentUrl - Raw agent URL.\n * @returns URL without trailing slashes.\n */\nfunction normalizeAgentUrl(agentUrl: string_agent_url): string_agent_url {\n    return agentUrl.replace(/\\/+$/g, '') as string_agent_url;\n}\n\n/**\n * Builds the current resolution lineage ending with the agent being resolved now.\n *\n * @param options - Resolution options with current agent metadata.\n * @returns Ordered lineage without empty values.\n */\nfunction createResolutionLineage(options?: ResolveInheritedAgentSourceOptions): Array<string_agent_url> {\n    const lineage = [...(options?.inheritancePath || [])];\n\n    if (options?.currentAgentUrl) {\n        lineage.push(options.currentAgentUrl);\n    }\n\n    for (const alias of options?.currentAgentAliases || []) {\n        lineage.push(alias);\n    }\n\n    return [...new Set(lineage.map(normalizeAgentUrl))];\n}\n\n/**\n * Creates the shared import context used throughout one resolution pass.\n *\n * @param options - Resolution options passed to `resolveInheritedAgentSource`.\n * @returns Normalized shared import context.\n */\nfunction createAgentImportContext(options?: ResolveInheritedAgentSourceOptions): AgentImportContext {\n    return {\n        adamAgentUrl: options?.adamAgentUrl || 'https://core.ptbk.io/agents/adam',\n        agentReferenceResolver: options?.agentReferenceResolver,\n        federatedAgentImportConfiguration:\n            options?.federatedAgentImportConfiguration || DEFAULT_FEDERATED_AGENT_IMPORT_CONFIGURATION,\n        importAgentOptions: {\n            recursionLevel: options?.recursionLevel || 0,\n            inheritancePath: createResolutionLineage(options),\n        },\n        agentSourceImporter: options?.agentSourceImporter,\n        resolutionOptions: options,\n    };\n}\n\n/**\n * Computes the effective parent URL after applying explicit `FROM` and Adam fallback rules.\n *\n * @param resolvedParentAgentUrl - Parent URL derived from lightweight commitment parsing.\n * @param hasExplicitFromCommitment - Whether the source explicitly declared `FROM`.\n * @param adamAgentUrl - Default Adam ancestor URL.\n * @param currentAgentUrl - Canonical URL of the source being resolved.\n * @param agentSource - Raw source used for unexpected diagnostics.\n * @returns Effective parent URL or `null` when inheritance is disabled.\n */\nfunction determineParentAgentUrl(\n    resolvedParentAgentUrl: string_agent_url | null | undefined,\n    hasExplicitFromCommitment: boolean,\n    adamAgentUrl: string_agent_url,\n    currentAgentUrl?: string_agent_url,\n    agentSource?: string_book,\n): string_agent_url | null {\n    if (isValidAgentUrl(resolvedParentAgentUrl)) {\n        return resolvedParentAgentUrl as string_agent_url;\n    }\n\n    if (resolvedParentAgentUrl === null && hasExplicitFromCommitment) {\n        return null;\n    }\n\n    if (resolvedParentAgentUrl === undefined || resolvedParentAgentUrl === null) {\n        return currentAgentUrl && normalizeAgentUrl(currentAgentUrl) === normalizeAgentUrl(adamAgentUrl)\n            ? null\n            : adamAgentUrl;\n    }\n\n    throw new ParseError(\n        spaceTrim(\n            (block) => `\n                Invalid parent agent URL in FROM \"${resolvedParentAgentUrl}\" commitment:\n\n                \\`\\`\\`book\n                ${block(agentSource || '')}\n                \\`\\`\\`\n            `,\n        ),\n    );\n}\n\n/**\n * Imports one referenced agent and returns only its body content ready to be embedded as a NOTE block.\n *\n * @param agentUrl - Canonical referenced agent URL.\n * @param commitmentType - Commitment that introduced the reference.\n * @param context - Shared import context for the current resolution pass.\n * @returns Imported source body without title/status.\n */\nasync function importAgentCorpus(\n    agentUrl: string_agent_url,\n    commitmentType: 'FROM' | 'IMPORT',\n    context: AgentImportContext,\n): Promise<string> {\n    assertNoResolutionCycle(agentUrl, commitmentType, context.resolutionOptions);\n\n    const locallyImportedAgentSource = context.agentSourceImporter\n        ? await context.agentSourceImporter(agentUrl, {\n              commitmentType,\n              importAgentOptions: context.importAgentOptions,\n              federatedAgentImportConfiguration: context.federatedAgentImportConfiguration,\n          })\n        : null;\n    const importedAgentSource =\n        locallyImportedAgentSource ??\n        (await importAgentWithFallback(\n            agentUrl,\n            context.importAgentOptions,\n            context.federatedAgentImportConfiguration,\n        ));\n\n    return getAgentSourceCorpus(importedAgentSource as string_book);\n}\n\n/**\n * Resolves the effective parent state before the source body is rewritten.\n *\n * @param agentSource - Raw child agent source.\n * @param context - Shared import context for the current resolution pass.\n * @returns Parent URL, imported parent body, and unresolved `FROM` issues.\n */\nasync function resolveParentAgentContext(\n    agentSource: string_book,\n    context: AgentImportContext,\n): Promise<ResolvedParentAgentContext> {\n    const explicitFromContent = getLastSingleLineCommitmentContent(agentSource, 'FROM');\n    const hasExplicitFromCommitment = explicitFromContent !== undefined;\n    const resolvedParentAgentUrl = await resolveParentAgentUrlFromCommitments(\n        agentSource,\n        context.agentReferenceResolver,\n    );\n    const fromResolutionIssues = consumeAgentReferenceResolutionIssues(context.agentReferenceResolver).filter(\n        (issue) => issue.commitmentType === 'FROM',\n    );\n    const parentAgentUrl = determineParentAgentUrl(\n        resolvedParentAgentUrl,\n        hasExplicitFromCommitment,\n        context.adamAgentUrl,\n        context.resolutionOptions?.currentAgentUrl,\n        agentSource,\n    );\n    const parentAgentSourceCorpus = parentAgentUrl ? await importAgentCorpus(parentAgentUrl, 'FROM', context) : null;\n\n    return {\n        parentAgentUrl,\n        parentAgentSourceCorpus,\n        fromResolutionIssues,\n    };\n}\n\n/**\n * Formats one embedded agent body into the NOTE block used by inheritance/import resolution.\n *\n * @param noteLine - First NOTE line describing the embedded source.\n * @param sourceCorpus - Imported source body to embed.\n * @returns Multi-line NOTE block.\n */\nfunction createEmbeddedAgentSourceNote(noteLine: string, sourceCorpus: string): string {\n    return spaceTrim(\n        (block) => `\n\n            ${noteLine}\n            ${block(sourceCorpus)}\n\n            NOTE ===========\n    `,\n    );\n}\n\n/**\n * Resolves one `IMPORT ...` line into embedded source or leaves non-agent imports untouched.\n *\n * @param line - Current source line.\n * @param context - Shared import context for the current resolution pass.\n * @returns Output lines replacing the original line.\n */\nasync function resolveImportCommitmentLine(line: string, context: AgentImportContext): Promise<Array<string>> {\n    const rawImportedUrlOrPath = line.trim().substring('IMPORT '.length).trim();\n    let importedUrlOrPath = rawImportedUrlOrPath;\n    let importResolutionIssues: Array<AgentReferenceResolutionIssue> = [];\n\n    if (context.agentReferenceResolver && rawImportedUrlOrPath) {\n        try {\n            importedUrlOrPath = await context.agentReferenceResolver.resolveCommitmentContent(\n                'IMPORT',\n                rawImportedUrlOrPath,\n            );\n        } catch (error) {\n            console.warn('[AgentReferenceResolver] Failed to resolve IMPORT commitment references:', error);\n        } finally {\n            importResolutionIssues = consumeAgentReferenceResolutionIssues(context.agentReferenceResolver).filter(\n                (issue) => issue.commitmentType === 'IMPORT' || issue.commitmentType === 'IMPORTS',\n            );\n        }\n    }\n\n    const resolvedChunks: Array<string> = [];\n    appendResolutionIssueNotes(resolvedChunks, importResolutionIssues);\n\n    if (!importedUrlOrPath) {\n        return resolvedChunks;\n    }\n\n    if (!isValidAgentUrl(importedUrlOrPath)) {\n        resolvedChunks.push(line);\n        return resolvedChunks;\n    }\n\n    const importedAgentUrl = importedUrlOrPath as string_agent_url;\n    const importedAgentSourceCorpus = await importAgentCorpus(importedAgentUrl, 'IMPORT', context);\n\n    resolvedChunks.push(\n        createEmbeddedAgentSourceNote(`NOTE Imported from ${importedAgentUrl}`, importedAgentSourceCorpus),\n        '', // <- Note: Add an extra newline for separation\n    );\n\n    return resolvedChunks;\n}\n\n/**\n * Resolves one explicit `FROM ...` line into inherited content or fallback NOTE lines.\n *\n * @param line - Current source line.\n * @param agentSource - Full source used for duplicate-`FROM` diagnostics.\n * @param isFromResolved - Whether a previous `FROM ...` line was already handled.\n * @param parentContext - Effective parent state computed earlier in the resolution.\n * @returns Output lines and remaining `FROM` issues.\n */\nfunction resolveFromCommitmentLine(\n    line: string,\n    agentSource: string_book,\n    isFromResolved: boolean,\n    parentContext: ResolvedParentAgentContext,\n): ResolvedFromCommitmentLine {\n    if (isFromResolved) {\n        throw new UnexpectedError(\n            spaceTrim(\n                (block) => `\n                    Multiple \\`FROM\\` commitments found in agent source:\n\n                    \\`\\`\\`book\n                    ${block(agentSource)}\n                    \\`\\`\\`\n                `,\n            ),\n        );\n    }\n\n    if (parentContext.parentAgentUrl === null) {\n        const agentSourceChunks = [line];\n\n        if (parentContext.fromResolutionIssues.length > 0) {\n            appendResolutionIssueNotes(agentSourceChunks, parentContext.fromResolutionIssues);\n        }\n\n        return {\n            agentSourceChunks,\n            fromResolutionIssues: [],\n        };\n    }\n\n    if (parentContext.parentAgentSourceCorpus) {\n        return {\n            agentSourceChunks: [\n                createEmbeddedAgentSourceNote(\n                    `NOTE Inherited FROM ${parentContext.parentAgentUrl}`,\n                    parentContext.parentAgentSourceCorpus,\n                ),\n                '', // <- Note: Add an extra newline for separation\n            ],\n            fromResolutionIssues: parentContext.fromResolutionIssues,\n        };\n    }\n\n    return {\n        agentSourceChunks: [\n            `NOTE Parent agent \"${parentContext.parentAgentUrl}\" was not found or could not be loaded. Inheritance skipped.`,\n            '',\n        ],\n        fromResolutionIssues: parentContext.fromResolutionIssues,\n    };\n}\n\n/**\n * Rewrites the source body line by line while delegating each branching step to a focused helper.\n *\n * @param agentSource - Raw child agent source.\n * @param context - Shared import context for the current resolution pass.\n * @param parentContext - Effective parent state computed earlier in the resolution.\n * @returns Rewritten chunks plus final `FROM` bookkeeping.\n */\nasync function resolveAgentSourceBuild(\n    agentSource: string_book,\n    context: AgentImportContext,\n    parentContext: ResolvedParentAgentContext,\n): Promise<ResolvedAgentSourceBuild> {\n    const agentSourceChunks = spaceTrim(agentSource).split(/\\r?\\n/);\n    const resolvedAgentSourceChunks: Array<string> = [];\n    let isFromResolved = false;\n    let fromResolutionIssues = parentContext.fromResolutionIssues;\n    // <- TODO: [🈲] Simple and encapsulated way to split book into commitments\n\n    for (const line of agentSourceChunks) {\n        if (line.trim().startsWith('IMPORT ')) {\n            resolvedAgentSourceChunks.push(...(await resolveImportCommitmentLine(line, context)));\n            continue;\n        }\n\n        if (line.trim().startsWith('FROM ')) {\n            const resolvedFromCommitment = resolveFromCommitmentLine(\n                line,\n                agentSource,\n                isFromResolved,\n                {\n                    ...parentContext,\n                    fromResolutionIssues,\n                },\n            );\n\n            resolvedAgentSourceChunks.push(...resolvedFromCommitment.agentSourceChunks);\n            fromResolutionIssues = resolvedFromCommitment.fromResolutionIssues;\n            isFromResolved = true;\n            continue;\n        }\n\n        resolvedAgentSourceChunks.push(line);\n    }\n    // <- TODO: [🈲] Simple and encapsulated way to split book into commitments\n\n    return {\n        agentSourceChunks: resolvedAgentSourceChunks,\n        isFromResolved,\n        fromResolutionIssues,\n    };\n}\n\n/**\n * Materializes the implicit Adam inheritance block when no explicit `FROM ...` was present.\n *\n * @param build - Current rewritten source build.\n * @param parentContext - Effective parent state computed earlier in the resolution.\n * @param adamAgentUrl - Default Adam ancestor URL.\n * @returns Updated source build with implicit Adam inheritance applied when needed.\n */\nfunction applyImplicitAdamInheritance(\n    build: ResolvedAgentSourceBuild,\n    parentContext: ResolvedParentAgentContext,\n    adamAgentUrl: string_agent_url,\n): ResolvedAgentSourceBuild {\n    if (build.isFromResolved || parentContext.parentAgentUrl !== adamAgentUrl) {\n        return build;\n    }\n\n    const titleLine = build.agentSourceChunks[0] || '';\n    const restLines = build.agentSourceChunks.slice(1);\n    const agentSourceChunks = [titleLine, ''];\n\n    if (parentContext.parentAgentSourceCorpus) {\n        agentSourceChunks.push(\n            createEmbeddedAgentSourceNote(\n                `NOTE Inherited Adam FROM ${parentContext.parentAgentUrl}`,\n                parentContext.parentAgentSourceCorpus,\n            ),\n            ...restLines,\n        );\n    } else {\n        agentSourceChunks.push(\n            `NOTE Default parent agent \"${parentContext.parentAgentUrl}\" was not found or could not be loaded. Inheritance skipped.`,\n            '',\n            ...restLines,\n        );\n    }\n\n    return {\n        ...build,\n        agentSourceChunks,\n    };\n}\n\n/**\n * Validates and pads the resolved source, then inserts any deferred unresolved-`FROM` notes.\n *\n * @param build - Final rewritten source build.\n * @returns Valid resolved book.\n */\nfunction finalizeResolvedAgentSource(build: ResolvedAgentSourceBuild): string_book {\n    const resolvedAgentSource = padBook(validateBook(build.agentSourceChunks.join('\\n')));\n\n    if (build.fromResolutionIssues.length === 0) {\n        return resolvedAgentSource;\n    }\n\n    const unresolvedFromNotes = build.fromResolutionIssues.map(formatResolutionIssueAsNote);\n    return insertNotesAfterTitle(resolvedAgentSource, unresolvedFromNotes);\n}\n\n/**\n * Throws when a `FROM`/`IMPORT` edge would create an inheritance cycle.\n *\n * @param referenceUrl - Next referenced agent URL.\n * @param commitmentType - Commitment that introduced the reference.\n * @param options - Current resolution options.\n */\nfunction assertNoResolutionCycle(\n    referenceUrl: string_agent_url,\n    commitmentType: 'FROM' | 'IMPORT',\n    options?: ResolveInheritedAgentSourceOptions,\n): void {\n    const normalizedReferenceUrl = normalizeAgentUrl(referenceUrl);\n    const lineage = createResolutionLineage(options);\n    const cycleStartIndex = lineage.findIndex((visitedUrl) => visitedUrl === normalizedReferenceUrl);\n\n    if (cycleStartIndex === -1) {\n        return;\n    }\n\n    const cycleChain = [...lineage.slice(cycleStartIndex), normalizedReferenceUrl]\n        .map((visitedUrl) => `- \\`${visitedUrl}\\``)\n        .join('\\n');\n\n    throw new ParseError(\n        spaceTrim(\n            (block) => `\n                Cyclic \\`${commitmentType}\\` reference detected while resolving agent source.\n\n                Resolution chain:\n                ${block(cycleChain)}\n            `,\n        ),\n    );\n}\n\n/**\n * Resolves agent source with inheritance (FROM commitment)\n *\n * It recursively fetches the parent agent source and merges it with the current source.\n *\n * @param agentSource The initial agent source\n * @returns The resolved agent source with inheritance applied\n */\nexport async function resolveInheritedAgentSource(\n    agentSource: string_book,\n    options?: ResolveInheritedAgentSourceOptions,\n): Promise<string_book> {\n    const context = createAgentImportContext(options);\n    const parentContext = await resolveParentAgentContext(agentSource, context);\n    const resolvedBuild = await resolveAgentSourceBuild(agentSource, context, parentContext);\n    const finalizedBuild = applyImplicitAdamInheritance(resolvedBuild, parentContext, context.adamAgentUrl);\n\n    return finalizeResolvedAgentSource(finalizedBuild);\n}\n\n// TODO: [🈲] Create a function that can manipulate books by modifying commitments, splitting the book up into commitments or syntactic tokens, and editing or deleting these via object methods.\n// TODO: [🐱‍🚀][⏩] This function should be in `/src` and exported from `@promptbook/core`\n","numLines":828,"startLine":1,"totalLines":828}}}
