{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Tv3XwP4ijkd4xdyejmyUtU","type":"tool_result","content":"1\timport type { AgentReferenceResolver } from '../../../../../src/book-2.0/agent-source/AgentReferenceResolver';\n2\timport { normalizeAgentName } from '../../../../../src/book-2.0/agent-source/normalizeAgentName';\n3\timport type { TeammateProfile } from '../../../../../src/book-2.0/agent-source/TeammateProfileResolver';\n4\timport {\n5\t    VOID_PSEUDO_AGENT_REFERENCE,\n6\t    createPseudoAgentUrl,\n7\t    isPseudoAgentAllowedInCommitment,\n8\t    resolvePseudoAgentKindFromReference,\n9\t} from '../../../../../src/book-2.0/agent-source/pseudoAgentReferences';\n10\timport type { AgentCollection } from '../../../../../src/collection/agent-collection/AgentCollection';\n11\timport type { BookCommitment } from '../../../../../src/commitments/_base/BookCommitment';\n12\timport {\n13\t    type AgentReferenceResolutionIssue,\n14\t    type IssueTrackingAgentReferenceResolver,\n15\t} from './AgentReferenceResolutionIssue';\n16\timport { extractAgentReferenceTokens } from './extractAgentReferenceTokens';\n17\timport { resolveAgentRouteIdentifier } from '../agentIdentifier';\n18\t\n19\t/**\n20\t * Dependencies required to resolve local/federated compact references.\n21\t */\n22\ttype ServerResolverOptions = {\n23\t    readonly agentCollection: AgentCollection;\n24\t    readonly localServerUrl: string;\n25\t    readonly federatedServers?: readonly string[];\n26\t};\n27\t\n28\t/**\n29\t * Cached lookup maps fetched from a federated server.\n30\t */\n31\ttype RemoteAgentLookup = {\n32\t    readonly byName: Map<string, string>;\n33\t    readonly byId: Map<string, string>;\n34\t};\n35\t\n36\t/**\n37\t * Lightweight heuristic for identifying base58-like permanent IDs.\n38\t */\n39\tconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\n40\t\n41\t/**\n42\t * Upper bound for in-memory unresolved-reference issue tracking.\n43\t */\n44\tconst MAX_TRACKED_RESOLUTION_ISSUES = 200;\n45\t\n46\t/**\n47\t * Upper bound for one federated-agent lookup request before falling back to an empty cache.\n48\t *\n49\t * @private\n50\t */\n51\tconst FEDERATED_AGENT_LOOKUP_TIMEOUT_MS = 1_500;\n52\t\n53\t/**\n54\t * Creates a resolver backed by the Agents Server collection and configured federated servers.\n55\t *\n56\t * @param options - Resolver dependencies\n57\t * @returns Agent reference resolver for the current agents server instance\n58\t *\n59\t * @private\n60\t */\n61\texport async function createServerAgentReferenceResolver(\n62\t    options: ServerResolverOptions,\n63\t): Promise<AgentReferenceResolver> {\n64\t    const resolver = new ServerAgentReferenceResolver(options);\n65\t    await resolver.initialize();\n66\t    return resolver;\n67\t}\n68\t\n69\t/**\n70\t * Agents Server resolver that expands compact references and tracks unresolved tokens.\n71\t */\n72\tclass ServerAgentReferenceResolver implements IssueTrackingAgentReferenceResolver {\n73\t    private readonly agentCollection: AgentCollection;\n74\t    private readonly localServerUrl: string;\n75\t    private readonly federatedServers: string[];\n76\t    private readonly localNameToUrl = new Map<string, string>();\n77\t    private readonly localIdToUrl = new Map<string, string>();\n78\t    private readonly localUrlToProfile = new Map<string, TeammateProfile>();\n79\t    private readonly remoteCaches = new Map<string, RemoteAgentLookup>();\n80\t    private readonly remoteRequests = new Map<string, Promise<RemoteAgentLookup>>();\n81\t    private readonly resolutionIssues: Array<AgentReferenceResolutionIssue> = [];\n82\t\n83\t    public constructor(options: ServerResolverOptions) {\n84\t        this.agentCollection = options.agentCollection;\n85\t        this.localServerUrl = ServerAgentReferenceResolver.normalizeServerUrl(options.localServerUrl);\n86\t        const servers = options.federatedServers || [];\n87\t        this.federatedServers = [\n88\t            ...new Set(\n89\t                servers\n90\t                    .map(ServerAgentReferenceResolver.normalizeServerUrl)\n91\t                    .filter((server) => server.length > 0 && server !== this.localServerUrl),\n92\t            ),\n93\t        ];\n94\t    }\n95\t\n96\t    public async initialize(): Promise<void> {\n97\t        const agents = await this.agentCollection.listAgents();\n98\t        for (const agent of agents) {\n99\t            const routeIdentifier = resolveAgentRouteIdentifier(agent);\n100\t            const url = this.buildLocalAgentUrl(routeIdentifier);\n101\t            this.localNameToUrl.set(normalizeAgentName(agent.agentName), url);\n102\t            this.localNameToUrl.set(agent.agentName, url);\n103\t            if (agent.permanentId) {\n104\t                this.localIdToUrl.set(agent.permanentId, url);\n105\t            }\n106\t\n107\t            const profile: TeammateProfile = {\n108\t                agentName: agent.agentName,\n109\t                personaDescription: agent.personaDescription,\n110\t            };\n111\t            this.localUrlToProfile.set(url, profile);\n112\t\n113\t            if (routeIdentifier !== agent.agentName) {\n114\t                this.localUrlToProfile.set(this.buildLocalAgentUrl(agent.agentName), profile);\n115\t            }\n116\t        }\n117\t    }\n118\t\n119\t    /**\n120\t     * Drains and returns unresolved-reference issues captured in previous resolutions.\n121\t     */\n122\t    public consumeResolutionIssues(): Array<AgentReferenceResolutionIssue> {\n123\t        const issues = [...this.resolutionIssues];\n124\t        this.resolutionIssues.length = 0;\n125\t        return issues;\n126\t    }\n127\t\n128\t    /**\n129\t     * Returns the human-readable agent profile for a teammate URL if it belongs to this server.\n130\t     *\n131\t     * Used during TEAM commitment processing to enrich tool definitions with real agent names\n132\t     * and profile descriptions instead of technical IDs.\n133\t     *\n134\t     * @param url - Canonical teammate URL from the resolved TEAM commitment content.\n135\t     * @returns Agent profile or `null` when the URL is not a local agent.\n136\t     */\n137\t    public async resolveTeammateProfile(url: string): Promise<TeammateProfile | null> {\n138\t        return this.localUrlToProfile.get(url) ?? null;\n139\t    }\n140\t\n141\t    /**\n142\t     * Rewrites compact references in commitment content into canonical URLs.\n143\t     *\n144\t     * Missing references are handled with commitment-specific safe fallbacks instead of throwing.\n145\t     */\n146\t    public async resolveCommitmentContent(commitmentType: BookCommitment, content: string): Promise<string> {\n147\t        if (!content) {\n148\t            return content;\n149\t        }\n150\t"}]},"parent_tool_use_id":null,"session_id":"5fcf42d8-e79f-4895-8760-3d62c1e26adf","uuid":"3e4c060b-bbc6-4373-b690-8e8a3d72c28b","timestamp":"2026-07-07T15:24:34.648Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\me\\work\\ai\\promptbook\\apps\\agents-server\\src\\utils\\agentReferenceResolver\\createServerAgentReferenceResolver.ts","content":"import type { AgentReferenceResolver } from '../../../../../src/book-2.0/agent-source/AgentReferenceResolver';\nimport { normalizeAgentName } from '../../../../../src/book-2.0/agent-source/normalizeAgentName';\nimport type { TeammateProfile } from '../../../../../src/book-2.0/agent-source/TeammateProfileResolver';\nimport {\n    VOID_PSEUDO_AGENT_REFERENCE,\n    createPseudoAgentUrl,\n    isPseudoAgentAllowedInCommitment,\n    resolvePseudoAgentKindFromReference,\n} from '../../../../../src/book-2.0/agent-source/pseudoAgentReferences';\nimport type { AgentCollection } from '../../../../../src/collection/agent-collection/AgentCollection';\nimport type { BookCommitment } from '../../../../../src/commitments/_base/BookCommitment';\nimport {\n    type AgentReferenceResolutionIssue,\n    type IssueTrackingAgentReferenceResolver,\n} from './AgentReferenceResolutionIssue';\nimport { extractAgentReferenceTokens } from './extractAgentReferenceTokens';\nimport { resolveAgentRouteIdentifier } from '../agentIdentifier';\n\n/**\n * Dependencies required to resolve local/federated compact references.\n */\ntype ServerResolverOptions = {\n    readonly agentCollection: AgentCollection;\n    readonly localServerUrl: string;\n    readonly federatedServers?: readonly string[];\n};\n\n/**\n * Cached lookup maps fetched from a federated server.\n */\ntype RemoteAgentLookup = {\n    readonly byName: Map<string, string>;\n    readonly byId: Map<string, string>;\n};\n\n/**\n * Lightweight heuristic for identifying base58-like permanent IDs.\n */\nconst BASE58_PATTERN = /^[1-9A-HJ-NP-Za-km-z]+$/;\n\n/**\n * Upper bound for in-memory unresolved-reference issue tracking.\n */\nconst MAX_TRACKED_RESOLUTION_ISSUES = 200;\n\n/**\n * Upper bound for one federated-agent lookup request before falling back to an empty cache.\n *\n * @private\n */\nconst FEDERATED_AGENT_LOOKUP_TIMEOUT_MS = 1_500;\n\n/**\n * Creates a resolver backed by the Agents Server collection and configured federated servers.\n *\n * @param options - Resolver dependencies\n * @returns Agent reference resolver for the current agents server instance\n *\n * @private\n */\nexport async function createServerAgentReferenceResolver(\n    options: ServerResolverOptions,\n): Promise<AgentReferenceResolver> {\n    const resolver = new ServerAgentReferenceResolver(options);\n    await resolver.initialize();\n    return resolver;\n}\n\n/**\n * Agents Server resolver that expands compact references and tracks unresolved tokens.\n */\nclass ServerAgentReferenceResolver implements IssueTrackingAgentReferenceResolver {\n    private readonly agentCollection: AgentCollection;\n    private readonly localServerUrl: string;\n    private readonly federatedServers: string[];\n    private readonly localNameToUrl = new Map<string, string>();\n    private readonly localIdToUrl = new Map<string, string>();\n    private readonly localUrlToProfile = new Map<string, TeammateProfile>();\n    private readonly remoteCaches = new Map<string, RemoteAgentLookup>();\n    private readonly remoteRequests = new Map<string, Promise<RemoteAgentLookup>>();\n    private readonly resolutionIssues: Array<AgentReferenceResolutionIssue> = [];\n\n    public constructor(options: ServerResolverOptions) {\n        this.agentCollection = options.agentCollection;\n        this.localServerUrl = ServerAgentReferenceResolver.normalizeServerUrl(options.localServerUrl);\n        const servers = options.federatedServers || [];\n        this.federatedServers = [\n            ...new Set(\n                servers\n                    .map(ServerAgentReferenceResolver.normalizeServerUrl)\n                    .filter((server) => server.length > 0 && server !== this.localServerUrl),\n            ),\n        ];\n    }\n\n    public async initialize(): Promise<void> {\n        const agents = await this.agentCollection.listAgents();\n        for (const agent of agents) {\n            const routeIdentifier = resolveAgentRouteIdentifier(agent);\n            const url = this.buildLocalAgentUrl(routeIdentifier);\n            this.localNameToUrl.set(normalizeAgentName(agent.agentName), url);\n            this.localNameToUrl.set(agent.agentName, url);\n            if (agent.permanentId) {\n                this.localIdToUrl.set(agent.permanentId, url);\n            }\n\n            const profile: TeammateProfile = {\n                agentName: agent.agentName,\n                personaDescription: agent.personaDescription,\n            };\n            this.localUrlToProfile.set(url, profile);\n\n            if (routeIdentifier !== agent.agentName) {\n                this.localUrlToProfile.set(this.buildLocalAgentUrl(agent.agentName), profile);\n            }\n        }\n    }\n\n    /**\n     * Drains and returns unresolved-reference issues captured in previous resolutions.\n     */\n    public consumeResolutionIssues(): Array<AgentReferenceResolutionIssue> {\n        const issues = [...this.resolutionIssues];\n        this.resolutionIssues.length = 0;\n        return issues;\n    }\n\n    /**\n     * Returns the human-readable agent profile for a teammate URL if it belongs to this server.\n     *\n     * Used during TEAM commitment processing to enrich tool definitions with real agent names\n     * and profile descriptions instead of technical IDs.\n     *\n     * @param url - Canonical teammate URL from the resolved TEAM commitment content.\n     * @returns Agent profile or `null` when the URL is not a local agent.\n     */\n    public async resolveTeammateProfile(url: string): Promise<TeammateProfile | null> {\n        return this.localUrlToProfile.get(url) ?? null;\n    }\n\n    /**\n     * Rewrites compact references in commitment content into canonical URLs.\n     *\n     * Missing references are handled with commitment-specific safe fallbacks instead of throwing.\n     */\n    public async resolveCommitmentContent(commitmentType: BookCommitment, content: string): Promise<string> {\n        if (!content) {\n            return content;\n        }\n","numLines":150,"startLine":1,"totalLines":450}}}
