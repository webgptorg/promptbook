{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xg5jZnjzeL2mHv2kZb7z3N","type":"tool_result","content":"1\timport type { AgentReferenceResolver } from '../../../../../src/book-2.0/agent-source/AgentReferenceResolver';\n2\timport { normalizeAgentName } from '../../../../../src/book-2.0/agent-source/normalizeAgentName';\n3\timport { parseAgentSourceWithCommitments } from '../../../../../src/book-2.0/agent-source/parseAgentSourceWithCommitments';\n4\timport { parseAgentSource } from '../../../../../src/book-2.0/agent-source/parseAgentSource';\n5\timport type { string_book } from '../../../../../src/book-2.0/agent-source/string_book';\n6\timport type { AgentCollection } from '../../../../../src/collection/agent-collection/AgentCollection';\n7\timport type { BookCommitment } from '../../../../../src/commitments/_base/BookCommitment';\n8\timport type { string_agent_permanent_id, string_agent_url } from '../../../../../src/types/typeAliases';\n9\timport { extractAgentReferenceTokens } from './extractAgentReferenceTokens';\n10\t\n11\t/**\n12\t * Prefix used for synthetic route identifiers that point to embedded in-book agents.\n13\t */\n14\tconst BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX = '__book_agent__~';\n15\t\n16\t/**\n17\t * Regex pattern to match horizontal lines (markdown thematic breaks).\n18\t */\n19\tconst HORIZONTAL_LINE_PATTERN = /^[\\s]*[-_*][\\s]*[-_*][\\s]*[-_*][\\s]*[-_*]*[\\s]*$/;\n20\t\n21\t/**\n22\t * Commitment types that can reference other agents.\n23\t */\n24\tconst AGENT_REFERENCE_COMMITMENT_TYPES: ReadonlySet<BookCommitment> = new Set<BookCommitment>([\n25\t    'FROM',\n26\t    'IMPORT',\n27\t    'IMPORTS',\n28\t    'TEAM',\n29\t]);\n30\t\n31\t/**\n32\t * Minimal collection shape required for resolving book-scoped agent sources.\n33\t */\n34\ttype AgentSourceCollection = Pick<AgentCollection, 'getAgentPermanentId' | 'getAgentSource'>;\n35\t\n36\t/**\n37\t * Type describing issue tracking resolver.\n38\t */\n39\ttype IssueTrackingResolver = AgentReferenceResolver & {\n40\t    consumeResolutionIssues(): unknown[];\n41\t};\n42\t\n43\t/**\n44\t * Resolved context for one route-level agent identifier (regular or embedded).\n45\t */\n46\texport type ResolvedBookScopedAgentContext = {\n47\t    readonly requestedAgentIdentifier: string;\n48\t    readonly canonicalAgentIdentifier: string;\n49\t    readonly canonicalAgentUrl: string_agent_url;\n50\t    readonly currentAgentAliases: ReadonlyArray<string_agent_url>;\n51\t    readonly resolvedAgentName: string;\n52\t    readonly unresolvedAgentSource: string_book;\n53\t    readonly parentAgentPermanentId: string_agent_permanent_id;\n54\t    readonly parentAgentSource: string_book;\n55\t    readonly isBookScopedAgent: boolean;\n56\t    readonly scopedAgentReferenceResolver: AgentReferenceResolver;\n57\t};\n58\t\n59\t/**\n60\t * Parsed descriptor for a synthetic in-book agent identifier.\n61\t */\n62\texport type ParsedBookScopedAgentIdentifier = {\n63\t    readonly parentAgentIdentifier: string;\n64\t    readonly embeddedAgentName: string;\n65\t};\n66\t\n67\t/**\n68\t * Creates a synthetic route identifier for an embedded in-book agent.\n69\t *\n70\t * @param parentAgentIdentifier - Parent agent name/permanent id.\n71\t * @param embeddedAgentName - Embedded agent reference name.\n72\t * @returns Route-safe identifier for `/agents/:agentName` URLs.\n73\t */\n74\texport function createBookScopedAgentIdentifier(\n75\t    parentAgentIdentifier: string,\n76\t    embeddedAgentName: string,\n77\t): string {\n78\t    const normalizedEmbeddedAgentName = normalizeAgentName(embeddedAgentName);\n79\t    const encodedParentAgentIdentifier = Buffer.from(parentAgentIdentifier, 'utf8').toString('base64url');\n80\t    const encodedEmbeddedAgentName = Buffer.from(normalizedEmbeddedAgentName, 'utf8').toString('base64url');\n81\t    return `${BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX}${encodedParentAgentIdentifier}~${encodedEmbeddedAgentName}`;\n82\t}\n83\t\n84\t/**\n85\t * Parses a synthetic in-book identifier back into `(parent, embedded)` values.\n86\t *\n87\t * @param agentIdentifier - Incoming route identifier.\n88\t * @returns Parsed identifier or `null` when not book-scoped.\n89\t */\n90\texport function parseBookScopedAgentIdentifier(agentIdentifier: string): ParsedBookScopedAgentIdentifier | null {\n91\t    if (!agentIdentifier.startsWith(BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX)) {\n92\t        return null;\n93\t    }\n94\t\n95\t    const serializedParts = agentIdentifier\n96\t        .slice(BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX.length)\n97\t        .split('~')\n98\t        .filter(Boolean);\n99\t    if (serializedParts.length !== 2) {\n100\t        return null;\n101\t    }\n102\t\n103\t    const [encodedParentAgentIdentifier, encodedEmbeddedAgentName] = serializedParts;\n104\t    if (!encodedParentAgentIdentifier || !encodedEmbeddedAgentName) {\n105\t        return null;\n106\t    }\n107\t\n108\t    try {\n109\t        const parentAgentIdentifier = Buffer.from(encodedParentAgentIdentifier, 'base64url').toString('utf8');\n110\t        const embeddedAgentName = Buffer.from(encodedEmbeddedAgentName, 'base64url').toString('utf8');\n111\t\n112\t        if (!parentAgentIdentifier || !embeddedAgentName) {\n113\t            return null;\n114\t        }\n115\t\n116\t        return {\n117\t            parentAgentIdentifier,\n118\t            embeddedAgentName: normalizeAgentName(embeddedAgentName),\n119\t        };\n120\t    } catch {"}]},"parent_tool_use_id":null,"session_id":"5fcf42d8-e79f-4895-8760-3d62c1e26adf","uuid":"c523b606-f67c-43d2-ad27-1be2827ec0e5","timestamp":"2026-07-07T15:24:34.167Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\me\\work\\ai\\promptbook\\apps\\agents-server\\src\\utils\\agentReferenceResolver\\bookScopedAgentReferences.ts","content":"import type { AgentReferenceResolver } from '../../../../../src/book-2.0/agent-source/AgentReferenceResolver';\nimport { normalizeAgentName } from '../../../../../src/book-2.0/agent-source/normalizeAgentName';\nimport { parseAgentSourceWithCommitments } from '../../../../../src/book-2.0/agent-source/parseAgentSourceWithCommitments';\nimport { parseAgentSource } from '../../../../../src/book-2.0/agent-source/parseAgentSource';\nimport type { string_book } from '../../../../../src/book-2.0/agent-source/string_book';\nimport type { AgentCollection } from '../../../../../src/collection/agent-collection/AgentCollection';\nimport type { BookCommitment } from '../../../../../src/commitments/_base/BookCommitment';\nimport type { string_agent_permanent_id, string_agent_url } from '../../../../../src/types/typeAliases';\nimport { extractAgentReferenceTokens } from './extractAgentReferenceTokens';\n\n/**\n * Prefix used for synthetic route identifiers that point to embedded in-book agents.\n */\nconst BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX = '__book_agent__~';\n\n/**\n * Regex pattern to match horizontal lines (markdown thematic breaks).\n */\nconst HORIZONTAL_LINE_PATTERN = /^[\\s]*[-_*][\\s]*[-_*][\\s]*[-_*][\\s]*[-_*]*[\\s]*$/;\n\n/**\n * Commitment types that can reference other agents.\n */\nconst AGENT_REFERENCE_COMMITMENT_TYPES: ReadonlySet<BookCommitment> = new Set<BookCommitment>([\n    'FROM',\n    'IMPORT',\n    'IMPORTS',\n    'TEAM',\n]);\n\n/**\n * Minimal collection shape required for resolving book-scoped agent sources.\n */\ntype AgentSourceCollection = Pick<AgentCollection, 'getAgentPermanentId' | 'getAgentSource'>;\n\n/**\n * Type describing issue tracking resolver.\n */\ntype IssueTrackingResolver = AgentReferenceResolver & {\n    consumeResolutionIssues(): unknown[];\n};\n\n/**\n * Resolved context for one route-level agent identifier (regular or embedded).\n */\nexport type ResolvedBookScopedAgentContext = {\n    readonly requestedAgentIdentifier: string;\n    readonly canonicalAgentIdentifier: string;\n    readonly canonicalAgentUrl: string_agent_url;\n    readonly currentAgentAliases: ReadonlyArray<string_agent_url>;\n    readonly resolvedAgentName: string;\n    readonly unresolvedAgentSource: string_book;\n    readonly parentAgentPermanentId: string_agent_permanent_id;\n    readonly parentAgentSource: string_book;\n    readonly isBookScopedAgent: boolean;\n    readonly scopedAgentReferenceResolver: AgentReferenceResolver;\n};\n\n/**\n * Parsed descriptor for a synthetic in-book agent identifier.\n */\nexport type ParsedBookScopedAgentIdentifier = {\n    readonly parentAgentIdentifier: string;\n    readonly embeddedAgentName: string;\n};\n\n/**\n * Creates a synthetic route identifier for an embedded in-book agent.\n *\n * @param parentAgentIdentifier - Parent agent name/permanent id.\n * @param embeddedAgentName - Embedded agent reference name.\n * @returns Route-safe identifier for `/agents/:agentName` URLs.\n */\nexport function createBookScopedAgentIdentifier(\n    parentAgentIdentifier: string,\n    embeddedAgentName: string,\n): string {\n    const normalizedEmbeddedAgentName = normalizeAgentName(embeddedAgentName);\n    const encodedParentAgentIdentifier = Buffer.from(parentAgentIdentifier, 'utf8').toString('base64url');\n    const encodedEmbeddedAgentName = Buffer.from(normalizedEmbeddedAgentName, 'utf8').toString('base64url');\n    return `${BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX}${encodedParentAgentIdentifier}~${encodedEmbeddedAgentName}`;\n}\n\n/**\n * Parses a synthetic in-book identifier back into `(parent, embedded)` values.\n *\n * @param agentIdentifier - Incoming route identifier.\n * @returns Parsed identifier or `null` when not book-scoped.\n */\nexport function parseBookScopedAgentIdentifier(agentIdentifier: string): ParsedBookScopedAgentIdentifier | null {\n    if (!agentIdentifier.startsWith(BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX)) {\n        return null;\n    }\n\n    const serializedParts = agentIdentifier\n        .slice(BOOK_SCOPED_AGENT_IDENTIFIER_PREFIX.length)\n        .split('~')\n        .filter(Boolean);\n    if (serializedParts.length !== 2) {\n        return null;\n    }\n\n    const [encodedParentAgentIdentifier, encodedEmbeddedAgentName] = serializedParts;\n    if (!encodedParentAgentIdentifier || !encodedEmbeddedAgentName) {\n        return null;\n    }\n\n    try {\n        const parentAgentIdentifier = Buffer.from(encodedParentAgentIdentifier, 'base64url').toString('utf8');\n        const embeddedAgentName = Buffer.from(encodedEmbeddedAgentName, 'base64url').toString('utf8');\n\n        if (!parentAgentIdentifier || !embeddedAgentName) {\n            return null;\n        }\n\n        return {\n            parentAgentIdentifier,\n            embeddedAgentName: normalizeAgentName(embeddedAgentName),\n        };\n    } catch {","numLines":120,"startLine":1,"totalLines":353}}}
