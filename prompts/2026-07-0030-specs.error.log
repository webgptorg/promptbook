{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013VbKUqajEekaSdxRjnsu6v","type":"tool_result","content":"1\timport { padBook } from '../../../../src/book-2.0/agent-source/padBook';\n2\timport type { string_book } from '../../../../src/book-2.0/agent-source/string_book';\n3\timport { validateBook } from '../../../../src/book-2.0/agent-source/string_book';\n4\timport { spaceTrim } from '../../../../src/utils/organization/spaceTrim';\n5\t\n6\t/**\n7\t * Inputs required to persist one self-learning update without rewriting inherited source snapshots.\n8\t */\n9\ttype ResolveAppendOnlySelfLearningAgentSourceOptions = {\n10\t    /**\n11\t     * Editable child source currently stored in the database.\n12\t     */\n13\t    readonly unresolvedAgentSourceBeforeLearning: string_book;\n14\t    /**\n15\t     * Effective resolved source used during runtime before self-learning started.\n16\t     */\n17\t    readonly resolvedAgentSourceBeforeLearning: string_book;\n18\t    /**\n19\t     * Effective resolved source after self-learning finished in memory.\n20\t     */\n21\t    readonly resolvedAgentSourceAfterLearning: string_book;\n22\t};\n23\t\n24\t/**\n25\t * Normalizes one book string for append-delta and idempotency comparisons.\n26\t *\n27\t * @param source - Raw book text to normalize.\n28\t * @returns Comparable normalized text.\n29\t */\n30\tfunction normalizeBookForComparison(source: string): string {\n31\t    return spaceTrim(source).replace(/\\r\\n/g, '\\n');\n32\t}\n33\t\n34\t/**\n35\t * Extracts only the suffix appended during self-learning from the resolved runtime source.\n36\t *\n37\t * Returns `null` when no new suffix exists or when the change is not append-only.\n38\t *\n39\t * @param sourceBeforeLearning - Effective source used before learning.\n40\t * @param sourceAfterLearning - Effective source after learning.\n41\t * @returns Newly appended section, or `null` when unsafe/unavailable.\n42\t */\n43\tfunction extractResolvedSelfLearningAppendedSection(\n44\t    sourceBeforeLearning: string_book,\n45\t    sourceAfterLearning: string_book,\n46\t): string | null {\n47\t    const normalizedBefore = normalizeBookForComparison(sourceBeforeLearning);\n48\t    const normalizedAfter = normalizeBookForComparison(sourceAfterLearning);\n49\t\n50\t    if (normalizedBefore === normalizedAfter) {\n51\t        return null;\n52\t    }\n53\t\n54\t    if (!normalizedAfter.startsWith(normalizedBefore)) {\n55\t        return null;\n56\t    }\n57\t\n58\t    const appendedSection = spaceTrim(normalizedAfter.slice(normalizedBefore.length));\n59\t    return appendedSection.length > 0 ? appendedSection : null;\n60\t}\n61\t\n62\t/**\n63\t * Produces the next stored child source using append-only semantics.\n64\t *\n65\t * The function derives only the newly appended part from resolved runtime sources, then appends that part\n66\t * onto the unresolved child source. Parent/inherited source materialized in the resolved runtime source\n67\t * is intentionally never copied into stored child source.\n68\t *\n69\t * Returns `null` when there is nothing new to persist, when the update is non-append-only,\n70\t * or when the appended section is already present in the unresolved child source.\n71\t *\n72\t * @param options - Persistence inputs from one self-learning run.\n73\t * @returns Next unresolved child source to store, or `null` when no safe write should occur.\n74\t */\n75\texport function resolveAppendOnlySelfLearningAgentSource(\n76\t    options: ResolveAppendOnlySelfLearningAgentSourceOptions,\n77\t): string_book | null {\n78\t    const appendedSection = extractResolvedSelfLearningAppendedSection(\n79\t        options.resolvedAgentSourceBeforeLearning,\n80\t        options.resolvedAgentSourceAfterLearning,\n81\t    );\n82\t\n83\t    if (!appendedSection) {\n84\t        return null;\n85\t    }\n86\t\n87\t    const normalizedUnresolvedSource = normalizeBookForComparison(options.unresolvedAgentSourceBeforeLearning);\n88\t    const normalizedAppendedSection = normalizeBookForComparison(appendedSection);\n89\t\n90\t    if (!normalizedAppendedSection) {\n91\t        return null;\n92\t    }\n93\t\n94\t    if (normalizedUnresolvedSource.includes(normalizedAppendedSection)) {\n95\t        return null;\n96\t    }\n97\t\n98\t    return padBook(validateBook(`${normalizedUnresolvedSource}\\n\\n${normalizedAppendedSection}`));\n99\t}\n100\t"}]},"parent_tool_use_id":null,"session_id":"5fcf42d8-e79f-4895-8760-3d62c1e26adf","uuid":"9bb40236-0c42-406a-a03d-879dc6d4c1ec","timestamp":"2026-07-07T15:25:09.433Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\me\\work\\ai\\promptbook\\apps\\agents-server\\src\\utils\\resolveAppendOnlySelfLearningAgentSource.ts","content":"import { padBook } from '../../../../src/book-2.0/agent-source/padBook';\nimport type { string_book } from '../../../../src/book-2.0/agent-source/string_book';\nimport { validateBook } from '../../../../src/book-2.0/agent-source/string_book';\nimport { spaceTrim } from '../../../../src/utils/organization/spaceTrim';\n\n/**\n * Inputs required to persist one self-learning update without rewriting inherited source snapshots.\n */\ntype ResolveAppendOnlySelfLearningAgentSourceOptions = {\n    /**\n     * Editable child source currently stored in the database.\n     */\n    readonly unresolvedAgentSourceBeforeLearning: string_book;\n    /**\n     * Effective resolved source used during runtime before self-learning started.\n     */\n    readonly resolvedAgentSourceBeforeLearning: string_book;\n    /**\n     * Effective resolved source after self-learning finished in memory.\n     */\n    readonly resolvedAgentSourceAfterLearning: string_book;\n};\n\n/**\n * Normalizes one book string for append-delta and idempotency comparisons.\n *\n * @param source - Raw book text to normalize.\n * @returns Comparable normalized text.\n */\nfunction normalizeBookForComparison(source: string): string {\n    return spaceTrim(source).replace(/\\r\\n/g, '\\n');\n}\n\n/**\n * Extracts only the suffix appended during self-learning from the resolved runtime source.\n *\n * Returns `null` when no new suffix exists or when the change is not append-only.\n *\n * @param sourceBeforeLearning - Effective source used before learning.\n * @param sourceAfterLearning - Effective source after learning.\n * @returns Newly appended section, or `null` when unsafe/unavailable.\n */\nfunction extractResolvedSelfLearningAppendedSection(\n    sourceBeforeLearning: string_book,\n    sourceAfterLearning: string_book,\n): string | null {\n    const normalizedBefore = normalizeBookForComparison(sourceBeforeLearning);\n    const normalizedAfter = normalizeBookForComparison(sourceAfterLearning);\n\n    if (normalizedBefore === normalizedAfter) {\n        return null;\n    }\n\n    if (!normalizedAfter.startsWith(normalizedBefore)) {\n        return null;\n    }\n\n    const appendedSection = spaceTrim(normalizedAfter.slice(normalizedBefore.length));\n    return appendedSection.length > 0 ? appendedSection : null;\n}\n\n/**\n * Produces the next stored child source using append-only semantics.\n *\n * The function derives only the newly appended part from resolved runtime sources, then appends that part\n * onto the unresolved child source. Parent/inherited source materialized in the resolved runtime source\n * is intentionally never copied into stored child source.\n *\n * Returns `null` when there is nothing new to persist, when the update is non-append-only,\n * or when the appended section is already present in the unresolved child source.\n *\n * @param options - Persistence inputs from one self-learning run.\n * @returns Next unresolved child source to store, or `null` when no safe write should occur.\n */\nexport function resolveAppendOnlySelfLearningAgentSource(\n    options: ResolveAppendOnlySelfLearningAgentSourceOptions,\n): string_book | null {\n    const appendedSection = extractResolvedSelfLearningAppendedSection(\n        options.resolvedAgentSourceBeforeLearning,\n        options.resolvedAgentSourceAfterLearning,\n    );\n\n    if (!appendedSection) {\n        return null;\n    }\n\n    const normalizedUnresolvedSource = normalizeBookForComparison(options.unresolvedAgentSourceBeforeLearning);\n    const normalizedAppendedSection = normalizeBookForComparison(appendedSection);\n\n    if (!normalizedAppendedSection) {\n        return null;\n    }\n\n    if (normalizedUnresolvedSource.includes(normalizedAppendedSection)) {\n        return null;\n    }\n\n    return padBook(validateBook(`${normalizedUnresolvedSource}\\n\\n${normalizedAppendedSection}`));\n}\n","numLines":100,"startLine":1,"totalLines":100}}}
