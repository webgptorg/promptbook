{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012PFwH3KPkJsLNxRqVQQS5n","type":"tool_result","content":"1\timport { RemoteAgent } from '@promptbook-local/core';\n2\timport { getWellKnownAgentUrl } from './getWellKnownAgentUrl';\n3\t\n4\t/**\n5\t * Shared in-flight Teacher agent connection promise.\n6\t */\n7\tlet pendingTeacherRemoteAgent: Promise<RemoteAgent> | null = null;\n8\t\n9\t/**\n10\t * Connected Teacher agent reused across server-side chat requests.\n11\t */\n12\tlet cachedTeacherRemoteAgent: RemoteAgent | null = null;\n13\t\n14\t/**\n15\t * Resolves the well-known Teacher agent once and reuses the connected remote profile afterwards.\n16\t */\n17\texport async function getTeacherRemoteAgent(): Promise<RemoteAgent> {\n18\t    if (cachedTeacherRemoteAgent) {\n19\t        return cachedTeacherRemoteAgent;\n20\t    }\n21\t\n22\t    if (pendingTeacherRemoteAgent) {\n23\t        return pendingTeacherRemoteAgent;\n24\t    }\n25\t\n26\t    pendingTeacherRemoteAgent = (async (): Promise<RemoteAgent> => {\n27\t        try {\n28\t            const teacherRemoteAgent = await RemoteAgent.connect({\n29\t                agentUrl: await getWellKnownAgentUrl('TEACHER'),\n30\t            });\n31\t            cachedTeacherRemoteAgent = teacherRemoteAgent;\n32\t            return teacherRemoteAgent;\n33\t        } finally {\n34\t            pendingTeacherRemoteAgent = null;\n35\t        }\n36\t    })();\n37\t\n38\t    return pendingTeacherRemoteAgent;\n39\t}\n40\t"}]},"parent_tool_use_id":null,"session_id":"5fcf42d8-e79f-4895-8760-3d62c1e26adf","uuid":"164e16f9-ecd6-445d-8559-3f7dc199dd40","timestamp":"2026-07-07T15:25:28.163Z","tool_use_result":{"type":"text","file":{"filePath":"C:\\Users\\me\\work\\ai\\promptbook\\apps\\agents-server\\src\\utils\\getTeacherRemoteAgent.ts","content":"import { RemoteAgent } from '@promptbook-local/core';\nimport { getWellKnownAgentUrl } from './getWellKnownAgentUrl';\n\n/**\n * Shared in-flight Teacher agent connection promise.\n */\nlet pendingTeacherRemoteAgent: Promise<RemoteAgent> | null = null;\n\n/**\n * Connected Teacher agent reused across server-side chat requests.\n */\nlet cachedTeacherRemoteAgent: RemoteAgent | null = null;\n\n/**\n * Resolves the well-known Teacher agent once and reuses the connected remote profile afterwards.\n */\nexport async function getTeacherRemoteAgent(): Promise<RemoteAgent> {\n    if (cachedTeacherRemoteAgent) {\n        return cachedTeacherRemoteAgent;\n    }\n\n    if (pendingTeacherRemoteAgent) {\n        return pendingTeacherRemoteAgent;\n    }\n\n    pendingTeacherRemoteAgent = (async (): Promise<RemoteAgent> => {\n        try {\n            const teacherRemoteAgent = await RemoteAgent.connect({\n                agentUrl: await getWellKnownAgentUrl('TEACHER'),\n            });\n            cachedTeacherRemoteAgent = teacherRemoteAgent;\n            return teacherRemoteAgent;\n        } finally {\n            pendingTeacherRemoteAgent = null;\n        }\n    })();\n\n    return pendingTeacherRemoteAgent;\n}\n","numLines":40,"startLine":1,"totalLines":40}}}
