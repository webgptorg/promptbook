9.     database.exec(`CREATE TABLE IF NOT EXISTS ${quoteIdentifier(tableName)} (${primaryKey})`);\n810. \n811.     const existingColumns = new Set(\n812.         database\n813.             .prepare(`PRAGMA table_info(${quoteIdentifier(tableName)})`)\n814.             .all()\n815.             .map((row) => String(row.name)),\n816.     );\n817.     const columnsToEnsure = uniqueStrings([...requiredColumns, ...resolveUniqueIndexColumns(tableBaseName)]).filter(\n818.         (column) => column !== '*' && column !== 'id',\n819.     );\n820. \n821.     for (const column of columnsToEnsure) {\n822.         if (existingColumns.has(column)) {\n823.             continue;\n824.         }\n825. \n826.         database.exec(\n827.             `ALTER TABLE ${quoteIdentifier(tableName)} ADD COLUMN ${quoteIdentifier(column)} ${resolveSqliteColumnType(column)}`,\n828.         );\n829.         existingColumns.add(column);\n830.     }\n831. \n832.     ensureUniqueIndexes(database, tableName, tableBaseName);\n833. }\n834. \n835. /**\n836.  * Creates known unique indexes after required columns exist.\n837.  */\n838. function ensureUniqueIndexes(database: AgentsServerSqliteDatabase, tableName: string, tableBaseName: string): void {\n839.     const uniqueIndexes = UNIQUE_INDEX_COLUMNS_BY_TABLE.get(tableBaseName) || [];\n840. \n841.     for (const columns of uniqueIndexes) {\n842.         const indexName = `idx_${sanitizeSqlIdentifier(tableName)}_${columns.join('_')}_unique`;\n843.         const columnSql = columns.map(quoteIdentifier).join(', ');\n844.         database.exec(`CREATE UNIQUE INDEX IF NOT EXISTS ${quoteIdentifier(indexName)} ON ${quoteIdentifier(tableName)} (${columnSql})`);\n845.     }\n846. }\n847. \n848. /**\n849.  * Inserts one row into the table.\n850.  */\n851. function insertRow(\n852.     database: AgentsServerSqliteDatabase,\n853.     tableName: string,\n854.     row: Record<string, unknown>,\n855. ): { readonly lastInsertRowid: number | bigint } {\n856.     const columns = Object.keys(row).filter((column) => row[column] !== undefined);\n857. \n858.     if (columns.length === 0) {\n859.         return database.prepare(`INSERT INTO ${quoteIdentifier(tableName)} DEFAULT VALUES`).run();\n860.     }\n861. \n862.     const placeholders = columns.map(() => '?').join(', ');\n863.     const values = columns.map((column) => serializeValue(tableName, column, row[column]));\n864.     const sql = `INSERT INTO ${quoteIdentifier(tableName)} (${columns.map(quoteIdentifier).join(', ')}) VALUES (${placeholders})`;\n865. \n866.     return database.prepare(sql).run(...values);\n867. }\n868. \n869. /**\n870.  * Updates one row by SQLite rowid.\n871.  */\n872. function updateRowid(\n873.     database: AgentsServerSqliteDatabase,\n874.     tableName: string,\n875.     rowid: number | bigint,\n876.     row: Record<string, unknown>,\n877. ): void {\n878.     const columns = Object.keys(row).filter((column) => column !== 'id' && row[column] !== undefined);\n879.     if (columns.length === 0) {\n880.         return;\n881.     }\n882. \n883.     const assignments = columns.map((column) => `${quoteIdentifier(column)} = ?`).join(', ');\n884.     const values = columns.map((column) => serializeValue(tableName, column, row[column]));\n885.     database.prepare(`UPDATE ${quoteIdentifier(tableName)} SET ${assignments} WHERE rowid = ?`).run(...values, rowid);\n886. }\n887. \n888. /**\n889.  * Finds the rowid matching an upsert conflict target.\n890.  */\n891. function findConflictRowid(\n892.     database: AgentsServerSqliteDatabase,\n893.     tableName: string,\n894.     row: Record<string, unknown>,\n895.     conflictColumns: ReadonlyArray<string>,\n896. ): number | bigint | null {\n897.     if (conflictColumns.some((column) => row[column] === undefined)) {\n898.         return null;\n899.     }\n900. \n901.     const conditions = conflictColumns.map((column) => `${quoteIdentifier(column)} = ?`).join(' AND ');\n902.     const values = conflictColumns.map((column) => serializeValue(tableName, column, row[column]));\n903.     const result = database.prepare(`SELECT rowid FROM ${quoteIdentifier(tableName)} WHERE ${conditions} LIMIT 1`).get(...values);\n904. \n905.     return result ? (result.rowid as number | bigint) : null;\n906. }\n907. \n908. /**\n909.  * Selects rows by rowids for a mutation returning clause.\n910.  */\n911. function selectRowsByRowids(\n912.     database: AgentsServerSqliteDatabase,\n913.     tableName: string,\n914.     rowids: ReadonlyArray<number | bigint>,\n915.     selectedColumns: ReadonlyArray<string>,\n916. ): Array<Record<string, unknown>> {\n917.     if (rowids.length === 0) {\n918.         return [];\n919.     }\n920. \n921.     ensureTable(database, tableName, selectedColumns);\n922.     const placeholders = rowids.map(() => '?').join(', ');\n923.     const rows = database\n924.         .prepare(\n925.             `SELECT ${createSelectExpression(selectedColumns)} FROM ${quoteIdentifier(tableName)} WHERE rowid IN (${placeholders})`,\n926.         )\n927.         .all(...rowids);\n928. \n929.     return rows.map((row) => deserializeRow(tableName, row));\n930. }\n931. \n932. /**\n933.  * Creates SQL for one simple filter.\n934.  */\n935. function createFilterCondition(\n936.     tableName: string,\n937.     filter: LocalSqliteFilter,\n938. ): { readonly sql: string; readonly values: ReadonlyArray<unknown> } {\n939.     const column = quoteIdentifier(filter.column);\n940.     const value = serializeValue(tableName, filter.column, filter.value);\n941. \n942.     switch (filter.operator) {\n943.         case 'eq':\n944.             return value === null ? { sql: `${column} IS NULL`, values: [] } : { sql: `${column} = ?`, values: [value] };\n945.         case 'neq':\n946.             return value === null\n947.                 ? { sql: `${column} IS NOT NULL`, values: [] }\n948.                 : { sql: `${column} <> ?`, values: [value] };\n949.         case 'is':\n950.             return filter.value === null ? { sql: `${column} IS NULL`, values: [] } : { sql: `${column} IS ?`, values: [value] };\n951.         case 'not-is':\n952.             return filter.value === null ? { sql: `${column} IS NOT NULL`, values: [] } : { sql: `${column} IS NOT ?`, values: [value] };\n953.         case 'in': {\n954.             const values = Array.isArray(filter.value) ? filter.value.map((item) => serializeValue(tableName, filter.column, item)) : [];\n955.             if (values.length === 0) {\n956.                 return { sql: '0 = 1', values: [] };\n957.             }\n958.             return { sql: `${column} IN (${values.map(() => '?').join(', ')})`, values };\n959.         }\n960.         case 'lt':\n961.             return { sql: `${column} < ?`, values: [value] };\n962.         case 'lte':\n963.             return { sql: `${column} <= ?`, values: [value] };\n964.         case 'gt':\n965.             return { sql: `${column} > ?`, values: [value] };\n966.         case 'gte':\n967.             return { sql: `${column} >= ?`, values: [value] };\n968.         case 'like':\n969.             return { sql: `${column} LIKE ? ESCAPE '\\\\'`, values: [value] };\n970.         case 'ilike':\n971.             return { sql: `LOWER(${column}) LIKE LOWER(?) ESCAPE '\\\\'`, values: [value] };\n972.         default:\n973.             return { sql: '1 = 1', values: [] };\n974.     }\n975. }\n976. \n977. /**\n978.  * Creates SQL for one PostgREST `.or(...)` filter.\n979.  */\n980. function createOrFilterCondition(\n981.     tableName: string,\n982.     filter: string,\n983. ): { readonly sql: string; readonly values: ReadonlyArray<unknown> } | null {\n984.     const conditions: Array<string> = [];\n985.     const values: Array<unknown> = [];\n986. \n987.     for (const part of splitPostgrestOrFilter(filter)) {\n988.         const parsedFilter = parsePostgrestFilter(part);\n989.         if (!parsedFilter) {\n990.             continue;\n991.         }\n992. \n993.         if (parsedFilter.operator === 'cs') {\n994.             conditions.push('0 = 1');\n995.             continue;\n996.         }\n997. \n998.         const condition = createFilterCondition(tableName, {\n999.             column: parsedFilter.column,\n1000.             operator: normalizePostgrestOperator(parsedFilter.operator),\n1001.             value: decodePostgrestFilterValue(parsedFilter.value),\n1002.         });\n1003.         conditions.push(condition.sql);\n1004.         values.push(...condition.values);\n1005.     }\n1006. \n1007.     if (conditions.length === 0) {\n1008.         return null;\n1009.     }\n1010. \n1011.     return {\n1012.         sql: `(${conditions.join(' OR ')})`,\n1013.         values,\n1014.     };\n1015. }\n1016. \n1017. /**\n1018.  * Splits a PostgREST OR filter while keeping JSON literals intact.\n1019.  */\n1020. function splitPostgrestOrFilter(filter: string): Array<string> {\n1021.     const parts: Array<string> = [];\n1022.     let current = '';\n1023.     let depth = 0;\n1024.     let isInsideString = false;\n1025. \n1026.     for (let index = 0; index < filter.length; index++) {\n1027.         const character = filter[index]!;\n1028.         const previousCharacter = filter[index - 1];\n1029. \n1030.         if (character === '\"' && previousCharacter !== '\\\\') {\n1031.             isInsideString = !isInsideString;\n1032.         } else if (!isInsideString && (character === '{' || character === '[')) {\n1033.             depth++;\n1034.         } else if (!isInsideString && (character === '}' || character === ']')) {\n1035.             depth--;\n1036.         }\n1037. \n1038.         if (character === ',' && depth === 0 && !isInsideString) {\n1039.             parts.push(current);\n1040.             current = '';\n1041.             continue;\n1042.         }\n1043. \n1044.         current += character;\n1045.     }\n1046. \n1047.     if (current) {\n1048.         parts.push(current);\n1049.     }\n1050. \n1051.     return parts.map((part) => part.trim()).filter(Boolean);\n1052. }\n1053. \n1054. /**\n1055.  * Parses one PostgREST filter expression.\n1056.  */\n1057. function parsePostgrestFilter(filter: string): ParsedPostgrestFilter | null {\n1058.     const match = /^([^.]*)\\.([a-z]+)\\.([\\s\\S]*)$/iu.exec(filter.trim());\n1059.     if (!match) {\n1060.         return null;\n1061.     }\n1062. \n1063.     return {\n1064.         column: match[1]!,\n1065.         operator: match[2]!.toLowerCase(),\n1066.         value: match[3]!,\n1067.     };\n1068. }\n1069. \n1070. /**\n1071.  * Converts PostgREST operators into internal filter operators.\n1072.  */\n1073. function normalizePostgrestOperator(operator: string): LocalSqliteFilter['operator'] {\n1074.     switch (operator) {\n1075.         case 'neq':\n1076.             return 'neq';\n1077.         case 'ilike':\n1078.             return 'ilike';\n1079.         case 'like':\n1080.             return 'like';\n1081.         case 'lt':\n1082.             return 'lt';\n1083.         case 'lte':\n1084.             return 'lte';\n1085.         case 'gt':\n1086.             return 'gt';\n1087.         case 'gte':\n1088.             return 'gte';\n1089.         case 'eq':\n1090.         default:\n1091.             return 'eq';\n1092.     }\n1093. }\n1094. \n1095. /**\n1096.  * Decodes a PostgREST filter value when URL-encoded by callers.\n1097.  */\n1098. function decodePostgrestFilterValue(value: string): string {\n1099.     try {\n1100.         return decodeURIComponent(value);\n1101.     } catch {\n1102.         return value;\n1103.     }\n1104. }\n1105. \n1106. /**\n1107.  * Creates a select expression from parsed columns.\n1108.  */\n1109. function createSelectExpression(columns: ReadonlyArray<string>): string {\n1110.     if (columns.length === 0 || columns.includes('*')) {\n1111.         return '*';\n1112.     }\n1113. \n1114.     return columns.map(quoteIdentifier).join(', ');\n1115. }\n1116. \n1117. /**\n1118.  * Parses a simple Supabase select column list.\n1119.  */\n1120. function parseSelectedColumns(columns: string): Array<string> {\n1121.     const trimmedColumns = columns.trim();\n1122.     if (!trimmedColumns || trimmedColumns === '*') {\n1123.         return ['*'];\n1124.     }\n1125. \n1126.     return trimmedColumns\n1127.         .split(',')\n1128.         .map((column) => column.trim())\n1129.         .filter(Boolean)\n1130.         .map((column) => column.split(':').pop() || column)\n1131.         .map((column) => column.replace(/\\s+/g, ''))\n1132.         .filter((column) => /^[A-Za-z_][A-Za-z0-9_]*$/u.test(column));\n1133. }\n1134. \n1135. /**\n1136.  * Converts mutation payloads into a uniform array of records.\n1137.  */\n1138. function normalizeMutationRows(values: TODO_any): Array<Record<string, unknown>> {\n1139.     if (Array.isArray(values)) {\n1140.         return values.map((row) => stripUndefinedValues(row || {}));\n1141.     }\n1142. \n1143.     return [stripUndefinedValues(values || {})];\n1144. }\n1145. \n1146. /**\n1147.  * Removes undefined values because Supabase omits them from mutation payloads.\n1148.  */\n1149. function stripUndefinedValues(values: Record<string, unknown>): Record<string, unknown> {\n1150.     const result: Record<string, unknown> = {};\n1151. \n1152.     for (const [key, value] of Object.entries(values)) {\n1153.         if (value !== undefined) {\n1154.             result[key] = value;\n1155.         }\n1156.     }\n1157. \n1158.     return result;\n1159. }\n1160. \n1161. /**\n1162.  * Adds SQLite-side defaults that are normally supplied by PostgreSQL migrations.\n1163.  */\n1164. function withInsertDefaults(tableBaseName: string, row: Record<string, unknown>): Record<string, unknown> {\n1165.     const nowIso = new Date().toISOString();\n1166.     const result = { ...row };\n1167. \n1168.     if (result.createdAt === undefined) {\n1169.         result.createdAt = nowIso;\n1170.     }\n1171.     if (result.updatedAt === undefined && tableBaseName !== 'AgentHistory' && tableBaseName !== 'ChatHistory') {\n1172.         result.updatedAt = nowIso;\n1173.     }\n1174. \n1175.     switch (tableBaseName) {\n1176.         case 'Agent':\n1177.             result.visibility ??= 'PRIVATE';\n1178.             result.folderId ??= null;\n1179.             result.sortOrder ??= Date.now();\n1180.             result.deletedAt ??= null;\n1181.             result.preparedModelRequirements ??= null;\n1182.             break;\n1183.         case 'AgentFolder':\n1184.             result.parentId ??= null;\n1185.             result.sortOrder ??= Date.now();\n1186.             result.deletedAt ??= null;\n1187.             result.icon ??= null;\n1188.             result.color ??= null;\n1189.             break;\n1190.         case 'User':\n1191.             result.isAdmin ??= false;\n1192.             result.profileImageUrl ??= null;\n1193.             break;\n1194.         case 'UserChat':\n1195.             result.messages ??= [];\n1196.             result.source ??= 'WEB_UI';\n1197.             result.title ??= null;\n1198.             result.draftMessage ??= null;\n1199.             break;\n1200.         case 'UserChatJob':\n1201.             result.parameters ??= {};\n1202.             result.queuedAt ??= nowIso;\n1203.             result.attemptCount ??= 0;\n1204.             break;\n1205.         case 'UserChatTimeout':\n1206.             result.parameters ??= {};\n1207.             result.queuedAt ??= nowIso;\n1208.             result.attemptCount ??= 0;\n1209.             result.runCount ??= 0;\n1210.             break;\n1211.         case 'ApiTokens':\n1212.             result.isRevoked ??= false;\n1213.             break;\n1214.         case 'Wallet':\n1215.             result.isUserScoped ??= true;\n1216.             result.isGlobal ??= false;\n1217.             result.deletedAt ??= null;\n1218.             break;\n1219.         case 'UserMemory':\n1220.             result.isGlobal ??= false;\n1221.             result.deletedA