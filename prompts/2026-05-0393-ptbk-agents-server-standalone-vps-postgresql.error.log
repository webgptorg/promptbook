ce_mib=0\n341.     fi\n342. \n343.     confirm_minimum_disk_space \"$projected_disk_space_mib\" \"$install_disk_check_path\" \"will remain after adding swap\"\n344. }\n345. \n346. check_required_resources() {\n347.     local install_disk_check_path=\"\"\n348.     local available_disk_space_mib=0\n349.     local total_memory_mib=0\n350.     local additional_swap_mib=0\n351. \n352.     log \"Checking VPS resources.\"\n353. \n354.     install_disk_check_path=\"$(resolve_existing_path \"$INSTALL_DIR\")\"\n355.     available_disk_space_mib=\"$(get_available_disk_space_mib \"$install_disk_check_path\")\"\n356.     confirm_minimum_disk_space \"$available_disk_space_mib\" \"$install_disk_check_path\" \"is available\"\n357. \n358.     total_memory_mib=\"$(get_total_memory_mib)\"\n359. \n360.     if [[ \"$total_memory_mib\" -ge \"$MINIMUM_REQUIRED_MEMORY_MIB\" ]]; then\n361.         log \"Resources OK: $(format_mib \"$total_memory_mib\") memory and $(format_mib \"$available_disk_space_mib\") free disk.\"\n362.         return\n363.     fi\n364. \n365.     additional_swap_mib=$((MINIMUM_REQUIRED_MEMORY_MIB - total_memory_mib))\n366.     warn \"Only $(format_mib \"$total_memory_mib\") total memory (RAM + swap) is available. Agents Server requires at least $(format_mib \"$MINIMUM_REQUIRED_MEMORY_MIB\").\"\n367. \n368.     if ! prompt_yes_no \"Add $(format_mib \"$additional_swap_mib\") of swap at $PROMPTBOOK_SWAP_FILE?\" \"yes\"; then\n369.         fail \"Installation stopped because the VPS does not have enough memory.\"\n370.     fi\n371. \n372.     confirm_disk_space_after_swap \"$install_disk_check_path\" \"$available_disk_space_mib\" \"$additional_swap_mib\"\n373.     add_required_swap_file \"$additional_swap_mib\"\n374.     total_memory_mib=\"$(get_total_memory_mib)\"\n375. \n376.     if [[ \"$total_memory_mib\" -lt \"$MINIMUM_REQUIRED_MEMORY_MIB\" ]]; then\n377.         fail \"Swap was configured, but total memory is still only $(format_mib \"$total_memory_mib\").\"\n378.     fi\n379. \n380.     log \"Swap configured. Total memory is now $(format_mib \"$total_memory_mib\").\"\n381. }\n382. \n383. append_domain() {\n384.     local raw_domain=\"$1\"\n385.     local normalized_domain=\"\"\n386.     local existing_domain=\"\"\n387. \n388.     normalized_domain=\"$(normalize_domain \"$raw_domain\")\"\n389.     if [[ -z \"$normalized_domain\" ]]; then\n390.         fail \"Invalid domain '$raw_domain'. Use one or more DNS hostnames, for example example.com,www.example.com.\"\n391.     fi\n392. \n393.     for existing_domain in \"${DOMAINS[@]}\"; do\n394.         if [[ \"$existing_domain\" == \"$normalized_domain\" ]]; then\n395.             return\n396.         fi\n397.     done\n398. \n399.     DOMAINS+=(\"$normalized_domain\")\n400. }\n401. \n402. set_domains_from_csv() {\n403.     local raw_domains=\"$1\"\n404.     local domain=\"\"\n405. \n406.     DOMAINS=()\n407.     IFS=',' read -ra requested_domains <<< \"$raw_domains\"\n408.     for domain in \"${requested_domains[@]}\"; do\n409.         if [[ -z \"${domain//[[:space:]]/}\" ]]; then\n410.             continue\n411.         fi\n412.         append_domain \"$domain\"\n413.     done\n414. }\n415. \n416. initialize_sudo() {\n417.     if [[ \"$EUID\" -eq 0 ]]; then\n418.         SUDO=()\n419.         return\n420.     fi\n421. \n422.     log \"sudo is required to install system packages, Node.js, global npm tools, and the pm2 boot service.\"\n423.     sudo -v\n424.     SUDO=(sudo)\n425. }\n426. \n427. resolve_run_user() {\n428.     if [[ -n \"${SUDO_USER:-}\" && \"${SUDO_USER:-}\" != \"root\" ]]; then\n429.         RUN_USER=\"$SUDO_USER\"\n430.     else\n431.         RUN_USER=\"$(id -un)\"\n432.     fi\n433. \n434.     RUN_GROUP=\"$(id -gn \"$RUN_USER\")\"\n435.     RUN_HOME=\"$(getent passwd \"$RUN_USER\" | cut -d: -f6)\"\n436. \n437.     if [[ -z \"$RUN_HOME\" ]]; then\n438.         fail \"Could not resolve home directory for user $RUN_USER.\"\n439.     fi\n440. }\n441. \n442. run_as_service_user() {\n443.     if [[ \"$RUN_USER\" == \"root\" ]]; then\n444.         HOME=\"$RUN_HOME\" \"$@\"\n445.         return\n446.     fi\n447. \n448.     sudo -H -u \"$RUN_USER\" env HOME=\"$RUN_HOME\" \"$@\"\n449. }\n450. \n451. check_platform() {\n452.     if [[ ! -r /etc/os-release ]]; then\n453.         fail \"This installer is intended for Ubuntu 24.04 LTS x64.\"\n454.     fi\n455. \n456.     # shellcheck source=/dev/null\n457.     source /etc/os-release\n458. \n459.     if [[ \"${ID:-}\" != \"ubuntu\" ]]; then\n460.         warn \"Detected ${PRETTY_NAME:-unknown OS}; this installer is tested on Ubuntu 24.04 LTS x64.\"\n461.     elif [[ \"${VERSION_ID:-}\" != \"24.04\" ]]; then\n462.         warn \"Detected Ubuntu ${VERSION_ID:-unknown}; this installer is tested on Ubuntu 24.04 LTS x64.\"\n463.     fi\n464. \n465.     local architecture=\"\"\n466.     architecture=\"$(dpkg --print-architecture)\"\n467.     if [[ \"$architecture\" != \"amd64\" ]]; then\n468.         fail \"Unsupported architecture $architecture. Use an x64/amd64 VPS.\"\n469.     fi\n470. }\n471. \n472. install_system_packages() {\n473.     log \"Installing system packages.\"\n474.     \"${SUDO[@]}\" env DEBIAN_FRONTEND=noninteractive apt-get update\n475.     \"${SUDO[@]}\" env DEBIAN_FRONTEND=noninteractive apt-get install -y \\\n476.         ca-certificates \\\n477.         curl \\\n478.         git \\\n479.         gnupg \\\n480.         build-essential \\\n481.         python3 \\\n482.         make \\\n483.         g++ \\\n484.         openssl \\\n485.         nginx \\\n486.         libnginx-mod-http-headers-more-filter \\\n487.         certbot \\\n488.         python3-certbot-nginx\n489. }\n490. \n491. is_node_version_supported() {\n492.     local minimum_version=\"\"\n493.     minimum_version=\"$(resolve_node_minimum_version)\"\n494. \n495.     command -v node >/dev/null 2>&1 &&\n496.         NODE_MINIMUM_VERSION=\"$minimum_version\" node -e '\n497.             const currentParts = process.versions.node.split(\".\").map(Number);\n498.             const minimumParts = (process.env.NODE_MINIMUM_VERSION || \"22.12.0\").split(\".\").map(Number);\n499.             const maxLength = Math.max(currentParts.length, minimumParts.length);\n500. \n501.             for (let index = 0; index < maxLength; index++) {\n502.                 const currentPart = currentParts[index] || 0;\n503.                 const minimumPart = minimumParts[index] || 0;\n504. \n505.                 if (currentPart > minimumPart) {\n506.                     process.exit(0);\n507.                 }\n508. \n509.                 if (currentPart < minimumPart) {\n510.                     process.exit(1);\n511.                 }\n512.             }\n513. \n514.             process.exit(0);\n515.         ' >/dev/null 2>&1\n516. }\n517. \n518. resolve_node_minimum_version() {\n519.     if [[ -n \"$NODE_MINIMUM_VERSION\" ]]; then\n520.         printf '%s' \"$NODE_MINIMUM_VERSION\"\n521.         return\n522.     fi\n523. \n524.     case \"$NODE_MAJOR_VERSION\" in\n525.         20)\n526.             printf '20.19.0'\n527.             ;;\n528.         22)\n529.             printf '22.12.0'\n530.             ;;\n531.         *)\n532.             printf '%s.0.0' \"$NODE_MAJOR_VERSION\"\n533.             ;;\n534.     esac\n535. }\n536. \n537. install_nodejs() {\n538.     local minimum_version=\"\"\n539.     minimum_version=\"$(resolve_node_minimum_version)\"\n540. \n541.     if is_node_version_supported && command -v npm >/dev/null 2>&1; then\n542.         log \"Node.js $(node --version) is already installed.\"\n543.         return\n544.     fi\n545. \n546.     log \"Installing Node.js ${NODE_MAJOR_VERSION}.x from NodeSource (minimum ${minimum_version}).\"\n547.     \"${SUDO[@]}\" install -d -m 0755 /etc/apt/keyrings\n548.     curl -fsSL https://deb.nodesource.com/gpgkey/nodesource-repo.gpg.key |\n549.         \"${SUDO[@]}\" gpg --dearmor --yes -o /etc/apt/keyrings/nodesource.gpg\n550.     echo \"d