ction createAutomaticMigrationFailureLogContext(error: unknown): Record<string, unknown> {\n53.     const defaultPrefix = process.env.SUPABASE_TABLE_PREFIX || '';\n54.     const errorContext: Record<string, unknown> = {\n55.         prefix: defaultPrefix,\n56.         nextRuntime: process.env.NEXT_RUNTIME,\n57.         nodeEnv: process.env.NODE_ENV,\n58.         vercelEnv: process.env.VERCEL_ENV,\n59.         vercelRegion: process.env.VERCEL_REGION,\n60.         vercelUrl: process.env.VERCEL_URL,\n61.     };\n62. \n63.     if (error instanceof Error) {\n64.         errorContext.errorName = error.name;\n65.         errorContext.errorMessage = error.message;\n66.         errorContext.errorStack = error.stack;\n67.     } else {\n68.         errorContext.errorValue = error;\n69.     }\n70. \n71.     const postgresLikeError = error as Partial<PostgresLikeError> | null;\n72. \n73.     if (!postgresLikeError || typeof postgresLikeError !== 'object') {\n74.         return errorContext;\n75.     }\n76. \n77.     for (const [key, value] of Object.entries({\n78.         postgresCode: postgresLikeError.code,\n79.         postgresSeverity: postgresLikeError.severity,\n80.         postgresDetail: postgresLikeError.detail,\n81.         postgresHint: postgresLikeError.hint,\n82.         postgresPosition: postgresLikeError.position,\n83.         postgresInternalPosition: postgresLikeError.internalPosition,\n84.         postgresInternalQuery: postgresLikeError.internalQuery,\n85.         postgresWhere: postgresLikeError.where,\n86.         postgresSchema: postgresLikeError.schema,\n87.         postgresTable: postgresLikeError.table,\n88.         postgresColumn: postgresLikeError.column,\n89.         postgresDataType: postgresLikeError.dataType,\n90.         postgresConstraint: postgresLikeError.constraint,\n91.         postgresFile: postgresLikeError.file,\n92.         postgresLine: postgresLikeError.line,\n93.         postgresRoutine: postgresLikeError.routine,\n94.     })) {\n95.         if (value !== undefined) {\n96.             errorContext[key] = value;\n97.         }\n98.     }\n99. \n100.     return errorContext;\n101. }\n102. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/instrumentation-node.ts b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/instrumentation-node.ts\nindex 0000000..0000000 100644\n--- a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/instrumentation-node.ts\n+++ b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/instrumentation-node.ts\n@@ -1,102 +1,102 @@\n import { ensureAutomaticDatabaseMigrations } from './database/ensureAutomaticDatabaseMigrations';\n \n /**\n  * Runs Node.js-only startup hooks for the Agents Server runtime.\n  *\n  * @returns Promise that resolves after all startup hooks finish.\n  * @private internal startup hook for Agents Server runtime\n  */\n export async function registerNodeRuntimeInstrumentation(): Promise<void> {\n     try {\n         await ensureAutomaticDatabaseMigrations();\n     } catch (error) {\n         console.error(\n             '❌ Automatic database migration failed during Agents Server instrumentation. Continuing without blocking request handling.',\n             createAutomaticMigrationFailureLogContext(error),\n         );\n     }\n }\n \n /**\n  * PostgreSQL error shape exposed by the `pg` client.\n  *\n  * @private internal logging helper for Agents Server instrumentation\n  */\n type PostgresLikeError = Error & {\n     code?: string;\n     severity?: string;\n     detail?: string;\n     hint?: string;\n     position?: string;\n     internalPosition?: string;\n     internalQuery?: string;\n     where?: string;\n     schema?: string;\n     table?: string;\n     column?: string;\n     dataType?: string;\n     constraint?: string;\n     file?: string;\n     line?: string;\n     routine?: string;\n };\n \n /**\n  * Creates structured log context for startup migration failures so production logs retain the useful PostgreSQL fields.\n  *\n  * @param error - Unknown startup error.\n  * @returns Structured log object safe to print to console.\n  *\n  * @private internal logging helper for Agents Server instrumentation\n  */\n function createAutomaticMigrationFailureLogContext(error: unknown): Record<string, unknown> {\n     const defaultPrefix = process.env.SUPABASE_TABLE_PREFIX || '';\n     const errorContext: Record<string, unknown> = {\n         prefix: defaultPrefix,\n         nextRuntime: process.env.NEXT_RUNTIME,\n         nodeEnv: process.env.NODE_ENV,\n         vercelEnv: process.env.VERCEL_ENV,\n         vercelRegion: process.env.VERCEL_REGION,\n         vercelUrl: process.env.VERCEL_URL,\n     };\n \n     if (error instanceof Error) {\n         errorContext.errorName = error.name;\n         errorContext.errorMessage = error.message;\n         errorContext.errorStack = error.stack;\n     } else {\n         errorContext.errorValue = error;\n     }\n \n     const postgresLikeError = error as Partial<PostgresLikeError> | null;\n \n     if (!postgresLikeError || typeof postgresLikeError !== 'object') {\n         return errorContext;\n     }\n \n     for (const [key, value] of Object.entries({\n         postgresCode: postgresLikeError.code,\n         postgresSeverity: postgresLikeError.severity,\n         postgresDetail: postgresLikeError.detail,\n         postgresHint: postgresLikeError.hint,\n         postgresPosition: postgresLikeError.position,\n         postgresInternalPosition: postgresLikeError.internalPosition,\n         postgresInternalQuery: postgresLikeError.internalQuery,\n         postgresWhere: postgresLikeError.where,\n         postgresSchema: postgresLikeError.schema,\n         postgresTable: postgresLikeError.table,\n         postgresColumn: postgresLikeError.column,\n         postgresDataType: postgresLikeError.dataType,\n         postgresConstraint: postgresLikeError.constraint,\n         postgresFile: postgresLikeError.file,\n         postgresLine: postgre