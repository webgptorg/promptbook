interacting with your database\n         supabase = createClient<AgentsServerDatabase>(\n             process.env.NEXT_PUBLIC_SUPABASE_URL!,\n             process.env.SUPABASE_SERVICE_ROLE_KEY!,\n             {\n                 auth: {\n                     autoRefreshToken: false,\n                     persistSession: false,\n                 },\n             },\n         );\n     }\n \n     /*\n     // Access auth admin api\n     const adminAuthClient = supabase.auth.admin;\n     */\n \n     return supabase;\n }\n \n // TODO: [🏓] Unite `xxxForServer` and `xxxForNode` naming\n \n"},"toolTelemetry":{"properties":{"command":"view","options":"{\"truncateBasedOn\":\"tokenCount\",\"truncateStyle\":\"middle\"}","inputs":"[\"path\",\"command\"]","resolvedPathAgainstCwd":"false","fileExtension":"[\".ts\"]","viewType":"file"},"metrics":{"resultLength":1979,"resultForLlmLength":1979,"responseTokenLimit":68000},"restrictedProperties":{}}},"id":"1bfe60c1-8386-43de-bd1b-d099d0f2981a","timestamp":"2026-05-29T10:02:59.622Z","parentId":"7f496b35-7d3b-4c59-9276-aed8da0b3bfd"}
{"type":"tool.execution_complete","data":{"toolCallId":"call_hVZ3x23nhtBgwVJ4JiwYv41d","model":"gpt-5.4","interactionId":"0a603915-c65a-4110-b10e-3f0d506120f6","turnId":"15","success":true,"result":{"content":"1. import colors from 'colors';\n2. import * as dotenv from 'dotenv';\n3. import {\n4.     DATABASE_MIGRATION_APPLIED_BY,\n5.     resolveDatabaseMigrationRuntimeConfiguration,\n6.     runDatabaseMigrations,\n7. } from './runDatabaseMigrations';\n8. \n9. dotenv.config();\n10. \n11. /**\n12.  * Runs manual migration command from CLI arguments.\n13.  */\n14. async function migrate(): Promise<void> {\n15.     console.info(colors.bgBlue('🚀 Starting database migration'));\n16. \n17.     const runtimeConfiguration = await resolveDatabaseMigrationRuntimeConfiguration(console);\n18.     if (!runtimeConfiguration) {\n19.         return;\n20.     }\n21. \n22.     const onlyTargets = parseOnlyMigrationTargetsFromCliArguments(process.argv.slice(2));\n23.     if (onlyTargets !== null) {\n24.         console.info(colors.cyan(`🎯 Running migrations only for: ${onlyTargets.join(', ')}`));\n25.     }\n26. \n27.     try {\n28.         await runDatabaseMigrations({\n29.             prefixes: runtimeConfiguration.prefixes,\n30.             registeredServers: runtimeConfiguration.registeredServers,\n31.             connectionString: runtimeConfiguration.connectionString,\n32.             onlyTargets,\n33.             appliedBy: DATABASE_MIGRATION_APPLIED_BY.MANUAL,\n34.             logger: console,\n35.             logSqlStatements: true,\n36.         });\n37.         console.info(colors.bgGreen('\\n🎉 All migrations completed successfully'));\n38.     } catch (error) {\n39.         console.error(colors.bgRed('\\n❌ Migration failed:'));\n40.         if (error instanceof Error) {\n41.             console.error(error.message);\n42.         } else {\n43.             console.error(error);\n44.         }\n45.         process.exit(1);\n46.     }\n47. }\n48. \n49. /**\n50.  * Parses optional `--only` flag from CLI arguments.\n51.  *\n52.  * Targets may reference `production`, `preview`, registered server names, or raw table prefixes.\n53.  *\n54.  * @param args - CLI arguments.\n55.  * @returns Selected migration targets or `null` when not provided.\n56.  */\n57. function parseOnlyMigrationTargetsFromCliArguments(args: ReadonlyArray<string>): Array<string> | null {\n58.     for (let index = 0; index < args.length; index++) {\n59.         const arg = args[index];\n60.         if (arg === '--only' && args[index + 1]) {\n61.             return parseMigrationTargets(args[index + 1]);\n62.         }\n63.         if (arg?.startsWith('--only=')) {\n64.             return parseMigrationTargets(arg.substring('--only='.length));\n65.         }\n66.     }\n67.     return null;\n68. }\n69. \n70. /**\n71.  * Splits one comma-separated `--only` value into ordered tokens.\n72.  *\n73.  * @param rawTargets - Raw CLI value.\n74.  * @returns Parsed non-empty tokens.\n75.  */\n76. function parseMigrationTargets(rawTargets: string): Array<string> {\n77.     return rawTargets\n78.         .split(',')\n79.         .map((target) => target.trim())\n80.         .filter((target) => target !== '');\n81. }\n82. \n83. migrate();\n84. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/migrate.ts b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/migrate.ts\nindex 0000000..0000000 100644\n--- a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/migrate.ts\n+++ b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/migrate.ts\n@@ -1,84 +1,84 @@\n import colors from 'colors';\n import * as dotenv from 'dotenv';\n import {\n     DATABASE_MIGRATION_APPLIED_BY,\n     resolveDatabaseMigrationRuntimeConfiguration,\n     runDatabaseMigrations,\n } from './runDatabaseMigrations';\n \n dotenv.config();\n \n /**\n  * Runs manual migration command from CLI arguments.\n  */\n async function migrate(): Promise<void> {\n     console.info(colors.bgBlue('🚀 Starting database migration'));\n \n     const runtimeConfiguration = await resolveDatabaseMigrationRuntimeConfiguration(console);\n     if (!runtimeConfiguration) {\n         return;\n     }\n \n     const onlyTargets = parseOnlyMigrationTargetsFromCliArguments(process.argv.slice(2));\n     if (onlyTargets !== null) {\n         console.info(colors.cyan(`🎯 Running migrations only for: ${onlyTargets.join(', ')}`));\n     }\n \n     try {\n         await runDatabaseMigrations({\n             prefixes: runtimeConfiguration.prefixes,\n             registeredServers: runtimeConfiguration.registeredServers,\n             connectionString: runtimeConfiguration.connectionString,\n             onlyTargets,\n             appliedBy: DATABASE_MIGRATION_APPLIED_BY.MANUAL,\n             logger: console,\n             logSqlStatements: true,\n         });\n         console.info(colors.bgGreen('\\n🎉 All migrations completed successfully'));\n     } catch (error) {\n         console.error(colors.bgRed('\\n❌ Migration failed:'));\n         if (error instanceof Error) {\n             console.error(error.message);\n         } else {\n             console.error(error);\n         }\n         process.exit(1);\n     }\n }\n \n /**\n  * Parses optional `--only` flag from CLI arguments.\n  *\n  * Targets may reference `production`, `preview`, registered server names, or raw table prefixes.\n  *\n  * @param args - CLI arguments.\n  * @returns Selected migration targets or `null` when not provided.\n  */\n function parseOnlyMigrationTargetsFromCliArguments(args: ReadonlyArray<string>): Array<string> | null {\n     for (let index = 0; index < args.length; index++) {\n         const arg = args[index];\n         if (arg === '--only' && args[index + 1]) {\n             return parseMigrationTargets(args[index + 1]);\n         }\n         if (arg?.startsWith('--only=')) {\n             return parseMigrationTargets(arg.substring('--only='.length));\n         }\n     }\n     return null;\n }\n \n /**\n  * Splits one comma-separated `--only` value into ordered tokens.\n  *\n  * @param rawTargets - Raw CLI value.\n  * @returns Parsed non-empty tokens.\n  */\n function parseMigrationTargets(rawTargets: string): Array<string> {\n     return rawTargets\n         .split(',')\n         .map((target) => target.trim())\n         .filter((target) => target !== '');\n }\n \n migrate();\n \n"},"toolTelemetry":{"properties":{"command":"view","options":"{\"truncateBasedOn\":\"tokenCount\",\"truncateStyle\":\"middle\"}","inputs":"[\"path\",\"command\"]","resolvedPathAgainstCwd":"false","fileExtension":"[\".ts\"]","viewType":"file"},"metrics":{"resultLength":2948,"resultForLlmLength":2948,"responseTokenLimit":68000},"restrictedProperties":{}}},"id":"7c904eec-945e-4ae1-8aee-ed9eafdfae9f","timestamp":"2026-05-29T10:02:59.624Z","parentId":"b15c055b-bf5e-45f1-9ae2-ebd59fe5b45f"}
{"type":"tool.execution_complete","data":{"toolCallId":"call_BRivhMQ1m2pWw2YYpXkznw4Y","model":"gpt-5.4","interactionId":"0a603915-c65a-4110-b10e-3f0d506120f6","turnId":"15","success":true,"result":{"content":"1. import { execFile } from 'child_process';\n2. import { constants as filesystemConstants } from 'fs';\n3. import { access, mkdir, readFile, writeFile } from 'fs/promises';\n4. import { dirname, join, resolve } from 'path';\n5. import { promisify } from 'util';\n6. import { spaceTrim } from 'spacetrim';\n7. import { NotAllowed } from '../../../../src/errors/NotAllowed';\n8. import { normalizeServerDomain } from './serverRegistry';\n9. import { isStandaloneVpsRawIpBootstrapActive } from './standaloneVpsRawIpBootstrap';\n10. \n11. const execFileAsync = promisify(execFile);\n12. \n13. /**\n14.  * Mask rendered for sensitive environment values in the UI.\n15.  */\n16. export const HIDDEN_ENVIRONMENT_VALUE = '********';\n17. \n18. /**\n19.  * Environment variable names that can be managed from the standalone VPS UI.\n20.  */\n21. export const VPS_ENVIRONMENT_VARIABLE_KEYS = [\n22.     'SERVERS',\n23.     'NEXT_PUBLIC_SITE_URL',\n24.     'ADMIN_PASSWORD',\n25.     'OPENAI_API_KEY',\n26.     'PTBK_AGENT',\n27.     'PTBK_MODEL',\n28.     'PTBK_THINKING_LEVEL',\n29.     'PORT',\n30.     'PTBK_HOSTNAME',\n31.     'PTBK_PUBLIC_IP_ADDRESS',\n32.     'PTBK_PM2_APP_NAME',\n33.     'PTBK_NGINX_SITE_NAME',\n34.     'LETS_ENCRYPT_EMAIL',\n35.     'PTBK_AGENTS_SERVER_DATABASE',\n36.     'PTBK_AGENTS_SERVER_SQLITE_PATH',\n37.     'SUPABASE_TABLE_PREFIX',\n38.     'SUPABASE_AUTO_MIGRATE',\n39.     'COPILOT_GITHUB_TOKEN',\n40.     'GH_TOKEN',\n41.     'ANTHROPIC_CLAUDE_API_KEY',\n42.     'GOOGLE_GENERATIVE_AI_API_KEY',\n43.     'AZUREOPENAI_API_KEY',\n44. ] as const;\n45. \n46. /**\n47.  * Editable environment variable key supported by the standalone VPS UI.\n48.  */\n49. export type VpsEnvironmentVariableKey = (typeof VPS_ENVIRONMENT_VARIABLE_KEYS)[number];\n50. \n51. /**\n52.  * One environment variable row safe to send to the browser.\n53.  */\n54. export type VpsEnvironmentVariableRecord = {\n55.     /**\n56.      * Environment variable name.\n57.      */\n58.     readonly key: VpsEnvironmentVariableKey;\n59. \n60.     /**\n61.      * Masked or plain UI value.\n62.      */\n63.     readonly value: string;\n64. \n65.     /**\n66.      * Whether the real stored value is sensitive and hidden.\n67.      */\n68.     readonly isSensitive: boolean;\n69. \n70.     /**\n71.      * Whether the variable exists in the `.env` file or current process.\n72.      */\n73.     readonly isDefined: boolean;\n74. };\n75. \n76. /**\n77.  * Result of running a VPS command from the admin UI.\n78.  */\n79. export type VpsCommandResult = {\n80.     /**\n81.      * Whether the command was attempted on this host.\n82.      */\n83.     readonly isAvailable: boolean;\n84. \n85.     /**\n86.      * Process exit output or skipped reason.\n87.      */\n88.     readonly output: string;\n89. };\n90. \n91. /**\n92.  * Runtime-installer execution options used by VPS admin actions.\n93.  */\n94. type RunVpsInstallerCommandOptions = {\n95.     /**\n96.      * Whether the installer may restart the running Agents Server process.\n97.      */\n98.     readonly isProcessRestartEnabled?: boolean;\n99. };\n100. \n101. /**\n102.  * Parsed `.env` line representation used to preserve comments and ordering.\n103.  */\n104. type ParsedEnvLine =\n105.     | {\n106.           readonly type: 'entry';\n107.           readonly raw: string;\n108.           readonly key: string;\n109.           readonly value: string;\n110.       }\n111.     | {\n112.           readonly type: 'raw';\n113.           readonly raw: string;\n114.       };\n115. \n116. /**\n117.  * Returns the installed Agents Server `.env` file path.\n118.  *\n119.  * @returns Absolute path to the editable `.env` file.\n120.  */\n121. export function resolveVpsEnvironmentFilePath(): string {\n122.     const explicitEnvFile = process.env.PTBK_AGENTS_SERVER_ENV_FILE?.trim();\n123.     if (explicitEnvFile) {\n124.         return resolve(explicitEnvFile);\n125.     }\n126. \n127.     const explicitInstallDirectory = process.env.PTBK_INSTALL_DIR?.trim();\n128.     if (explicitInstallDirectory) {\n129.         return resolve(explicitInstallDirectory, '.env');\n130.     }\n131. \n132.     const sqlitePath = process.env.PTBK_AGENTS_SERVER_SQLITE_PATH?.trim();\n133.     if (sqlitePath) {\n134.         return resolve(dirname(dirname(resolve(sqlitePath))), '.env');\n135.     }\n136. \n137.     return resolve(process.cwd(), '.env');\n138. }\n139. \n140. /**\n141.  * Reads managed environment variables with sensitive values masked.\n142.  *\n143.  * @returns Safe environment snapshot for the admin UI.\n144.  */\n145. export async function listVpsEnvironmentVariables(): Promise<{\n146.     readonly envFilePath: string;\n147.     readonly variables: ReadonlyArray<VpsEnvironmentVariableRecord>;\n148. }> {\n149.     const envFilePath = resolveVpsEnvironmentFilePath();\n150.     const envValues = await readVpsEnvironmentMap(envFilePath);\n151. \n152.     return {\n153.         envFilePath,\n154.         variables: VPS_ENVIRONMENT_VARIABLE_KEYS.map((key) => {\n155.             const rawValue = envValues.get(key) ?? process.env[key] ?? '';\n156.             const isSensitive = isSensitiveEnvironmentVariable(key);\n157.             return {\n158.                 key,\n159.                 value: isSensitive && rawValue ? HIDDEN_ENVIRONMENT_VALUE : rawValue,\n160.                 isSensitive,\n161.                 isDefined: rawValue !== '',\n162.             };\n163.         }),\n164.     };\n165. }\n166. \n167. /**\n168.  * Updates supported variables in the installed `.env` file.\n169.  *\n170.  * Sensitive variables are updated only when the submitted value is not empty and not the mask.\n171.  *\n172.  * @param updates - Key/value pairs to persist.\n173.  * @returns Safe environment snapshot after writing.\n174.  */\n175. export async function updateVpsEnvironmentVariables(\n176.     updates: Readonly<Record<string, string>>,\n177. ): Promise<Awaited<ReturnType<typeof listVpsEnvironmentVariables>>> {\n178.     const normalizedUpdates = normalizeVpsEnvironmentUpdates(updates);\n179.     const envFilePath = resolveVpsEnvironmentFilePath();\n180.     const existingContent = await readOptionalTextFile(envFilePath);\n181.     const nextContent = serializeUpdatedEnvFile(existingContent, normalizedUpdates);\n182. \n183.     await mkdir(dirname(envFilePath), { recursive: true });\n184.     await writeFile(envFilePath, nextContent, { encoding: 'utf-8', mode: 0o600 });\n185. \n186.     for (const [key, value] of normalizedUpdates) {\n187.         process.env[key] = value;\n188.     }\n189. \n190.     return listVpsEnvironmentVariables();\n191. }\n192. \n193. /**\n194.  * Reads domains from the installed `.env` file or current process.\n195.  *\n196.  * @returns Normalized configured domains.\n197.  */\n198. export async function listConfiguredVpsDomains(): Promise<Array<string>> {\n199.     const envValues = await readVpsEnvironmentMap(resolveVpsEnvironmentFilePath());\n200.     const rawServers = envValues.get('SERVERS') ?? process.env.SERVERS ?? '';\n201. \n202.     return parseDomainsCsv(rawServers);\n203. }\n204. \n205. /**\n206.  * Options used when updating the standalone VPS domain list.\n207.  */\n208. type UpdateConfiguredVpsDomainsOptions = {\n209.     /**\n210.      * Optional server-level table prefix to persist together with the domain list.\n211.      */\n212.     readonly tablePrefix?: string | null;\n213. };\n214. \n215. /**\n216.  * Replaces the standalone VPS domain list in `.env`.\n217.  *\n218.  * @param domains - Domains to store in `SERVERS`.\n219.  * @param options - Optional server-level settings to persist.\n220.  * @returns Safe environment snapshot after writing.\n221.  */\n222. export async function updateConfiguredVpsDomains(\n223.     domains: ReadonlyArray<string>,\n224.     options?: UpdateConfiguredVpsDomainsOptions,\n225. ): Promise<Awaited<ReturnType<typeof listVpsEnvironmentVariables>>> {\n226.     const normalizedDomains = normalizeDomains(domains);\n227.     const primaryDomain = normalizedDomains[0] ?? '';\n228.     const envValues = await readVpsEnvironmentMap(resolveVpsEnvironmentFilePath());\n229.     const currentPublicSiteUrl = envValues.get('NEXT_PUBLIC_SITE_URL') ?? process.env.NEXT_PUBLIC_SITE_URL ?? '';\n230.     const publicIpAddress = envValues.get('PTBK_PUBLIC_IP_ADDRESS') ?? process.env.PTBK_PUBLIC_IP_ADDRESS ?? '';\n231.     const updates: Record<string, string> = {\n232.         SERVERS: normalizedDomains.join(','),\n233.     };\n234. \n235.     if (primaryDomain) {\n236.         updates.NEXT_PUBLIC_SITE_URL = isStandaloneVpsRawIpBootstrapActive({\n237.             nextPublicSiteUrl: currentPublicSiteUrl,\n238.             publicIpAddress,\n239.         })\n240.             ? currentPublicSiteUrl\n241.             : `https://${primaryDomain}`;\n242.     } else {\n243.         updates.NEXT_PUBLIC_SITE_URL = publicIpAddress\n244.             ? `http://${publicIpAddress}`\n245.             : '';\n246.     }\n247. \n248.     if (options && Object.prototype.hasOwnProperty.call(options, 'tablePrefix')) {\n249.         updates.SUPABASE_TABLE_PREFIX = options.tablePrefix?.trim() || '';\n250.     }\n251. \n252.     return updateVpsEnvironmentVariables(updates);\n253. }\n254. \n255. /**\n256.  * Applies Nginx, Certbot, and process-manager changes through the shared VPS installer script.\n257.  *\n258.  * @returns Command output or a skipped reason when not running on a Linux VPS.\n259.  */\n260. export async function applyVpsRuntimeConfiguration(\n261.     options?: RunVpsInstallerCommandOptions,\n262. ): Promise<VpsCommandResult> {\n263.     return runVpsInstallerCommand(\n264.         'apply-domains',\n265.         'VPS runtime configuration can only be applied on Linux.',\n266.         options,\n267.     );\n268. }\n269. \n270. /**\n271.  * Installs/configures the selected local code runner through the shared VPS installer script.\n272.  *\n273.  * @returns Command output or a skipped reason when not running on a Linux VPS.\n274.  */\n275. export async function applyVpsCodeRunnerConfiguration(): Promise<VpsCommandResult> {\n276.     return runVpsInstallerCommand('apply-runner', 'VPS code-runner configuration can only be applied on Linux.');\n277. }\n278. \n279. /**\n280.  * Reads recent pm2 logs for the configured Agents Server process.\n281.  *\n282.  * @param lineCount - Number of lines to request.\n283.  * @returns Log output or a skipped reason.\n284.  */\n285. export async function readVpsPm2Logs(lineCount = 200): Promise<VpsCommandResult> {\n286.     if (process.platform !== 'linux') {\n287.         return {\n288.             isAvailable: false,\n289.             output: 'pm2 logs are available only on the Linux VPS runtime.',\n290.         };\n291.     }\n292. \n293.     const appName = process.env.PTBK_PM2_APP_NAME?.trim() || 'promptbook-agents-server';\n294.     const { stdout, stderr } = await execFileAsync('pm2', ['logs', appName, '--nostream', '--lines', String(lineCount)], {\n295.         maxBuffer: 1024 * 1024,\n296.     });\n297. \n298.     return {\n299.         isAvailable: true,\n300.         output: [stdout, stderr].filter(Boolean).join('\\n').trim(),\n301.     };\n302. }\n303. \n304. /**\n305.  * Runs one maintenance subcommand from the shared VPS installer script.\n306.  *\n307.  * @param command - Installer subcommand.\n308.  * @param unavailableOutput - Message returned on non-Linux platforms.\n309.  * @returns Command output or unavailable reason.\n310.  */\n311. async function runVpsInstallerCommand(\n312.     command: string,\n313.     unavailableOutput: string,\n314.     options?: RunVpsInstallerCommandOptions,\n315. ): Promise<VpsCommandResult> {\n316.     if (process.platform !== 'linux') {\n317.         return {\n318.             isAvailable: false,\n319.             output: unavailableOutput,\n320.         };\n321.     }\n322. \n323.     const scriptPath = await resolveVpsInstallerScriptPath();\n324.     if (!scriptPath) {\n325.         return {\n326.             isAvailable: false,\n327.             output: 'The VPS installer script could not be found on this server.',\n328.         };\n329.     }\n330. \n331.     try {\n332.         const { stdout, stderr } = await execFileAsync('bash', [scriptPath, command], {\n333.             env: createVpsInstallerCommandEnvironment(options),\n334.             maxBuffer: 1024 * 1024,\n335.         });\n336. \n337.         return {\n338.             isAvailable: true,\n339.             output: [stdout, stderr].filter(Boolean).join('\\n').trim(),\n340.         };\n341.     } catch (error) {\n342.         const commandError = error as Error & { readonly stdout?: string; readonly stderr?: string };\n343.         const commandOutput = [commandError.stdout, commandError.stderr, commandError.message]\n344.             .filter(Boolean)\n345.             .join('\\n')\n346.             .trim();\n347. \n348.         throw new Error(\n349.             spaceTrim(`\n350.                 Failed to run VPS installer command \\`${command}\\`.\n351. \n352.                 ${commandOutput}\n353.             `),\n354.         );\n355.     }\n356. }\n357. \n358. /**\n359.  * Creates the environment passed to the shared VPS installer script.\n360.  *\n361.  * @param options - Installer execution options.\n362.  * @returns Child-process environment.\n363.  *\n364.  * @private internal helper of `vpsConfiguration`\n365.  */\n366. export function createVpsInstallerCommandEnvironment(\n367.     options?: RunVpsInstallerCommandOptions,\n368. ): NodeJS.ProcessEnv {\n369.     return {\n370.         ...process.env,\n371.         PTBK_NON_INTERACTIVE: '1',\n372.         ...(options?.isProcessRestartEnabled === false ? { PTBK_SKIP_PM2_RESTART: '1' } : {}),\n373.     };\n374. }\n375. \n376. /**\n377.  * Returns whether an environment variable must be masked in the UI.\n378.  *\n379.  * @param key - Environment variable name.\n380.  * @returns `true` when the value is sensitive.\n381.  */\n382. export function isSensitiveEnvironmentVariable(key: string): boolean {\n383.     return /(?:PASSWORD|SECRET|TOKEN|API_KEY|PRIVATE_KEY|CREDENTIAL)/iu.test(key);\n384. }\n385. \n386. /**\n387.  * Parses a comma-separated domain list.\n388.  *\n389.  * @param value - Raw `SERVERS` value.\n390.  * @returns Normalized unique domains.\n391.  */\n392. export function parseDomainsCsv(value: string): Array<string> {\n393.     return normalizeDomains(value.split(','));\n394. }\n395. \n396. /**\n397.  * Builds the deterministic table prefix used by standalone domain records.\n398.  *\n399.  * @param domain - Normalized domain.\n400.  * @returns Table prefix for the server namespace.\n401.  */\n402. export function buildDomainTablePrefix(domain: string): string {\n403.     const prefixSuffix = domain\n404.         .toLowerCase()\n405.         .replace(/-/gu, '_dash_')\n406.         .replace(/\\./gu, '_')\n407.         .replace(/:/gu, '_port_')\n408.         .replace(/[^a-z0-9_]/gu, '_')\n409.         .replace(/_+/gu, '_')\n410.         .replace(/^_+|_+$/gu, '');\n411. \n412.     return `server_${prefixSuffix}_`;\n413. }\n414. \n415. /**\n416.  * Normalizes a list of raw domain values and removes duplicates.\n417.  *\n418.  * @param domains - Raw domains.\n419.  * @returns Normalized unique domains.\n420.  */\n421. function normalizeDomains(domains: ReadonlyArray<string>): Array<string> {\n422.     const normalizedDomains: Array<string> = [];\n423. \n424.     for (const rawDomain of domains) {\n425.         const normalizedDomain = normalizeServerDomain(rawDomain);\n426.         if (!normalizedDomain || normalizedDomains.includes(normalizedDomain)) {\n427.             continue;\n428.         }\n429. \n430.         normalizedDomains.push(normalizedDomain);\n431.     }\n432. \n433.     return normalizedDomains;\n434. }\n435. \n436. /**\n437.  * Reads a `.env` file into a map.\n438.  *\n439.  * @param envFilePath - File to parse.\n440.  * @returns Parsed environment map.\n441.  */\n442. async function readVpsEnvironmentMap(envFilePath: string): Promise<Map<string, string>> {\n443.     const content = await readOptionalTextFile(envFilePath);\n444.     const envMap = new Map<string, string>();\n445. \n446.     for (const line of parseEnvLines(content)) {\n447.         if (line.type === 'entry') {\n448.             envMap.set(line.key, line.value);\n449.         }\n450.     }\n451. \n452.     return envMap;\n453. }\n454. \n455. /**\n456.  * Normalizes update payloads and rejects unsupported keys.\n457.  *\n458.  * @param updates - Raw request updates.\n459.  * @returns Supported update entries.\n460.  */\n461. function normalizeVpsEnvironmentUpdates(updates: Readonly<Record<string, string>>): Map<string, string> {\n462.     const normalizedUpdates = new Map<string, string>();\n463. \n464.     for (const [rawKey, rawValue] of Object.entries(updates)) {\n465.         if (!isVpsEnvironmentVariableKey(rawKey)) {\n466.             throw new NotAllowed(\n467.                 spaceTrim(`\n468.                     Environment variable \\`${rawKey}\\` is not editable through the Agents Server UI.\n469.                 `),\n470.             );\n471.         }\n472. \n473.         if (typeof rawValue !== 'string') {\n474.             continue;\n475.         }\n476. \n477.         const value = rawValue.trim();\n478.         if (isSensitiveEnvironmentVariable(rawKey) && (value === '' || value === HIDDEN_ENVIRONMENT_VALUE)) {\n479.             continue;\n480.         }\n481. \n482.         normalizedUpdates.set(rawKey, value);\n483.     }\n484. \n485.     return normalizedUpdates;\n486. }\n487. \n488. /**\n489.  * Checks whether a raw key is supported by the VPS UI.\n490.  *\n491.  * @param key - Candidate environment variable key.\n492.  * @returns `true` when supported.\n493.  */\n494. function isVpsEnvironmentVariableKey(key: string): key is VpsEnvironmentVariableKey {\n495.     return VPS_ENVIRONMENT_VARIABLE_KEYS.includes(key as VpsEnvironmentVariableKey);\n496. }\n497. \n498. /**\n499.  * Serializes an updated `.env` file while preserving unrelated lines.\n500.  *\n501.  * @param existingContent - Current file content.\n502.  * @param updates - Normalized updates to apply.\n503.  * @returns Next file content.\n504.  */\n505. function serializeUpdatedEnvFile(existingContent: string, updates: ReadonlyMap<string, string>): string {\n506.     const remainingUpdates = new Map(updates);\n507.     const nextLines = parseEnvLines(existingContent).map((line) => {\n508.         if (line.type !== 'entry' || !remainingUpdates.has(line.key)) {\n509.             return line.raw;\n510.         }\n511. \n512.         const nextValue = remainingUpdates.get(line.key)!;\n513.         remainingUpdates.delete(line.key);\n514.         return `${line.key}=${nextValue}`;\n515.     });\n516. \n517.     for (const [key, value] of remainingUpdates) {\n518.         nextLines.push(`${key}=${value}`);\n519.     }\n520. \n521.     return `${nextLines.join('\\n').replace(/\\n+$/u, '')}\\n`;\n522. }\n523. \n524. /**\n525.  * Parses `.env` content into structured lines.\n526.  *\n527.  * @param content - Raw `.env` content.\n528.  * @returns Parsed line records.\n529.  */\n530. function parseEnvLines(content: string): Array<ParsedEnvLine> {\n531.     return content.split(/\\r?\\n/u).map((raw) => {\n532.         const match = raw.match(/^\\s*(?:export\\s+)?([A-Za-z_][A-Za-z0-9_]*)=(.*)$/u);\n533.         if (!match) {\n534.             return { type: 'raw', raw };\n535.         }\n536. \n537.         const key = match[1];\n538.         const rawValue = match[2] ?? '';\n539.         if (!key) {\n540.             return { type: 'raw', raw };\n541.         }\n542. \n543.         return {\n544.             type: 'entry',\n545.             raw,\n546.             key,\n547.             value: parseEnvValue(rawValue),\n548.         };\n549.     });\n550. }\n551. \n552. /**\n553.  * Parses the common `.env` value quoting forms.\n554.  *\n555.  * @param rawValue - Raw text after `=`.\n556.  * @returns Unquoted value.\n557.  */\n558. function parseEnvValue(rawValue: string): string {\n559.     const trimmedValue = rawValue.trim();\n560.     if (\n561.         (trimmedValue.startsWith('\"') && trimmedValue.endsWith('\"')) ||\n562.         (trimmedValue.startsWith(\"'\") && trimmedValue.endsWith(\"'\"))\n563.     ) {\n564.         return trimmedValue.slice(1, -1);\n565.     }\n566. \n567.     return trimmedValue;\n568. }\n569. \n570. /**\n571.  * Reads a text file and returns an empty string when it does not exist.\n572.  *\n573.  * @param filePath - File to read.\n574.  * @returns File content or empty string.\n575.  */\n576. async function readOptionalTextFile(filePath: string): Promise<string> {\n577.     try {\n578.         return await readFile(filePath, 'utf-8');\n579.     } catch (error) {\n580.         if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n581.             return '';\n582.         }\n583. \n584.         throw error;\n585.     }\n586. }\n587. \n588. /**\n589.  * Resolves the shared VPS installer script path.\n590.  *\n591.  * @returns Script path or `null` when unavailable.\n592.  */\n593. async function resolveVpsInstallerScriptPath(): Promise<string | null> {\n594.     const candidates = [\n595.         process.env.PTBK_VPS_INSTALL_SCRIPT?.trim(),\n596.         process.env.PTBK_REPOSITORY_DIR ? join(process.env.PTBK_REPOSITORY_DIR, 'other/vps/install.sh') : '',\n597.         join(process.cwd(), 'other/vps/install.sh'),\n598.         join(process.cwd(), '../../other/vps/install.sh'),\n599.     ].filter((candidate): candidate is string => Boolean(candidate));\n600. \n601.     for (const candidate of candidates) {\n602.         const absoluteCandidate = resolve(candidate);\n603.         try {\n604.             await access(absoluteCandidate, filesystemConstants.R_OK);\n605.             return absoluteCandidate;\n606.         } catch {\n607.             // Try the next candidate.\n608.         }\n609.     }\n610. \n611.     return null;\n612. }\n613. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/utils/vpsConfiguration.ts b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/utils/vpsConfiguration.ts\nindex 0000000..0000000 100644\n--- a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/utils/vpsConfiguration.ts\n+++ b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/utils/vpsConfiguration.ts\n@@ -1,613 +1,613 @@\n import { execFile } from 'child_process';\n import { constants as filesystemConstants } from 'fs';\n import { access, mkdir, readFile, writeFile } from 'fs/promises';\n import { dirname, join, resolve } from 'path';\n import { promisify } from 'util';\n import { spaceTrim } from 'spacetrim';\n import { NotAllowed } from '../../../../src/errors/NotAllowed';\n import { normalizeServerDomain } from './serverRegistry';\n import { isStandaloneVpsRawIpBootstrapActive } from './standaloneVpsRawIpBootstrap';\n \n const execFileAsync = promisify(execFile);\n \n /**\n  * Mask rendered for sensitive environment values in the UI.\n  */\n export const HIDDEN_ENVIRONMENT_VALUE = '********';\n \n /**\n  * Environment variable names that can be managed from the standalone VPS UI.\n  */\n export const VPS_ENVIRONMENT_VARIABLE_KEYS = [\n     'SERVERS',\n     'NEXT_PUBLIC_SITE_URL',\n     'ADMIN_PASSWORD',\n     'OPENAI_API_KEY',\n     'PTBK_AGENT',\n     'PTBK_MODEL',\n     'PTBK_THINKING_LEVEL',\n     'PORT',\n     'PTBK_HOSTNAME',\n     'PTBK_PUBLIC_IP_ADDRESS',\n     'PTBK_PM2_APP_NAME',\n     'PTBK_NGINX_SITE_NAME',\n     'LETS_ENCRYPT_EMAIL',\n     'PTBK_AGENTS_SERVER_DATABASE',\n     'PTBK_AGENTS_SERVER_SQLITE_PATH',\n     'SUPABASE_TABLE_PREFIX',\n     'SUPABASE_AUTO_MIGRATE',\n     'COPILOT_GITHUB_TOKEN',\n     'GH_TOKEN',\n     'ANTHROPIC_CLAUDE_API_KEY',\n     'GOOGLE_GENERATIVE_AI_API_KEY',\n     'AZUREOPENAI_API_KEY',\n ] as const;\n \n /**\n  * Editable environment variable key supported by the standalone VPS UI.\n  */\n export type VpsEnvironmentVariableKey = (typeof VPS_ENVIRONMENT_VARIABLE_KEYS)[number];\n \n /**\n  * One environment variable row safe to send to the browser.\n  */\n export type VpsEnvironmentVariableRecord = {\n     /**\n      * Environment variable name.\n      */\n     readonly key: VpsEnvironmentVariableKey;\n \n     /**\n      * Masked or plain UI value.\n      */\n     readonly value: string;\n \n     /**\n      * Whether the real stored value is sensitive and hidden.\n      */\n     readonly isSensitive: boolean;\n \n     /**\n      * Whether the variable exists in the `.env` file or current process.\n      */\n     readonly isDefined: boolean;\n };\n \n /**\n  * Result of running a VPS command from the admin UI.\n  */\n export type VpsCommandResult = {\n     /**\n      * Whether the command was attempted on this host.\n      */\n     readonly isAvailable: boolean;\n \n     /**\n      * Process exit output or skipped reason.\n      */\n     readonly output: string;\n };\n \n /**\n  * Runtime-installer execution options used by VPS admin actions.\n  */\n type RunVpsInstallerCommandOptions = {\n     /**\n      * Whether the installer may restart the running Agents Server process.\n      */\n     readonly isProcessRestartEnabled?: boolean;\n };\n \n /**\n  * Parsed `.env` line representation used to preserve comments and ordering.\n  */\n type ParsedEnvLine =\n     | {\n           readonly type: 'entry';\n           readonly raw: string;\n           readonly key: string;\n           readonly value: string;\n       }\n     | {\n           readonly type: 'raw';\n           readonly raw: string;\n       };\n \n /**\n  * Returns the installed Agents Server `.env` file path.\n  *\n  * @returns Absolute path to the editable `.env` file.\n  */\n export function resolveVpsEnvironmentFilePath(): string {\n     const explicitEnvFile = process.env.PTBK_AGENTS_SERVER_ENV_FILE?.trim();\n     if (explicitEnvFile) {\n         return resolve(explicitEnvFile);\n     }\n \n     const explicitInstallDirectory = process.env.PTBK_INSTALL_DIR?.trim();\n     if (explicitInstallDirectory) {\n         return resolve(explicitInstallDirectory, '.env');\n     }\n \n     const sqlitePath = process.env.PTBK_AGENTS_SERVER_SQLITE_PATH?.trim();\n     if (sqlitePath) {\n         return resolve(dirname(dirname(resolve(sqlitePath))), '.env');\n     }\n \n     return resolve(process.cwd(), '.env');\n }\n \n /**\n  * Reads managed environment variables with sensitive values masked.\n  *\n  * @returns Safe environment snapshot for the admin UI.\n  */\n export async function listVpsEnvironmentVariables(): Promise<{\n     readonly envFilePath: string;\n     readonly variables: ReadonlyArray<VpsEnvironmentVariableRecord>;\n }> {\n     const envFilePath = resolveVpsEnvironmentFilePath();\n     const envValues = await readVpsEnvironmentMap(envFilePath);\n \n     return {\n         envFilePath,\n         variables: VPS_ENVIRONMENT_VARIABLE_KEYS.map((key) => {\n             const rawValue = envValues.get(key) ?? process.env[key] ?? '';\n             const isSensitive = isSensitiveEnvironmentVariable(key);\n             return {\n                 key,\n                 value: isSensitive && rawValue ? HIDDEN_ENVIRONMENT_VALUE : rawValue,\n                 isSensitive,\n                 isDefined: rawValue !== '',\n             };\n         }),\n     };\n }\n \n /**\n  * Updates supported variables in the installed `.env` file.\n  *\n  * Sensitive variables are updated only when the submitted value is not empty and not the mask.\n  *\n  * @param updates - Key/value pairs to persist.\n  * @returns Safe environment snapshot after writing.\n  */\n export async function updateVpsEnvironmentVariables(\n     updates: Readonly<Record<string, string>>,\n ): Promise<Awaited<ReturnType<typeof listVpsEnvironmentVariables>>> {\n     const normalizedUpdates = normalizeVpsEnvironmentUpdates(updates);\n     const envFilePath = resolveVpsEnvironmentFilePath();\n     const existingContent = await readOptionalTextFile(envFilePath);\n     const nextContent = serializeUpdatedEnvFile(existingContent, normalizedUpdates);\n \n     await mkdir(dirname(envFilePath), { recursive: true });\n     await writeFile(envFilePath, nextContent, { encoding: 'utf-8', mode: 0o600 });\n \n     for (const [key, value] of normalizedUpdates) {\n         process.env[key] = value;\n     }\n \n     return listVpsEnvironmentVariables();\n }\n \n /**\n  * Reads domains from the installed `.env` file or current process.\n  *\n  * @returns Normalized configured domains.\n  */\n export async function listConfiguredVpsDomains(): Promise<Array<string>> {\n     const envValues = await readVpsEnvironmentMap(resolveVpsEnvironmentFilePath());\n     const rawServers = envValues.get('SERVERS') ?? process.env.SERVERS ?? '';\n \n     return parseDomainsCsv(rawServers);\n }\n \n /**\n  * Options used when updating the standalone VPS domain list.\n  */\n type UpdateConfiguredVpsDomainsOptions = {\n     /**\n      * Optional server-level table prefix to persist together with the domain list.\n      */\n     readonly tablePrefix?: string | null;\n };\n \n /**\n  * Replaces the standalone VPS domain list in `.env`.\n  *\n  * @param domains - Domains to store in `SERVERS`.\n  * @param options - Optional server-level settings to persist.\n  * @returns Safe environment snapshot after writing.\n  */\n export async function updateConfiguredVpsDomains(\n     domains: ReadonlyArray<string>,\n     options?: UpdateConfiguredVpsDomainsOptions,\n ): Promise<Awaited<ReturnType<typeof listVpsEnvironmentVariables>>> {\n     const normalizedDomains = normalizeDomains(domains);\n     const primaryDomain = normalizedDomains[0] ?? '';\n     const envValues = await readVpsEnvironmentMap(resolveVpsEnvironmentFilePath());\n     const currentPublicSiteUrl = envValues.get('NEXT_PUBLIC_SITE_URL') ?? process.env.NEXT_PUBLIC_SITE_URL ?? '';\n     const publicIpAddress = envValues.get('PTBK_PUBLIC_IP_ADDRESS') ?? process.env.PTBK_PUBLIC_IP_ADDRESS ?? '';\n     const updates: Record<string, string> = {\n         SERVERS: normalizedDomains.join(','),\n     };\n \n     if (primaryDomain) {\n         updates.NEXT_PUBLIC_SITE_URL = isStandaloneVpsRawIpBootstrapActive({\n             nextPublicSiteUrl: currentPublicSiteUrl,\n             publicIpAddress,\n         })\n             ? currentPublicSiteUrl\n             : `https://${primaryDomain}`;\n     } else {\n         updates.NEXT_PUBLIC_SITE_URL = publicIpAddress\n             ? `http://${publicIpAddress}`\n             : '';\n     }\n \n     if (options && Object.prototype.hasOwnProperty.call(options, 'tablePrefix')) {\n         updates.SUPABASE_TABLE_PREFIX = options.tablePrefix?.trim() || '';\n     }\n \n     return updateVpsEnvironmentVariables(updates);\n }\n \n /**\n  * Applies Nginx, Certbot, and process-manager changes through the shared VPS installer script.\n  *\n  * @returns Command output or a skipped reason when not running on a Linux VPS.\n  */\n export async function applyVpsRuntimeConfiguration(\n     options?: RunVpsInstallerCommandOptions,\n ): Promise<VpsCommandResult> {\n     return runVpsInstallerCommand(\n         'apply-domains',\n         'VPS runtime configuration can only be applied on Linux.',\n         options,\n     );\n }\n \n /**\n  * Installs/configures the selected local code runner through the shared VPS installer script.\n  *\n  * @returns Command output or a skipped reason when not running on a Linux VPS.\n  */\n export async function applyVpsCodeRunnerConfiguration(): Promise<VpsCommandResult> {\n     return runVpsInstallerCommand('apply-runner', 'VPS code-runner configuration can only be applied on Linux.');\n }\n \n /**\n  * Reads recent pm2 logs for the configured Agents Server process.\n  *\n  * @param lineCount - Number of lines to request.\n  * @returns Log output or a skipped reason.\n  */\n export async function readVpsPm2Logs(lineCount = 200): Promise<VpsCommandResult> {\n     if (process.platform !== 'linux') {\n         return {\n             isAvailable: false,\n             output: 'pm2 logs are available only on the Linux VPS runtime.',\n         };\n     }\n \n     const appName = process.env.PTBK_PM2_APP_NAME?.trim() || 'promptbook-agents-server';\n     const { stdout, stderr } = await execFileAsync('pm2', ['logs', appName, '--nostream', '--lines', String(lineCount)], {\n         maxBuffer: 1024 * 1024,\n     });\n \n     return {\n         isAvailable: true,\n         output: [stdout, stderr].filter(Boolean).join('\\n').trim(),\n     };\n }\n \n /**\n  * Runs one maintenance subcommand from the shared VPS installer script.\n  *\n  * @param command - Installer subcommand.\n  * @param unavailableOutput - Message returned on non-Linux platforms.\n  * @returns Command output or unavailable reason.\n  */\n async function runVpsInstallerCommand(\n     command: string,\n     unavailableOutput: string,\n     options?: RunVpsInstallerCommandOptions,\n ): Promise<VpsCommandResult> {\n     if (process.platform !== 'linux') {\n         return {\n             isAvailable: false,\n             output: unavailableOutput,\n         };\n     }\n \n     const scriptPath = await resolveVpsInstallerScriptPath();\n     if (!scriptPath) {\n         return {\n             isAvailable: false,\n             output: 'The VPS installer script could not be found on this server.',\n         };\n     }\n \n     try {\n         const { stdout, stderr } = await execFileAsync('bash', [scriptPath, command], {\n             env: createVpsInstallerCommandEnvironment(options),\n             maxBuffer: 1024 * 1024,\n         });\n \n         return {\n             isAvailable: true,\n             output: [stdout, stderr].filter(Boolean).join('\\n').trim(),\n         };\n     } catch (error) {\n         const commandError = error as Error & { readonly stdout?: string; readonly stderr?: string };\n         const commandOutput = [commandError.stdout, commandError.stderr, commandError.message]\n             .filter(Boolean)\n             .join('\\n')\n             .trim();\n \n         throw new Error(\n             spaceTrim(`\n                 Failed to run VPS installer command \\`${command}\\`.\n \n                 ${commandOutput}\n             `),\n         );\n     }\n }\n \n /**\n  * Creates the environment passed to the shared VPS installer script.\n  *\n  * @param options - Installer execution options.\n  * @returns Child-process environment.\n  *\n  * @private internal helper of `vpsConfiguration`\n  */\n export function createVpsInstallerCommandEnvironment(\n     options?: RunVpsInstallerCommandOptions,\n ): NodeJS.ProcessEnv {\n     return {\n         ...process.env,\n         PTBK_NON_INTERACTIVE: '1',\n         ...(options?.isProcessRestartEnabled === false ? { PTBK_SKIP_PM2_RESTART: '1' } : {}),\n     };\n }\n \n /**\n  * Returns whether an environment variable must be masked in the UI.\n  *\n  * @param key - Environment variable name.\n  * @returns `true` when the value is sensitive.\n  */\n export function isSensitiveEnvironmentVariable(key: string): boolean {\n     return /(?:PASSWORD|SECRET|TOKEN|API_KEY|PRIVATE_KEY|CREDENTIAL)/iu.test(key);\n }\n \n /**\n  * Parses a comma-separated domain list.\n  *\n  * @param value - Raw `SERVERS` value.\n  * @returns Normalized unique domains.\n  */\n export function parseDomainsCsv(value: string): Array<string> {\n     return normalizeDomains(value.split(','));\n }\n \n /**\n  * Builds the deterministic table prefix used by standalone domain records.\n  *\n  * @param domain - Normalized domain.\n  * @returns Table prefix for the server namespace.\n  */\n export function buildDomainTablePrefix(domain: string): string {\n     const prefixSuffix = domain\n         .toLowerCase()\n         .replace(/-/gu, '_dash_')\n         .replace(/\\./gu, '_')\n         .replace(/:/gu, '_port_')\n         .replace(/[^a-z0-9_]/gu, '_')\n         .replace(/_+/gu, '_')\n         .replace(/^_+|_+$/gu, '');\n \n     return `server_${prefixSuffix}_`;\n }\n \n /**\n  * Normalizes a list of raw domain values and removes duplicates.\n  *\n  * @param domains - Raw domains.\n  * @returns Normalized unique domains.\n  */\n function normalizeDomains(domains: ReadonlyArray<string>): Array<string> {\n     const normalizedDomains: Array<string> = [];\n \n     for (const rawDomain of domains) {\n         const normalizedDomain = normalizeServerDomain(rawDomain);\n         if (!normalizedDomain || normalizedDomains.includes(normalizedDomain)) {\n             continue;\n         }\n \n         normalizedDomains.push(normalizedDomain);\n     }\n \n     return normalizedDomains;\n }\n \n /**\n  * Reads a `.env` file into a map.\n  *\n  * @param envFilePath - File to parse.\n  * @returns Parsed environment map.\n  */\n async function readVpsEnvironmentMap(envFilePath: string): Promise<Map<string, string>> {\n     const content = await readOptionalTextFile(envFilePath);\n     const envMap = new Map<string, string>();\n \n     for (const line of parseEnvLines(content)) {\n         if (line.type === 'entry') {\n             envMap.set(line.key, line.value);\n         }\n     }\n \n     return envMap;\n }\n \n /**\n  * Normalizes update payloads and rejects unsupported keys.\n  *\n  * @param updates - Raw request updates.\n  * @returns Supported update entries.\n  */\n function normalizeVpsEnvironmentUpdates(updates: Readonly<Record<string, string>>): Map<string, string> {\n     const normalizedUpdates = new Map<string, string>();\n \n     for (const [rawKey, rawValue] of Object.entries(updates)) {\n         if (!isVpsEnvironmentVariableKey(rawKey)) {\n             throw new NotAllowed(\n                 spaceTrim(`\n                     Environment variable \\`${rawKey}\\` is not editable through the Agents Server UI.\n                 `),\n             );\n         }\n \n         if (typeof rawValue !== 'string') {\n             continue;\n         }\n \n         const value = rawValue.trim();\n         if (isSensitiveEnvironmentVariable(rawKey) && (value === '' || value === HIDDEN_ENVIRONMENT_VALUE)) {\n             continue;\n         }\n \n         normalizedUpdates.set(rawKey, value);\n     }\n \n     return normalizedUpdates;\n }\n \n /**\n  * Checks whether a raw key is supported by the VPS UI.\n  *\n  * @param key - Candidate environment variable key.\n  * @returns `true` when supported.\n  */\n function isVpsEnvironmentVariableKey(key: string): key is VpsEnvironmentVariableKey {\n     return VPS_ENVIRONMENT_VARIABLE_KEYS.includes(key as VpsEnvironmentVariableKey);\n }\n \n /**\n  * Serializes an updated `.env` file while preserving unrelated lines.\n  *\n  * @param existingContent - Current file content.\n  * @param updates - Normalized updates to apply.\n  * @returns Next file content.\n  */\n function serializeUpdatedEnvFile(existingContent: string, updates: ReadonlyMap<string, string>): string {\n     const remainingUpdates = new Map(updates);\n     const nextLines = parseEnvLines(existingContent).map((line) => {\n         if (line.type !== 'entry' || !remainingUpdates.has(line.key)) {\n             return line.raw;\n         }\n \n         const nextValue = remainingUpdates.get(line.key)!;\n         remainingUpdates.delete(line.key);\n         return `${line.key}=${nextValue}`;\n     });\n \n     for (const [key, value] of remainingUpdates) {\n         nextLines.push(`${key}=${value}`);\n     }\n \n     return `${nextLines.join('\\n').replace(/\\n+$/u, '')}\\n`;\n }\n \n /**\n  * Parses `.env` content into structured lines.\n  *\n  * @param content - Raw `.env` content.\n  * @returns Parsed line records.\n  */\n function parseEnvLines(content: string): Array<ParsedEnvLine> {\n     return content.split(/\\r?\\n/u).map((raw) => {\n         const match = raw.match(/^\\s*(?:export\\s+)?([A-Za-z_][A-Za-z0-9_]*)=(.*)$/u);\n         if (!match) {\n             return { type: 'raw', raw };\n         }\n \n         const key = match[1];\n         const rawValue = match[2] ?? '';\n         if (!key) {\n             return { type: 'raw', raw };\n         }\n \n         return {\n             type: 'entry',\n             raw,\n             key,\n             value: parseEnvValue(rawValue),\n         };\n     });\n }\n \n /**\n  * Parses the common `.env` value quoting forms.\n  *\n  * @param rawValue - Raw text after `=`.\n  * @returns Unquoted value.\n  */\n function parseEnvValue(rawValue: string): string {\n     const trimmedValue = rawValue.trim();\n     if (\n         (trimmedValue.startsWith('\"') && trimmedValue.endsWith('\"')) ||\n         (trimmedValue.startsWith(\"'\") && trimmedValue.endsWith(\"'\"))\n     ) {\n         return trimmedValue.slice(1, -1);\n     }\n \n     return trimmedValue;\n }\n \n /**\n  * Reads a text file and returns an empty string when it does not exist.\n  *\n  * @param filePath - File to read.\n  * @returns File content or empty string.\n  */\n async function readOptionalTextFile(filePath: string): Promise<string> {\n     try {\n         return await readFile(filePath, 'utf-8');\n     } catch (error) {\n         if ((error as NodeJS.ErrnoException).code === 'ENOENT') {\n             return '';\n         }\n \n         throw error;\n     }\n }\n \n /**\n  * Resolves the shared VPS installer script path.\n  *\n  * @returns Script path or `null` when unavailable.\n  */\n async function resolveVpsInstallerScriptPath(): Promise<string | null> {\n     const candidates = [\n         process.env.PTBK_VPS_INSTALL_SCRIPT?.trim(),\n         process.env.PTBK_REPOSITORY_DIR ? join(process.env.PTBK_REPOSITORY_DIR, 'other/vps/install.sh') : '',\n         join(process.cwd(), 'other/vps/install.sh'),\n         join(process.cwd(), '../../other/vps/install.sh'),\n     ].filter((candidate): candidate is string => Boolean(candidate));\n \n     for (const candidate of candidates) {\n         const absoluteCandidate = resolve(candidate);\n         try {\n             await access(absoluteCandidate, filesystemConstants.R_OK);\n             return absoluteCandidate;\n         } catch {\n             // Try the next candidate.\n         }\n     }\n \n     return null;\n }\n \n"},"toolTelemetry":{"properties":{"command":"view","options":"{\"truncateBasedOn\":\"tokenCount\",\"truncateStyle\":\"middle\"}","inputs":"[\"path\",\"command\"]","resolvedPathAgainstCwd":"false","fileExtension":"[\".ts\"]","viewType":"file"},"metrics":{"resultLength":21437,"resultForLlmLength":21437,"responseTokenLimit":68000},"restrictedProperties":{}}},"id":"886e8180-738e-4874-b201-19b745803e15","timestamp":"2026-05-29T10:02:59.626Z","parentId":"ce9d6f4a-230d-4b74-aa6f-596ee9011ed4"}
