ons.\n42.  */\n43. export type DatabaseMigrationRuntimeConfiguration = {\n44.     /**\n45.      * Prefixes for all table namespaces that should be migrated.\n46.      */\n47.     readonly prefixes: ReadonlyArray<string>;\n48.     /**\n49.      * Registered servers loaded from the global `_Server` table.\n50.      */\n51.     readonly registeredServers: ReadonlyArray<ServerRecord>;\n52.     /**\n53.      * Connection string for PostgreSQL used by migration runner.\n54.      */\n55.     readonly connectionString: string;\n56. };\n57. \n58. /**\n59.  * Options controlling one migration execution.\n60.  */\n61. export type RunDatabaseMigrationsOptions = {\n62.     /**\n63.      * Prefixes that should be migrated.\n64.      */\n65.     readonly prefixes: ReadonlyArray<string>;\n66.     /**\n67.      * Registered servers used for `--only=production|preview|<server-name>` expansion.\n68.      */\n69.     readonly registeredServers?: ReadonlyArray<ServerRecord>;\n70.     /**\n71.      * PostgreSQL connection string.\n72.      */\n73.     readonly connectionString: string;\n74.     /**\n75.      * Whether migration records should be marked as automatic or manual.\n76.      */\n77.     readonly appliedBy: DatabaseMigrationAppliedBy;\n78.     /**\n79.      * Optional subset of migration targets to process.\n80.      */\n81.     readonly onlyTargets?: ReadonlyArray<string> | null;\n82.     /**\n83.      * Optional custom migrations directory.\n84.      */\n85.     readonly migrationsDirectory?: string;\n86.     /**\n87.      * Logger used for progress output.\n88.      */\n89.     readonly logger?: DatabaseMigrationLogger;\n90.     /**\n91.      * If true, prints every SQL migration body before execution.\n92.      */\n93.     readonly logSqlStatements?: boolean;\n94.     /**\n95.      * Whether migration execution should wait for the advisory lock or skip when another process already owns it.\n96.      */\n97.     readonly executionLockMode?: DatabaseMigrationExecutionLockMode;\n98. };\n99. \n100. /**\n101.  * Result of one prefix migration run.\n102.  */\n103. export type DatabaseMigrationPrefixResult = {\n104.     /**\n105.      * Prefix that was processed.\n106.      */\n107.     readonly prefix: string;\n108.     /**\n109.      * Number of newly applied migration files.\n110.      */\n111.     readonly appliedCount: number;\n112. };\n113. \n114. /**\n115.  * Result of full migration run across all selected prefixes.\n116.  */\n117. export type RunDatabaseMigrationsResult = {\n118.     /**\n119.      * Prefixes that were processed.\n120.      */\n121.     readonly processedPrefixes: ReadonlyArray<string>;\n122.     /**\n123.      * Number of SQL migration files discovered on disk.\n124.      */\n125.     readonly totalMigrationFiles: number;\n126.     /**\n127.      * Per-prefix summary.\n128.      */\n129.     readonly perPrefix: ReadonlyArray<DatabaseMigrationPrefixResult>;\n130.     /**\n131.      * Whether migration execution was skipped because another process already held the advisory lock.\n132.      */\n133.     readonly isSkippedDueToActiveMigrationLock: boolean;\n134. };\n135. \n136. /**\n137.  * Constructor shape exposed by the `pg` package.\n138.  */\n139. type PostgresClientConstructor = new (options: {\n140.     readonly connectionString: string;\n141.     readonly ssl: {\n142.         readonly rejectUnauthorized: boolean;\n143.     };\n144. }) => Client;\n145. \n146. /**\n147.  * Environment variable used for the current/default table prefix.\n148.  */\n149. const SUPABASE_TABLE_PREFIX_ENV_NAME = 'SUPABASE_TABLE_PREFIX';\n150. \n151. /**\n152.  * Candidate environment variables for PostgreSQL connection string.\n153.  */\n154. const DATABASE_CONNECTION_ENV_NAMES = ['POSTGRES_URL', 'DATABASE_URL'] as const;\n155. \n156. /**\n157.  * Reads migration runtime configuration from environment variables and `_Server`.\n158.  *\n159.  * @param logger - Logger used for warnings.\n160.  * @returns Parsed configuration or `null` when migration should be skipped.\n161.  */\n162. export async function resolveDatabaseMigrationRuntimeConfiguration(\n163.     logger: DatabaseMigrationLogger = console,\n164. ): Promise<DatabaseMigrationRuntimeConfiguration | null> {\n165.     const connectionString = resolveDatabaseMigrationConnectionStringFromEnvironment();\n166.     if (!connectionString) {\n167.         throw new DatabaseError(\n168.             spaceTrim(`\n169.                 ${DATABASE_CONNECTION_ENV_NAMES.join(' or ')} is not defined.\n170.             `),\n171.         );\n172.     }\n173. \n174.     const client = await createPostgresClient(connectionString);\n175. \n176.     try {\n177.         await client.connect();\n178. \n179.         const registeredServers = mergeRegisteredServers(\n180.             await listRegisteredServersFromDatabase(client),\n181.             listEnvironmentRegisteredServers(),\n182.         );\n183.         const hasExplicitDefaultPrefix = process.env[SUPABASE_TABLE_PREFIX_ENV_NAME] !== undefined;\n184.         const configuredPrefixes = uniquePrefixes([\n185.             ...(hasExplicitDefaultPrefix\n186.                 ? [process.env[SUPABASE_TABLE_PREFIX_ENV_NAME] || '']\n187.                 : registeredServers.length === 0\n188.                 ? ['']\n189.                 : []),\n190.             ...registeredServers.map((server) => server.tablePrefix),\n191.         ]);\n192. \n193.         if (configuredPrefixes.length === 0) {\n194.             logger.warn(`⚠️ No migration prefixes resolved from \\`${SUPABASE_TABLE_PREFIX_ENV_NAME}\\` or \\`_Server\\`.`);\n195.             return null;\n196.         }\n197. \n198.         logger.info(`🗂️ Loaded ${registeredServers.length} registered servers from \\`_Server\\`.`);\n199. \n200.         return {\n201.             prefixes: configuredPrefixes,\n202.             registeredServers,\n203.             connectionString,\n204.         };\n205.     } finally {\n206.         await client.end();\n207.     }\n208. }\n209. \n210. /**\n211.  * Executes pending SQL migrations for selected prefixes.\n212.  *\n213.  * @param options - Migration execution options.\n214.  * @returns Aggregated migration summary.\n215.  */\n216. export async function runDatabaseMigrations(\n217.     options: RunDatabaseMigrationsOptions,\n218. ): Promise<RunDatabaseMigrationsResult> {\n219.     const logger = options.logger ?? console;\n220.     const failureContext: DatabaseMigrationFailureContext = {\n221.         stage: 'prepare-migration-plan',\n222.         onlyTargets: options.onlyTargets ?? null,\n223.         selectedPrefixes: [],\n224.         totalMigrationFiles: 0,\n225.         executionLockMode: options.executionLockMode ?? 'wait',\n226.     };\n227.     const perPrefix: Array<DatabaseMigrationPrefixResult> = [];\n228.     let client: Client | null = null;\n229.     let selectedPrefixes: Array<string> = [];\n230.     let totalMigrationFiles = 0;\n231.     let hasExecutionLock = false;\n232.     let isSkippedDueToActiveMigrationLock = false;\n233.     let migrationFailure: unknown = null;\n234.     let migrationsDirectory = '';\n235.     let migrationFiles: Array<string> = [];\n236. \n237.     try {\n238.         selectedPrefixes = selectPrefixesForMigration(options.prefixes, options.registeredServers ?? [], options.onlyTargets);\n239.         failureContext.selectedPrefixes = selectedPrefixes;\n240. \n241.         migrationsDirectory = options.migrationsDirectory ?? (await resolveMigrationsDirectory());\n242.         migrationFiles = await readMigrationFiles(migrationsDirectory);\n243.         totalMigrationFiles = migrationFiles.length;\n244.         failureContext.totalMigrationFiles = totalMigrationFiles;\n245. \n246.         logger.info(`📂 Found ${totalMigrationFiles} migration files`);\n247.         logger.info(\n248.             `📋 Found ${selectedPrefixes.length} prefixes to migrate: ${selectedPrefixes\n249.                 .map((prefix) => prefix || '<default>')\n250.                 .join(', ')}`,\n251.         );\n252. \n253.         failureContext.stage = 'connect-to-database';\n254.         client = await createPostgresClient(options.connectionString);\n255.         await client.connect();\n256.         logger.info('🔌 Connected to database');\n257. \n258.         failureContext.stage = 'acquire-migration-lock';\n259.         hasExecutionLock = await acquireMigrationExecutionLock(client, logger, options.executionLockMode ?? 'wait');\n260. \n261.         if (!hasExecutionLock) {\n262.             isSkippedDueToActiveMigrationLock = true;\n263. \n264.             return {\n265.                 processedPrefixes: [],\n266.                 totalMigrationFiles,\n267.                 perPrefix,\n268.                 isSkippedDueToActiveMigrationLock,\n269.             };\n270.         }\n271. \n272.         for (const prefix of selectedPrefixes) {\n273.             failureContext.stage = 'migrate-prefix';\n274.             failureContext.currentPrefix = prefix;\n275.             failureContext.currentPrefixStage = undefined;\n276.             failureContext.currentMigrationFile = undefined;\n277.             logger.info(`\\n🏗️ Migrating prefix: \"${prefix}\"`);\n278.             const appliedCount = await migratePrefix({\n279.                 prefix,\n280.                 appliedBy: options.appliedBy,\n281.                 manualAppliedByDefault: DATABASE_MIGRATION_APPLIED_BY.MANUAL,\n282.                 client,\n283.                 logger,\n284.                 migrationFiles,\n285.                 migrationsDirectory,\n286.                 logSqlStatements: options.logSqlStatements ?? false,\n287.                 onProgress: ({ prefix, stage, migrationFile }) => {\n288.                     failureContext.currentPrefix = prefix;\n289.                     failureContext.currentPrefixStage = stage;\n290.                     failureContext.currentMigrationFile = migrationFile;\n291.                 },\n292.             });\n293.             perPrefix.push({ prefix, appliedCount });\n294.         }\n295. \n296.         return {\n297.             processedPrefixes: selectedPrefixes,\n298.             totalMigrationFiles,\n299.             perPrefix,\n300.             isSkippedDueToActiveMigrationLock,\n301.         };\n302.     } catch (error) {\n303.         migrationFailure = createDatabaseMigrationFailureError(error, failureContext);\n304.     } finally {\n305.         if (client) {\n306.             if (hasExecutionLock) {\n307.                 await releaseMigrationExecutionLock(client, logger);\n308.             }\n309. \n310.             try {\n311.                 await client.end();\n312.             } catch (clientEndError) {\n313.                 if (migrationFailure === null) {\n314.                     migrationFailure = clientEndError;\n315.                 } else {\n316.                     logger.warn('⚠️ Failed to close migration database connection');\n317.                     logger.warn(String(clientEndError));\n318.                 }\n319.             }\n320.         }\n321.     }\n322. \n323.     throw migrationFailure;\n324. }\n325. \n326. /**\n327.  * Resolves PostgreSQL connection string from supported environment variables.\n328.  *\n329.  * @returns Connection string or `null` when not found.\n330.  */\n331. export function resolveDatabaseMigrationConnectionStringFromEnvironment(): string | null {\n332.     for (const envName of DATABASE_CONNECTION_ENV_NAMES) {\n333.         const value = process.env[envName];\n334.         if (value) {\n335.             return value;\n336.         }\n337.     }\n338. \n339.     return null;\n340. }\n341. \n342. /**\n343.  * Returns unique non-empty prefixes while preserving input order.\n344.  *\n345.  * @param prefixes - Raw prefixes.\n346.  * @returns Ordered unique prefixes.\n347.  */\n348. function uniquePrefixes(prefixes: ReadonlyArray<string>): Array<string> {\n349.     const result: Array<string> = [];\n350. \n351.     for (const prefix of prefixes) {\n352.         const normalizedPrefix = prefix.trim();\n353.         if (result.includes(normalizedPrefix)) {\n354.             continue;\n355.         }\n356.         result.push(normalizedPrefix);\n357.     }\n358. \n359.     return result;\n360. }\n361. \n362. /**\n363.  * Combines database and environment registry rows, keeping database rows authoritative.\n364.  *\n365.  * @param databaseServers - Persistent `_Server` rows.\n366.  * @param environmentServers - Virtual rows derived from `SERVERS`.\n367.  * @returns Merged rows without duplicate domains.\n368.  */\n369. function mergeRegisteredServers(\n370.     databaseServers: ReadonlyArray<ServerRecord>,\n371.     environmentServers: ReadonlyArray<ServerRecord>,\n372. ): Array<ServerRecord> {\n373.     const seenDomains = new Set(databaseServers.map((server) => server.domain));\n374.     const mergedServers = [...databaseServers];\n375. \n376.     for (const environmentServer of environmentServers) {\n377.         if (seenDomains.has(environmentServer.domain)) {\n378.             continue;\n379.         }\n380. \n381.         mergedServers.push(environmentServer);\n382.         seenDomains.add(environmentServer.domain);\n383.     }\n384. \n385.     return mergedServers;\n386. }\n387. \n388. /**\n389.  * Creates one PostgreSQL client using the lazily loaded `pg` package.\n390.  *\n391.  * @param connectionString - PostgreSQL connection string.\n392.  * @returns Connected-client constructor instance ready to call `.connect()`.\n393.  */\n394. async function createPostgresClient(connectionString: string): Promise<Client> {\n395.     const { Client: PostgresClient } = await importRuntimeModule<{ Client: PostgresClientConstructor }>('pg');\n396. \n397.     return new PostgresClient({\n398.         connectionString,\n399.         ssl: { rejectUnauthorized: false },\n400.     });\n401. }\n402. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/runDatabas