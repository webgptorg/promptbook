\"$(get_env_value POSTGRES_PORT)\"\n835.     default_postgres_port=\"${default_postgres_port:-${POSTGRES_PORT:-5432}}\"\n836.     default_postgres_database=\"$(get_env_value POSTGRES_DATABASE)\"\n837.     default_postgres_database=\"${default_postgres_database:-${POSTGRES_DATABASE:-promptbook_agents_server}}\"\n838.     default_postgres_user=\"$(get_env_value POSTGRES_USER)\"\n839.     default_postgres_user=\"${default_postgres_user:-${POSTGRES_USER:-promptbook_agents_server}}\"\n840.     default_postgres_password=\"$(get_env_value POSTGRES_PASSWORD)\"\n841.     default_postgres_password=\"${default_postgres_password:-${POSTGRES_PASSWORD:-}}\"\n842. \n843.     if [[ -n \"$default_postgres_password\" ]]; then\n844.         postgres_password_default_description=\"keep existing\"\n845.     else\n846.         GENERATED_POSTGRES_PASSWORD=\"$(openssl rand -hex 24)\"\n847.         default_postgres_password=\"$GENERATED_POSTGRES_PASSWORD\"\n848.     fi\n849. \n850.     REQUESTED_DATABASE_MODE=\"$(prompt_with_default \"Agents Server database (postgres/sqlite)\" \"$default_database_mode\")\"\n851.     REQUESTED_DATABASE_MODE=\"$(printf '%s' \"$REQUESTED_DATABASE_MODE\" | tr '[:upper:]' '[:lower:]')\"\n852. \n853.     case \"$REQUESTED_DATABASE_MODE\" in\n854.         postgres|postgresql)\n855.             REQUESTED_DATABASE_MODE=\"postgres\"\n856.             REQUESTED_POSTGRES_HOST=\"$(prompt_with_default \"PostgreSQL host\" \"$default_postgres_host\")\"\n857.             REQUESTED_POSTGRES_PORT=\"$(prompt_with_default \"PostgreSQL port\" \"$default_postgres_port\")\"\n858.             REQUESTED_POSTGRES_DATABASE=\"$(prompt_with_default \"PostgreSQL database\" \"$default_postgres_database\")\"\n859.             REQUESTED_POSTGRES_USER=\"$(prompt_with_default \"PostgreSQL user\" \"$default_postgres_user\")\"\n860.             log \"Press Enter to keep the current PostgreSQL password or use the generated strong default.\"\n861.             REQUESTED_POSTGRES_PASSWORD=\"$(\n862.                 prompt_secret_with_default \"PostgreSQL password\" \"$postgres_password_default_description\" \"$default_postgres_password\"\n863.             )\"\n864. \n865.             if [[ \"$REQUESTED_POSTGRES_PASSWORD\" != \"$GENERATED_POSTGRES_PASSWORD\" ]]; then\n866.                 GENERATED_POSTGRES_PASSWORD=\"\"\n867.             fi\n868.             ;;\n869.         sqlite|local)\n870.             REQUESTED_DATABASE_MODE=\"sqlite\"\n871.             REQUESTED_SQLITE_PATH=\"$(prompt_with_default \"SQLite database path\" \"$default_sqlite_path\")\"\n872.             GENERATED_POSTGRES_PASSWORD=\"\"\n873.             ;;\n874.         *)\n875.             fail \"Unsupported Agents Server database '$REQUESTED_DATABASE_MODE'. Use 'postgres' or 'sqlite'.\"\n876.             ;;\n877.     esac\n878. }\n879. \n880. install_and_configure_postgresql() {\n881.     local postgres_user_identifier=\"\"\n882.     local postgres_database_identifier=\"\"\n883.     local postgres_password_literal=\"\"\n884.     local postgres_role_exists=\"\"\n885.     local postgres_database_exists=\"\"\n886. \n887.     if [[ \"$REQUESTED_DATABASE_MODE\" != \"postgres\" ]]; then\n888.         return\n889.     fi\n890. \n891.     log \"Installing and configuring PostgreSQL.\"\n892.     \"${SUDO[@]}\" env DEBIAN_FRONTEND=noninteractive apt-get install -y postgresql postgresql-contrib\n893.     \"${SUDO[@]}\" systemctl enable --now postgresql\n894. \n895.     postgres_user_identifier=\"$(sql_quote_identifier \"$REQUESTED_POSTGRES_USER\")\"\n896.     postgres_database_identifier=\"$(sql_quote_identifier \"$REQUESTED_POSTGRES_DATABASE\")\"\n897.     postgres_password_literal=\"$(sql_quote_literal \"$REQUESTED_POSTGRES_PASSWORD\")\"\n898.     postgres_role_exists=\"$(\"${SUDO[@]}\" -u postgres psql postgres -tAc \"SELECT 1 FROM pg_roles WHERE rolname = $(sql_quote_literal \"$REQUESTED_POSTGRES_USER\")\" | tr -d '[:space:]')\"\n899. \n900.     if [[ \"$postgres_role_exists\" == \"1\" ]]; then\n901.         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n902.             \"ALTER ROLE $postgres_user_identifier WITH LOGIN PASSWORD $postgres_password_literal\"\n903.     else\n904.         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n905.             \"CREATE ROLE $postgres_user_identifier WITH LOGIN PASSWORD $postgres_password_literal\"\n906.     fi\n907. \n908.     postgres_database_exists=\"$(\"${SUDO[@]}\" -u postgres psql postgres -tAc \"SELECT 1 FROM pg_database WHERE datname = $(sql_quote_literal \"$REQUESTED_POSTGRES_DATABASE\")\" | tr -d '[:space:]')\"\n909. \n910.     if [[ \"$postgres_database_exists\" == \"1\" ]]; then\n911.         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n912.             \"ALTER DATABASE $postgres_database_identifier OWNER TO $postgres_user_identifier\"\n913.     else\n914.         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n915.             \"CREATE DATABASE $postgres_database_identifier OWNER $postgres_user_identifier\"\n916.     fi\n917. \n918.     \"${SUDO[@]}\" -u postgres psql \"$REQUESTED_POSTGRES_DATABASE\" -v ON_ERROR_STOP=1 -c \\\n919.         \"ALTER SCHEMA public OWNER TO $postgres_user_identifier\"\n920.     \"${SUDO[@]}\" -u postgres psql \"$REQUESTED_POSTGRES_DATABASE\" -v ON_ERROR_STOP=1 -c \\\n921.         \"GRANT ALL ON SCHEMA public TO $postgres_user_identifier\"\n922.     \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n923.         \"GRANT ALL PRIVILEGES ON DATABASE $postgres_database_identifier TO $postgres_user_identifier\"\n924. }\n925. \n926. configure_domains() {\n927.     local default_domains=\"$SERVERS\"\n928.     local existing_env_file=\"${ENV_FILE:-$INSTALL_DIR/.env}\"\n929.     local requested_domains=\"\"\n930.     local domain=\"\"\n931. \n932.     if [[ -z \"$default_domains\" && -r \"$existing_env_file\" ]]; then\n933.         default_domains=\"$(grep -E '^SERVERS=' \"$existing_env_file\" | tail -n 1 | cut -d= -f2- || true)\"\n934.     fi\n935. \n936.     requested_domains=\"$(prompt_with_default \"Primary domain (optional, comma-separated for advanced use)\" \"$default_domains\")\"\n937.     set_domains_from_csv \"$requested_domains\"\n938. \n939.     SERVERS=\"$(join_by_comma \"${DOMAINS[@]}\")\"\n940.     PUBLIC_IP_ADDRESS=\"$(resolve_public_ip_address)\"\n941. \n942.     if [[ \"${#DOMAINS[@]}\" -eq 0 ]]; then\n943.         log \"No custom domain configured. The server will be available on http://$PUBLIC_IP_ADDRESS and domains can be added later from the super admin UI.\"\n944.         return\n945.     fi\n946. \n947.     log \"Before SSL is issued, point these DNS records to this VPS:\"\n948.     for domain in \"${DOMAINS[@]}\"; do\n949.         log \"  $domain  A  $PUBLIC_IP_ADDRESS\"\n950.     done\n951.     log \"If your VPS provider gave you an IPv6 address, add matching AAAA records as well.\"\n952. \n953.     if ! prompt_yes_no \"Have the DNS records propagated and should SSL setup continue now?\" \"yes\"; then\n954.         fail \"Update DNS for $SERVERS, then run this installer again.\"\n955.     fi\n956. }\n957. \n958. configure_environment() {\n959.     local sqlite_path=\"$INSTALL_DIR/.promptbook/agents-server.sqlite\"\n960.     local default_public_url=\"\"\n961.     local public_site_url=\"\"\n962.     local first_domain=\"${DOMAINS[0]:-}\"\n963.     local table_prefix=\"\"\n964.     local postgres_connection_string=\"\"\n965. \n966.     if [[ -n \"$first_domain\" ]]; then\n967.         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-https://${first_domain}}}\"\n968.         table_prefix=\"$(build_domain_table_prefix \"$first_domain\")\"\n969.     else\n970.         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-$(resolve_default_public_url)}}\"\n971.     fi\n972. \n973.     public_site_url=\"$(prompt_with_default \"Public Agents Server URL\" \"$default_public_url\")\"\n974. \n975.     if [[ \"$REQUESTED_DATABASE_MODE\" == \"postgres\" ]]; then\n976.         postgres_connection_string=\"$(\n977.             build_postgres_connection_string \\\n978.                 \"$REQUESTED_POSTGRES_HOST\" \\\n979.                 \"$REQUESTED_POSTGRES_PORT\" \\\n980.                 \"$REQUESTED_POSTGRES_DATABASE\" \\\n981.                 \"$REQUESTED_POSTGRES_USER\" \\\n982.                 \"$REQUESTED_POSTGRES_PASSWORD\"\n983.         )\"\n984.         set_env_value PTBK_AGENTS_SERVER_DATABASE postgres\n985.         set_env_value PTBK_AGENTS_SERVER_SQLITE_PATH \"\"\n986.         set_env_value POSTGRES_HOST \"$REQUESTED_POSTGRES_HOST\"\n987.         set_env_value POSTGRES_PORT \"$REQUESTED_POSTGRES_PORT\"\n988.         set_env_value POSTGRES_DATABASE \"$REQUESTED_POSTGRES_DATABASE\"\n989.         set_env_value POSTGRES_USER \"$REQUESTED_POSTGRES_USER\"\n990.         set_env_value POSTGRES_PASSWORD \"$REQUESTED_POSTGRES_PASSWORD\"\n991.         set_env_value POSTGRES_URL \"$postgres_connection_string\"\n992.         set_env_value DATABASE_URL \"$postgres_connection_string\"\n993.         set_env_value NEXT_PUBLIC_SUPABASE_URL \"\"\n994.         set_env_value NEXT_PUBLIC_SUPABASE_ANON_KEY \"\"\n995.         set_env_value SUPABASE_SERVICE_ROLE_KEY \"\"\n996.         set_env_value SUPABASE_AUTO_MIGRATE true\n997.     else\n998.         set_env_value PTBK_AGENTS_SERVER_DATABASE sqlite\n999.         set_env_value PTBK_AGENTS_SERVER_SQLITE_PATH \"${REQUESTED_SQLITE_PATH:-$sqlite_path}\"\n1000.         set_env_value POSTGRES_HOST \"\"\n1001.         set_env_value POSTGRES_PORT \"\"\n1002.         set_env_value POSTGRES_DATABASE \"\"\n1003.         set_env_value POSTGRES_USER \"\"\n1004.         set_env_value POSTGRES_PASSWORD \"\"\n1005.         set_env_value POSTGRES_URL \"\"\n1006.         set_env_value DATABASE_URL \"\"\n1007.         set_env_value NEXT_PUBLIC_SUPABASE_URL \"\"\n1008.         set_env_value NEXT_PUBLIC_SUPABASE_ANON_KEY \"\"\n1009.         set_env_value SUPABASE_SERVICE_ROLE_KEY \"\"\n1010.         set_env_value SUPABASE_AUTO_MIGRATE false\n1011.     fi\n1012. \n1013.     set_env_value NEXT_PUBLIC_SITE_URL \"$public_site_url\"\n1014.     set_env_value SERVERS \"$SERVERS\"\n1015.     set_env_value SUPABASE_TABLE_PREFIX \"$table_prefix\"\n1016.     set_env_value PTBK_AGENT \"$PTBK_AGENT\"\n1017.     set_env_value PTBK_MODEL \"$PTBK_MODEL\"\n1018.     set_env_value PTBK_THINKING_LEVEL \"$PTBK_THINKING_LEVEL\"\n1019.     set_env_value PORT \"$PORT\"\n1020.     set_env_value NODE_ENV production\n1021.     set_env_value PTBK_HOSTNAME 127.0.0.1\n1022.     set_env_value PTBK_PUBLIC_IP_ADDRESS \"$PUBLIC_IP_ADDRESS\"\n1023.     set_env_value PTBK_INSTALL_DIR \"$INSTALL_DIR\"\n1024.     set_env_value PTBK_REPOSITORY_DIR \"$PROMPTBOOK_REPOSITORY_DIR\"\n1025.     set_env_value PTBK_VPS_INSTALL_SCRIPT \"$PROMPTBOOK_REPOSITORY_DIR/other/vps/install.sh\"\n1026.     set_env_value PTBK_AGENTS_SERVER_ENV_FILE \"$ENV_FILE\"\n1027.     set_env_value PTBK_PM2_APP_NAME \"$APP_NAME\"\n1028.     set_env_value PTBK_NGINX_SITE_NAME \"$NGINX_SITE_NAME\"\n1029.     set_env_value LETS_ENCRYPT_EMAIL \"$LETS_ENCRYPT_EMAIL\"\n1030.     set_env_value OPENAI_API_KEY \"$REQUESTED_OPENAI_API_KEY\"\n1031. \n1032.     if [[ -n \"$REQUESTED_ADMIN_PASSWORD\" ]]; then\n1033.         set_env_value ADMIN_PASSWORD \"$REQUESTED_ADMIN_PASSWORD\"\n1034.     elif ! has_non_empty_env_value ADMIN_PASSWORD; then\n1035.         GENERATED_ADMIN_PASSWORD=\"$(openssl rand -hex 24)\"\n1036.         set_env_value ADMIN_PASSWORD \"$GENERATED_ADMIN_PASSWORD\"\n1037.     fi\n1038. \n1039.     if [[ -n \"${COPILOT_GITHUB_TOKEN:-}\" ]]; then\n1040.         set_env_value COPILOT_GITHUB_TOKEN \"$COPILOT_GITHUB_TOKEN\"\n1041.     elif [[ -n \"${GH_TOKEN:-}\" ]]; then\n1042.         set_env_value GH_TOKEN \"$GH_TOKEN\"\n1043.     fi\n1044. }\n1045. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/other/vps/install.sh b/C:/Users/me/work/ai/promptbook/other/vps/install.sh\nindex 0000000..0000000 100644\n--- a/C:/Users/me/work/ai/promptbook/other/vps/install.sh\n+++ b/C:/Users/me/work/ai/promptbook/other/vps/install.sh\n@@ -800,246 +800,246 @@\n     fi\n \n     if [[ -n \"$default_admin_password\" ]]; then\n         admin_password_default_description=\"keep existing\"\n     fi\n \n     log \"Press Enter to leave the OpenAI API key empty or keep the current value.\"\n     REQUESTED_OPENAI_API_KEY=\"$(\n         prompt_secret_with_default \"OpenAI API key (optional)\" \"$openai_api_key_default_description\" \"$default_openai_api_key\"\n     )\"\n \n     log \"Press Enter to auto-generate the admin password or keep the current value.\"\n     REQUESTED_ADMIN_PASSWORD=\"$(\n         prompt_secret_with_default \"Admin password\" \"$admin_password_default_description\" \"$default_admin_password\"\n     )\"\n }\n \n prompt_database_configuration() {\n     local sqlite_path_default=\"$INSTALL_DIR/.promptbook/agents-server.sqlite\"\n     local default_database_mode=\"\"\n     local default_sqlite_path=\"\"\n     local default_postgres_host=\"\"\n     local default_postgres_port=\"\"\n     local default_postgres_database=\"\"\n     local default_postgres_user=\"\"\n     local default_postgres_password=\"\"\n     local postgres_password_default_description=\"auto-generate\"\n \n     default_database_mode=\"$(get_env_value PTBK_AGENTS_SERVER_DATABASE)\"\n     default_database_mode=\"${default_database_mode:-${PTBK_AGENTS_SERVER_DATABASE:-postgres}}\"\n     default_sqlite_path=\"$(get_env_value PTBK_AGENTS_SERVER_SQLITE_PATH)\"\n     default_sqlite_path=\"${default_sqlite_path:-$sqlite_path_default}\"\n     default_postgres_host=\"$(get_env_value POSTGRES_HOST)\"\n     default_postgres_host=\"${default_postgres_host:-${POSTGRES_HOST:-127.0.0.1}}\"\n     default_postgres_port=\"$(get_env_value POSTGRES_PORT)\"\n     default_postgres_port=\"${default_postgres_port:-${POSTGRES_PORT:-5432}}\"\n     default_postgres_database=\"$(get_env_value POSTGRES_DATABASE)\"\n     default_postgres_database=\"${default_postgres_database:-${POSTGRES_DATABASE:-promptbook_agents_server}}\"\n     default_postgres_user=\"$(get_env_value POSTGRES_USER)\"\n     default_postgres_user=\"${default_postgres_user:-${POSTGRES_USER:-promptbook_agents_server}}\"\n     default_postgres_password=\"$(get_env_value POSTGRES_PASSWORD)\"\n     default_postgres_password=\"${default_postgres_password:-${POSTGRES_PASSWORD:-}}\"\n \n     if [[ -n \"$default_postgres_password\" ]]; then\n         postgres_password_default_description=\"keep existing\"\n     else\n         GENERATED_POSTGRES_PASSWORD=\"$(openssl rand -hex 24)\"\n         default_postgres_password=\"$GENERATED_POSTGRES_PASSWORD\"\n     fi\n \n     REQUESTED_DATABASE_MODE=\"$(prompt_with_default \"Agents Server database (postgres/sqlite)\" \"$default_database_mode\")\"\n     REQUESTED_DATABASE_MODE=\"$(printf '%s' \"$REQUESTED_DATABASE_MODE\" | tr '[:upper:]' '[:lower:]')\"\n \n     case \"$REQUESTED_DATABASE_MODE\" in\n         postgres|postgresql)\n             REQUESTED_DATABASE_MODE=\"postgres\"\n             REQUESTED_POSTGRES_HOST=\"$(prompt_with_default \"PostgreSQL host\" \"$default_postgres_host\")\"\n             REQUESTED_POSTGRES_PORT=\"$(prompt_with_default \"PostgreSQL port\" \"$default_postgres_port\")\"\n             REQUESTED_POSTGRES_DATABASE=\"$(prompt_with_default \"PostgreSQL database\" \"$default_postgres_database\")\"\n             REQUESTED_POSTGRES_USER=\"$(prompt_with_default \"PostgreSQL user\" \"$default_postgres_user\")\"\n             log \"Press Enter to keep the current PostgreSQL password or use the generated strong default.\"\n             REQUESTED_POSTGRES_PASSWORD=\"$(\n                 prompt_secret_with_default \"PostgreSQL password\" \"$postgres_password_default_description\" \"$default_postgres_password\"\n             )\"\n \n             if [[ \"$REQUESTED_POSTGRES_PASSWORD\" != \"$GENERATED_POSTGRES_PASSWORD\" ]]; then\n                 GENERATED_POSTGRES_PASSWORD=\"\"\n             fi\n             ;;\n         sqlite|local)\n             REQUESTED_DATABASE_MODE=\"sqlite\"\n             REQUESTED_SQLITE_PATH=\"$(prompt_with_default \"SQLite database path\" \"$default_sqlite_path\")\"\n             GENERATED_POSTGRES_PASSWORD=\"\"\n             ;;\n         *)\n             fail \"Unsupported Agents Server database '$REQUESTED_DATABASE_MODE'. Use 'postgres' or 'sqlite'.\"\n             ;;\n     esac\n }\n \n install_and_configure_postgresql() {\n     local postgres_user_identifier=\"\"\n     local postgres_database_identifier=\"\"\n     local postgres_password_literal=\"\"\n     local postgres_role_exists=\"\"\n     local postgres_database_exists=\"\"\n \n     if [[ \"$REQUESTED_DATABASE_MODE\" != \"postgres\" ]]; then\n         return\n     fi\n \n     log \"Installing and configuring PostgreSQL.\"\n     \"${SUDO[@]}\" env DEBIAN_FRONTEND=noninteractive apt-get install -y postgresql postgresql-contrib\n     \"${SUDO[@]}\" systemctl enable --now postgresql\n \n     postgres_user_identifier=\"$(sql_quote_identifier \"$REQUESTED_POSTGRES_USER\")\"\n     postgres_database_identifier=\"$(sql_quote_identifier \"$REQUESTED_POSTGRES_DATABASE\")\"\n     postgres_password_literal=\"$(sql_quote_literal \"$REQUESTED_POSTGRES_PASSWORD\")\"\n     postgres_role_exists=\"$(\"${SUDO[@]}\" -u postgres psql postgres -tAc \"SELECT 1 FROM pg_roles WHERE rolname = $(sql_quote_literal \"$REQUESTED_POSTGRES_USER\")\" | tr -d '[:space:]')\"\n \n     if [[ \"$postgres_role_exists\" == \"1\" ]]; then\n         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n             \"ALTER ROLE $postgres_user_identifier WITH LOGIN PASSWORD $postgres_password_literal\"\n     else\n         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n             \"CREATE ROLE $postgres_user_identifier WITH LOGIN PASSWORD $postgres_password_literal\"\n     fi\n \n     postgres_database_exists=\"$(\"${SUDO[@]}\" -u postgres psql postgres -tAc \"SELECT 1 FROM pg_database WHERE datname = $(sql_quote_literal \"$REQUESTED_POSTGRES_DATABASE\")\" | tr -d '[:space:]')\"\n \n     if [[ \"$postgres_database_exists\" == \"1\" ]]; then\n         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n             \"ALTER DATABASE $postgres_database_identifier OWNER TO $postgres_user_identifier\"\n     else\n         \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n             \"CREATE DATABASE $postgres_database_identifier OWNER $postgres_user_identifier\"\n     fi\n \n     \"${SUDO[@]}\" -u postgres psql \"$REQUESTED_POSTGRES_DATABASE\" -v ON_ERROR_STOP=1 -c \\\n         \"ALTER SCHEMA public OWNER TO $postgres_user_identifier\"\n     \"${SUDO[@]}\" -u postgres psql \"$REQUESTED_POSTGRES_DATABASE\" -v ON_ERROR_STOP=1 -c \\\n         \"GRANT ALL ON SCHEMA public TO $postgres_user_identifier\"\n     \"${SUDO[@]}\" -u postgres psql postgres -v ON_ERROR_STOP=1 -c \\\n         \"GRANT ALL PRIVILEGES ON DATABASE $postgres_database_identifier TO $postgres_user_identifier\"\n }\n \n configure_domains() {\n     local default_domains=\"$SERVERS\"\n     local existing_env_file=\"${ENV_FILE:-$INSTALL_DIR/.env}\"\n     local requested_domains=\"\"\n     local domain=\"\"\n \n     if [[ -z \"$default_domains\" && -r \"$existing_env_file\" ]]; then\n         default_domains=\"$(grep -E '^SERVERS=' \"$existing_env_file\" | tail -n 1 | cut -d= -f2- || true)\"\n     fi\n \n     requested_domains=\"$(prompt_with_default \"Primary domain (optional, comma-separated for advanced use)\" \"$default_domains\")\"\n     set_domains_from_csv \"$requested_domains\"\n \n     SERVERS=\"$(join_by_comma \"${DOMAINS[@]}\")\"\n     PUBLIC_IP_ADDRESS=\"$(resolve_public_ip_address)\"\n \n     if [[ \"${#DOMAINS[@]}\" -eq 0 ]]; then\n         log \"No custom domain configured. The server will be available on http://$PUBLIC_IP_ADDRESS and domains can be added later from the super admin UI.\"\n         return\n     fi\n \n     log \"Before SSL is issued, point these DNS records to this VPS:\"\n     for domain in \"${DOMAINS[@]}\"; do\n         log \"  $domain  A  $PUBLIC_IP_ADDRESS\"\n     done\n     log \"If your VPS provider gave you an IPv6 address, add matching AAAA records as well.\"\n \n     if ! prompt_yes_no \"Have the DNS records propagated and should SSL setup continue now?\" \"yes\"; then\n         fail \"Update DNS for $SERVERS, then run this installer again.\"\n     fi\n }\n \n configure_environment() {\n     local sqlite_path=\"$INSTALL_DIR/.promptbook/agents-server.sqlite\"\n     local default_public_url=\"\"\n     local public_site_url=\"\"\n     local first_domain=\"${DOMAINS[0]:-}\"\n     local table_prefix=\"\"\n     local postgres_connection_string=\"\"\n \n     if [[ -n \"$first_domain\" ]]; then\n         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-https://${first_domain}}}\"\n         table_prefix=\"$(build_domain_table_prefix \"$first_domain\")\"\n     else\n         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-$(resolve_default_public_url)}}\"\n     fi\n \n     public_site_url=\"$(prompt_with_default \"Public Agents Server URL\" \"$default_public_url\")\"\n \n     if [[ \"$REQUESTED_DATABASE_MODE\" == \"postgres\" ]]; then\n         postgres_connection_string=\"$(\n             build_postgres_connection_string \\\n                 \"$REQUESTED_POSTGRES_HOST\" \\\n                 \"$REQUESTED_POSTGRES_PORT\" \\\n                 \"$REQUESTED_POSTGRES_DATABASE\" \\\n                 \"$REQUESTED_POSTGRES_USER\" \\\n                 \"$REQUESTED_POSTGRES_PASSWORD\"\n         )\"\n         set_env_value PTBK_AGENTS_SERVER_DATABASE postgres\n         set_env_value PTBK_AGENTS_SERVER_SQLITE_PATH \"\"\n         set_env_value POSTGRES_HOST \"$REQUESTED_POSTGRES_HOST\"\n         set_env_value POSTGRES_PORT \"$REQUESTED_POSTGRES_PORT\"\n         set_env_value POSTGRES_DATABASE \"$REQ