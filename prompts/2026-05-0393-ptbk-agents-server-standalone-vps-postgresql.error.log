   this.filters.push({ column, operator: 'is', value });\n326.         return this;\n327.     }\n328. \n329.     /**\n330.      * Adds negative filter for supported operators.\n331.      */\n332.     public not(column: string, operator: string, value: unknown): this {\n333.         if (operator === 'is') {\n334.             this.filters.push({ column, operator: 'not-is', value });\n335.         } else if (operator === 'eq') {\n336.             this.filters.push({ column, operator: 'neq', value });\n337.         }\n338.         return this;\n339.     }\n340. \n341.     /**\n342.      * Adds `IN` filter.\n343.      */\n344.     public in(column: string, value: ReadonlyArray<unknown>): this {\n345.         this.filters.push({ column, operator: 'in', value });\n346.         return this;\n347.     }\n348. \n349.     /**\n350.      * Adds less-than filter.\n351.      */\n352.     public lt(column: string, value: unknown): this {\n353.         this.filters.push({ column, operator: 'lt', value });\n354.         return this;\n355.     }\n356. \n357.     /**\n358.      * Adds less-than-or-equal filter.\n359.      */\n360.     public lte(column: string, value: unknown): this {\n361.         this.filters.push({ column, operator: 'lte', value });\n362.         return this;\n363.     }\n364. \n365.     /**\n366.      * Adds greater-than filter.\n367.      */\n368.     public gt(column: string, value: unknown): this {\n369.         this.filters.push({ column, operator: 'gt', value });\n370.         return this;\n371.     }\n372. \n373.     /**\n374.      * Adds greater-than-or-equal filter.\n375.      */\n376.     public gte(column: string, value: unknown): this {\n377.         this.filters.push({ column, operator: 'gte', value });\n378.         return this;\n379.     }\n380. \n381.     /**\n382.      * Adds SQL LIKE filter.\n383.      */\n384.     public like(column: string, value: string): this {\n385.         this.filters.push({ column, operator: 'like', value });\n386.         return this;\n387.     }\n388. \n389.     /**\n390.      * Adds case-insensitive LIKE filter.\n391.      */\n392.     public ilike(column: string, value: string): this {\n393.         this.filters.push({ column, operator: 'ilike', value });\n394.         return this;\n395.     }\n396. \n397.     /**\n398.      * Adds an OR filter in the PostgREST format used by Supabase.\n399.      */\n400.     public or(filter: string): this {\n401.         this.orFilters.push(filter);\n402.         return this;\n403.     }\n404. \n405.     /**\n406.      * Adds ordering.\n407.      */\n408.     public order(column: string, options: { ascending?: boolean; nullsFirst?: boolean } = {}): this {\n409.         this.orders.push({\n410.             column,\n411.             ascending: options.ascending !== false,\n412.             nullsFirst: options.nullsFirst,\n413.         });\n414.         return this;\n415.     }\n416. \n417.     /**\n418.      * Adds a limit.\n419.      */\n420.     public limit(count: number): this {\n421.         this.limitCount = count;\n422.         return this;\n423.     }\n424. \n425.     /**\n426.      * Adds inclusive range pagination.\n427.      */\n428.     public range(from: number, to: number): this {\n429.         this.offsetCount = from;\n430.         this.limitCount = Math.max(0, to - from + 1);\n431.         return this;\n432.     }\n433. \n434.     /**\n435.      * Marks the query as requiring exactly one row.\n436.      */\n437.     public single(): Promise<LocalSqliteQueryResult> {\n438.         this.singleMode = 'single';\n439.         return this.execute();\n440.     }\n441. \n442.     /**\n443.      * Marks the query as requiring at most one row.\n444.      */\n445.     public maybeSingle(): Promise<LocalSqliteQueryResult> {\n446.         this.singleMode = 'maybeSingle';\n447.         return this.execute();\n448.     }\n449. \n450.     /**\n451.      * Accepts an abort signal for API compatibility.\n452.      */\n453.     public abortSignal(si