en migration should be skipped.\n161.  */\n162. export async function resolveDatabaseMigrationRuntimeConfiguration(\n163.     logger: DatabaseMigrationLogger = console,\n164. ): Promise<DatabaseMigrationRuntimeConfiguration | null> {\n165.     const connectionString = resolveDatabaseMigrationConnectionStringFromEnvironment();\n166.     if (!connectionString) {\n167.         throw new DatabaseError(\n168.             spaceTrim(`\n169.                 ${DATABASE_CONNECTION_ENV_NAMES.join(' or ')} is not defined.\n170.             `),\n171.         );\n172.     }\n173. \n174.     const client = await createPostgresClient(connectionString);\n175. \n176.     try {\n177.         await client.connect();\n178. \n179.         const registeredServers = mergeRegisteredServers(\n180.             await listRegisteredServersFromDatabase(client),\n181.             listEnvironmentRegisteredServers(),\n182.         );\n183.         const hasExplicitDefaultPrefix = process.env[SUPABASE_TABLE_PREFIX_ENV_NAME] !== undefined;\n184.         const configuredPrefixes = uniquePrefixes([\n185.             ...(hasExplicitDefaultPrefix\n186.                 ? [process.env[SUPABASE_TABLE_PREFIX_ENV_NAME] || '']\n187.                 : registeredServers.length === 0\n188.                 ? ['']\n189.                 : []),\n190.             ...registeredServers.map((server) => server.tablePrefix),\n191.         ]);\n192. \n193.         if (configuredPrefixes.length === 0) {\n194.             logger.warn(`⚠️ No migration prefixes resolved from \\`${SUPABASE_TABLE_PREFIX_ENV_NAME}\\` or \\`_Server\\`.`);\n195.             return null;\n196.         }\n197. \n198.         logger.info(`🗂️ Loaded ${registeredServers.length} registered servers from \\`_Server\\`.`);\n199. \n200.         return {\n201.             prefixes: configuredPrefixes,\n202.             registeredServers,\n203.             connectionString,\n204.         };\n205.     } finally {\n206.         await client.end();\n207.     }\n20