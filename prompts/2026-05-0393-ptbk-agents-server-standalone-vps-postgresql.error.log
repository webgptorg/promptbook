lientPool) {\n52.         clientPool = new Pool({\n53.             connectionString: resolvePostgresConnectionString(),\n54.             ssl: { rejectUnauthorized: false },\n55.         });\n56.     }\n57. \n58.     const executeTemplate = async <TRow = Array<Record<string, unknown>>>(\n59.         templateStrings: TemplateStringsArray,\n60.         ...templateValues: ReadonlyArray<unknown>\n61.     ): Promise<TRow> => {\n62.         const textChunks: Array<string> = [];\n63.         for (let index = 0; index < templateStrings.length; index++) {\n64.             textChunks.push(templateStrings[index]!);\n65.             if (index < templateValues.length) {\n66.                 textChunks.push(`$${index + 1}`);\n67.             }\n68.         }\n69. \n70.         const text = textChunks.join('');\n71.         const result = await clientPool!.query(text, [...templateValues]);\n72.         return result.rows as TRow;\n73.     };\n74. \n75.     const executeRaw: ClientSqlRaw = async <TRow = Array<Record<string, unknown>>>(\n76.         text: string,\n77.         values: ReadonlyArray<unknown> = [],\n78.     ): Promise<TRow> => {\n79.         const result = await clientPool!.query(text, [...values]);\n80.         return result.rows as TRow;\n81.     };\n82. \n83.     return Object.assign(executeTemplate, { raw: executeRaw });\n84. }\n85. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/$provideClientSql.ts b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/$provideClientSql.ts\nindex 0000000..0000000 100644\n--- a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/$provideClientSql.ts\n+++ b/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/$provideClientSql.ts\n@@ -1,85 +1,85 @@\n import { $isRunningInNode } from '@promptbook-local/utils';\n import { Pool } from 'pg';\n import { resolvePostgresConnectionString } from './resolvePostgresConnectionString';\n \n /**\n  * SQL tagged-template executor used by server routes and utilities.\n  *\n  * @private internal utility of Agents Server database layer\n  */\n export type ClientSql = <TRow = Record<string, unknown>>(\n     templateStrings: TemplateStringsArray,\n     ...templateValues: ReadonlyArray<unknown>\n ) => Promise<TRow>;\n \n /**\n  * Raw SQL executor used when dynamic SQL identifiers (such as table names) are needed.\n  *\n  * @private internal utility of Agents Server database layer\n  */\n export type ClientSqlRaw = <TRow = Array<Record<string, unknown>>>(\n     text: string,\n     values?: ReadonlyArray<unknown>,\n ) => Promise<TRow>;\n \n /**\n  * SQL executor with both tagged-template and raw-query variants.\n  *\n  * @private internal utility of Agents Server database layer\n  */\n export type ClientSqlExecutor = ClientSql & {\n     readonly raw: ClientSqlRaw;\n };\n \n /**\n  * Shared PostgreSQL pool reused across all requests in the server process.\n  *\n  * @private internal singleton of Agents Server database layer\n  */\n let clientPool: Pool | undefined;\n \n /**\n  * Provides SQL tagged-template client for server-side PostgreSQL access.\n  *\n  * @private exported from Agents Server database utils\n  */\n export async function $provideClientSql(): Promise<ClientSqlExecutor> {\n     if (!$isRunningInNode()) {\n         throw new Error('Function `$provideClientSql` can only be used in Node.js runtime.');\n     }\n \n     if (!clientPool) {\n         clientPool = new Pool({\n             connectionString: resolvePostgresConnectionString(),\n             ssl: { rejectUnauthorized: false },\n         });\n     }\n \n     const executeTemplate = async <TRow = Array<Record<string, unknown>>>(\n         templateStrings: TemplateStringsArray,\n         ...templateValues: ReadonlyArray<unknown>\n     ): Promise<TRow> => {\n         const textChunks: Array<string> = [];\n         for (let index = 0; index < templateStrings.length; index++) {\n             textChunks.push(templateStrings[index]!);\n             if (index < templateValues.length) {\n                 textChunks.push(`$${index + 1}`);\n             }\n         }\n \n         const text = textChunks.join('');\n         const result = await clientPool!.query(text, [...templateValues]);\n         return result.rows as TRow;\n     };\n \n     const executeRaw: ClientSqlRaw = async <TRow = Array<Record<string, unknown>>>(\n         text: string,\n         values: ReadonlyArray<unknown> = [],\n     ): Promise<TRow> => {\n         const result = await clientPool!.query(text, [...values]);\n         return result.rows as TRow;\n     };\n \n     return Object.assign(executeTemplate, { raw: executeRaw });\n }\n \n"},"toolTelemetry":{"properties":{"command":"view","options":"{\"truncateBasedOn\":\"tokenCount\",\"truncateStyle\":\"middle\"}","inputs":"[\"path\",\"command\"]","resolvedPathAgainstCwd":"false","fileExtension":"[\".ts\"]","viewType":"file"},"metrics":{"resultLength":3061,"resultForLlmLength":3061,"responseTokenLimit":68000},"restrictedProperties":{}}},"id":"e995ed51-51a4-4867-8569-88a82f722d93","timestamp":"2026-05-29T10:02:51.111Z","parentId":"6f8e48af-2077-47ca-8c56-162aa418d137"}
