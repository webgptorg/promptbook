{"type":"tool.execution_complete","data":{"toolCallId":"call_hoVLMTrNenQYZ1HHnXLvbdhg","model":"gpt-5.4","interactionId":"0a603915-c65a-4110-b10e-3f0d506120f6","turnId":"70","success":true,"result":{"content":"1. import { afterEach, beforeEach, describe, expect, it, jest } from '@jest/globals';\n2. import type { RunDatabaseMigrationsResult } from './runDatabaseMigrations';\n3. \n4. const mockResolveDatabaseMigrationConnectionStringFromEnvironment = jest.fn() as jest.MockedFunction<\n5.     () => string | null\n6. >;\n7. const mockRunDatabaseMigrations = jest.fn() as jest.MockedFunction<\n8.     (...args: Array<unknown>) => Promise<RunDatabaseMigrationsResult>\n9. >;\n10. \n11. jest.mock('./runDatabaseMigrations', () => ({\n12.     DATABASE_MIGRATION_APPLIED_BY: {\n13.         AUTOMATIC: 'AUTOMATIC',\n14.         MANUAL: 'MANUAL',\n15.     },\n16.     resolveDatabaseMigrationConnectionStringFromEnvironment: mockResolveDatabaseMigrationConnectionStringFromEnvironment,\n17.     runDatabaseMigrations: mockRunDatabaseMigrations,\n18. }));\n19. \n20. const SUCCESSFUL_MIGRATION_RESULT = {\n21.     processedPrefixes: ['server_Test_'],\n22.     totalMigrationFiles: 1,\n23.     perPrefix: [{ prefix: 'server_Test_', appliedCount: 0 }],\n24.     isSkippedDueToActiveMigrationLock: false,\n25. };\n26. \n27. const ORIGINAL_NODE_ENV = process.env.NODE_ENV;\n28. const ORIGINAL_JEST_WORKER_ID = process.env.JEST_WORKER_ID;\n29. const ORIGINAL_NEXT_PHASE = process.env.NEXT_PHASE;\n30. const ORIGINAL_SUPABASE_AUTO_MIGRATE = process.env.SUPABASE_AUTO_MIGRATE;\n31. \n32. describe('ensureAutomaticDatabaseMigrationsForPrefix', () => {\n33.     beforeEach(() => {\n34.         jest.resetModules();\n35.         jest.clearAllMocks();\n36. \n37.         setEnvironmentVariable('NODE_ENV', 'development');\n38.         delete process.env.JEST_WORKER_ID;\n39.         delete process.env.NEXT_PHASE;\n40.         delete process.env.SUPABASE_AUTO_MIGRATE;\n41. \n42.         mockResolveDatabaseMigrationConnectionStringFromEnvironment.mockReturnValue('postgres://example.test/db');\n43.     });\n44. \n45.     afterEach(() => {\n46.         jest.restoreAllMocks();\n47.         restoreEnvironmentVariable('NODE_ENV', ORIGINAL_NODE_ENV);\n48.         restoreEnvironmentVariable('JEST_WORKER_ID', ORIGINAL_JEST_WORKER_ID);\n49.         restoreEnvironmentVariable('NEXT_PHASE', ORIGINAL_NEXT_PHASE);\n50.         restoreEnvironmentVariable('SUPABASE_AUTO_MIGRATE', ORIGINAL_SUPABASE_AUTO_MIGRATE);\n51.     });\n52. \n53.     it('shares one in-flight automatic migration attempt per prefix', async () => {\n54.         let resolveMigrationAttempt: ((value: typeof SUCCESSFUL_MIGRATION_RESULT) => void) | undefined;\n55. \n56.         mockRunDatabaseMigrations.mockReturnValueOnce(\n57.             new Promise<typeof SUCCESSFUL_MIGRATION_RESULT>((resolve) => {\n58.                 resolveMigrationAttempt = resolve;\n59.             }),\n60.         );\n61. \n62.         const { ensureAutomaticDatabaseMigrationsForPrefix } = await import('./ensureAutomaticDatabaseMigrations');\n63. \n64.         const firstAttemptPromise = ensureAutomaticDatabaseMigrationsForPrefix('server_Test_');\n65.         const secondAttemptPromise = ensureAutomaticDatabaseMigrationsForPrefix('server_Test_');\n66. \n67.         expect(mockRunDatabaseMigrations).toHaveBeenCalledTimes(1);\n68.         expect(mockRunDatabaseMigrations).toHaveBeenCalledWith(\n69.             expect.objectContaining({\n70.                 prefixes: ['server_Test_'],\n71.                 appliedBy: 'AUTOMATIC',\n72.                 executionLockMode: 'skip',\n73.             }),\n74.         );\n75. \n76.         resolveMigrationAttempt!(SUCCESSFUL_MIGRATION_RESULT);\n77. \n78.         await expect(Promise.all([firstAttemptPromise, secondAttemptPromise])).resolves.toEqual([undefined, undefined]);\n79.     });\n80. \n81.     it('retries after a failed automatic migration attempt', async () => {\n82.         mockRunDatabaseMigrations\n83.             .mockRejectedValueOnce(new Error('canceling statement due to statement timeout'))\n84.             .mockResolvedValueOnce(SUCCESSFUL_MIGRATION_RESULT);\n85. \n86.         const { ensureAutomaticDatabaseMigrationsForPrefix } = await import('./ensureAutomaticDatabaseMigrations');\n87. \n88.         await expect(ensureAutomaticDatabaseMigrationsForPrefix('server_Test_')).rejects.toThrow(\n89.             'canceling statement due to statement timeout',\n90.         );\n91.         await expect(ensureAutomaticDatabaseMigrationsForPrefix('server_Test_')).resolves.toBeUndefined();\n92. \n93.         expect(mockRunDatabaseMigrations).toHaveBeenCalledTimes(2);\n94.     });\n95. \n96.     it('retries after deferring to another runtime instance that already holds the migration lock', async () => {\n97.         mockRunDatabaseMigrations\n98.             .mockResolvedValueOnce({\n99.                 processedPrefixes: [],\n100.                 totalMigrationFiles: 1,\n101.                 perPrefix: [],\n102.                 isSkippedDueToActiveMigrationLock: true,\n103.             })\n104.             .mockResolvedValueOnce(SUCCESSFUL_MIGRATION_RESULT);\n105. \n106.         const consoleInfoSpy = jest.spyOn(console, 'info').mockImplementation(() => undefined);\n107.         const { ensureAutomaticDatabaseMigrationsForPrefix } = await import('./ensureAutomaticDatabaseMigrations');\n108. \n109.         await expect(ensureAutomaticDatabaseMigrationsForPrefix('server_Test_')).resolves.toBeUndefined();\n110.         await expect(ensureAutomaticDatabaseMigrationsForPrefix('server_Test_')).resolves.toBeUndefined();\n111. \n112.         expect(mockRunDatabaseMigrations).toHaveBeenCalledTimes(2);\n113.         expect(consoleInfoSpy).toHaveBeenCalledWith(\n114.             expect.stringContaining('already checking database migrations for prefix \"server_Test_\"'),\n115.         );\n116.     });\n117. });\n118. \n119. /**\n120.  * Restores one environment variable after tes