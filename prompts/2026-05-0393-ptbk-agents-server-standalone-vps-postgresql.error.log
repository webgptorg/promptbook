ance.\n41.  * @returns Promise that resolves after automatic migrations finish or are skipped.\n42.  * @private internal startup helper for Agents Server runtime\n43.  */\n44. export async function ensureAutomaticDatabaseMigrationsForPrefix(prefix: string): Promise<void> {\n45.     const normalizedPrefix = prefix || '';\n46.     if (!automaticDatabaseMigrationPromiseByPrefix.has(normalizedPrefix)) {\n47.         automaticDatabaseMigrationPromiseByPrefix.set(normalizedPrefix, createAutomaticDatabaseMigrationPromise(normalizedPrefix));\n48.     }\n49. \n50.     return automaticDatabaseMigrationPromiseByPrefix.get(normalizedPrefix)!;\n51. }\n52. \n53. /**\n54.  * Creates one shared automatic-migration promise and clears it again when the attempt should be retried later.\n55.  *\n56.  * A failed startup migration must not poison the process forever; otherwise every later instrumentation load would\n57.  * keep reusing the same rejected promise until redeploy.\n58.  */\n59. function createAutomaticDatabaseMigrationPromise(prefix: string): Promise<void> {\n60.     return runAutomaticDatabaseMigrationsForPrefix(prefix)\n61.         .then((isMigrationCheckComplete) => {\n62.             if (!isMigrationCheckComplete) {\n63.                 automaticDatabaseMigrationPromiseByPrefix.delete(prefix);\n64.             }\n65.         })\n66.         .catch((error) => {\n67.             automaticDatabaseMigrationPromiseByPrefix.delete(prefix);\n68.             throw error;\n69.         });\n70. }\n71. \n72. /**\n73.  * Executes automatic migration flow using the same shared migration runner as CLI command.\n74.  */\n75. async function runAutomaticDatabaseMigrationsForPrefix(prefix: string): Promise<boolean> {\n76.     if (shouldSkipAutomaticDatabaseMigrations()) {\n77.         return true;\n78.     }\n79. \n80.     const connectionString = resolveDatabaseMigrationConnectionStringFromEnvironment();\n81.     if (!connectionString) {\n82.         console.warn('⚠️ POSTGRES_URL or DATABASE_URL is not defined. Skipping automatic migrations.');\n83.         return true;\n84.     }\n85. \n86.     console.info(`🚀 Checking database migrations automatically for prefix \"${prefix}\"`);\n87.     const migrationResult = await runDatabaseMigrations({\n88.         prefixes: [prefix],\n89.         connectionString,\n90.         appliedBy: DATABASE_MIGRATION_APPLIED_BY.AUTOMATIC,\n91.         logger: console,\n92.         logSqlStatements: false,\n93.         executionLockMode: 'skip',\n94.     });\n95. \n96.     if (migrationResult.isSkippedDueToActiveMigrationLock) {\n97.         console.info(\n98.             `⏭️ Another runtime instance is already checking database migrations for prefix \"${prefix}\". Continuing without waiting.`,\n99.         );\n100.         return false;\n101.     }\n102. \n103.     console.info(`✅ Automatic database migration check finished for prefix \"${prefix}\"`);\n104.     return true;\n105. }\n106. \n107. /**\n108.  * Determines whether automatic migrations should be skipped in current runtime.\n109.  *\n110.  * @returns `true` when automatic migrations should not run.\n111.  */\n112. function shouldSkipAutomaticDatabaseMigrations(): boolean {\n113.     if (process.env.NODE_ENV === 'test' || process.env.JEST_WORKER_ID !== undefined) {\n114.         return true;\n115.     }\n116. \n117.     if (process.env.NEXT_PHASE === 'phase-production-build') {\n118.         return true;\n119.     }\n120. \n121.     if (process.argv.join(' ').toLowerCase().includes('next build')) {\n122.         return true;\n123.     }\n124. \n125.     const rawValue = process.env[SUPABASE_AUTO_MIGRATE_ENV_NAME]?.trim().toLowerCase();\n126.     if (!rawValue) {\n127.         return false;\n128.     }\n129. \n130.     return ['0', 'false', 'no'].includes(rawValue);\n131. }\n132. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/apps/agents-server/src/database/ensureAutomaticDatabaseMigrations.ts b/C:/Users/me/work/ai/promptbook/apps/agents-se