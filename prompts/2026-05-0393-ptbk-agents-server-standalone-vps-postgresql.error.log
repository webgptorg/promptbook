ICE_ROLE_KEY', ''),\n39.     createAgentsServerEnvVariable('SUPABASE_AUTO_MIGRATE', 'true'),\n40.     createAgentsServerEnvVariable('ADMIN_PASSWORD', ''),\n41. ];\n42. \n43. /**\n44.  * Ensures `.env` contains all required Agents Server configuration entries.\n45.  *\n46.  * @private internal utility of `ptbk agents-server init`\n47.  */\n48. export async function ensureAgentsServerEnvFile(projectPath: string): Promise<EnsureProjectEnvFileResult> {\n49.     return ensureProjectEnvFile({\n50.         projectPath,\n51.         emptyFileContent: EMPTY_AGENTS_SERVER_ENV_FILE_CONTENT,\n52.         envVariables: REQUIRED_AGENTS_SERVER_ENV_VARIABLES,\n53.         buildMissingEnvVariablesBlock,\n54.     });\n55. }\n56. \n57. /**\n58.  * Builds one initialized Agents Server environment variable definition.\n59.  */\n60. function createAgentsServerEnvVariable(name: string, value: string): RequiredAgentsServerEnvVariable {\n61.     return {\n62.         name,\n63.         value,\n64.         documentationUrl: `${AGENTS_SERVER_ENV_DOCUMENTATION_BASE_URL}${name.toLowerCase().replace(/_/gu, '-')}`,\n65.     };\n66. }\n67. \n68. /**\n69.  * Builds a `.env` block containing missing Agents Server variables and documentation links.\n70.  */\n71. function buildMissingEnvVariablesBlock(variables: ReadonlyArray<RequiredAgentsServerEnvVariable>): string {\n72.     const variableBlocks = variables.map(({ documentationUrl, name, value }) =>\n73.         [AGENTS_SERVER_ENV_CREATED_COMMENT, `# Documentation: ${documentationUrl}`, `${name}=${value}`].join('\\n'),\n74.     );\n75. \n76.     return ['# Promptbook Agents Server', ...variableBlocks].join('\\n\\n');\n77. }\n78. \n79. // Note: [🟡] Code for Agents Server environment bootstrapping [ensureAgentsServerEnvFile](src/cli/cli-commands/agents-server/ensureAgentsServerEnvFile.ts) should never be published outside of `@promptbook/cli`\n80. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/src/cli/cli-commands/agents-server/en