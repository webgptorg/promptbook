{"type":"tool.execution_complete","data":{"toolCallId":"call_q6FGqyziN2r2mRYAsczTZizG","model":"gpt-5.4","interactionId":"0a603915-c65a-4110-b10e-3f0d506120f6","turnId":"113","success":true,"result":{"content":"1. import type { TODO_any } from '@promptbook-local/types';\r\n2. import type { SupabaseClient } from '@supabase/supabase-js';\r\n3. import { type Pool } from 'pg';\r\n4. import { $provideAgentsServerPostgresPool } from './$provideAgentsServerPostgresPool';\r\n5. \r\n6. /**\r\n7.  * Minimal query result shape consumed by Agents Server Supabase call sites.\r\n8.  *\r\n9.  * @private internal PostgreSQL utility of Agents Server\r\n10.  */\r\n11. type LocalPostgresQueryResult<TData = TODO_any> = {\r\n12.     readonly data: TData | null;\r\n13.     readonly error: LocalPostgresError | null;\r\n14.     readonly count?: number | null;\r\n15.     readonly status?: number;\r\n16.     readonly statusText?: string;\r\n17. };\r\n18. \r\n19. /**\r\n20.  * Supabase-like error shape returned by the direct PostgreSQL adapter.\r\n21.  *\r\n22.  * @private internal PostgreSQL utility of Agents Server\r\n23.  */\r\n24. type LocalPostgresError = {\r\n25.     readonly code?: string;\r\n26.     readonly message: string;\r\n27.     readonly details?: string;\r\n28.     readonly hint?: string;\r\n29. };\r\n30. \r\n31. /**\r\n32.  * Supported query operation kinds.\r\n33.  *\r\n34.  * @private internal PostgreSQL utility of Agents Server\r\n35.  */\r\n36. type LocalPostgresOperation = 'select' | 'insert' | 'update' | 'delete' | 'upsert';\r\n37. \r\n38. /**\r\n39.  * Query filter captured from Supabase-like fluent calls.\r\n40.  *\r\n41.  * @private internal PostgreSQL utility of Agents Server\r\n42.  */\r\n43. type LocalPostgresFilter = {\r\n44.     readonly column: string;\r\n45.     readonly operator: 'eq' | 'neq' | 'is' | 'not-is' | 'in' | 'lt' | 'lte' | 'gt' | 'gte' | 'like' | 'ilike';\r\n46.     readonly value: unknown;\r\n47. };\r\n48. \r\n49. /**\r\n50.  * Query order captured from Supabase-like fluent calls.\r\n51.  *\r\n52.  * @private internal PostgreSQL utility of Agents Server\r\n53.  */\r\n54. type LocalPostgresOrder = {\r\n55.     readonly column: string;\r\n56.     readonly ascending: boolean;\r\n57.     readonly nullsFirst?: boolean;\r\n58. };\r\n59. \r\n60. /**\r\n61.  * Select options supported by Supabase and used by this app.\r\n62.  *\r\n63.  * @private internal PostgreSQL utility of Agents Server\r\n64.  */\r\n65. type LocalPostgresSelectOptions = {\r\n66.     readonly count?: 'exact';\r\n67.     readonly head?: boolean;\r\n68. };\r\n69. \r\n70. /**\r\n71.  * Upsert options supported by Supabase and used by this app.\r\n72.  *\r\n73.  * @private internal PostgreSQL utility of Agents Server\r\n74.  */\r\n75. type LocalPostgresUpsertOptions = {\r\n76.     readonly onConflict?: string;\r\n77. };\r\n78. \r\n79. /**\r\n80.  * Parsed PostgREST filter expression.\r\n81.  *\r\n82.  * @private internal PostgreSQL utility of Agents Server\r\n83.  */\r\n84. type ParsedPostgrestFilter = {\r\n85.     readonly column: string;\r\n86.     readonly operator: string;\r\n87.     readonly value: string;\r\n88. };\r\n89. \r\n90. /**\r\n91.  * Columns whose values are persisted as JSON text in Agents Server SQL adapters.\r\n92.  *\r\n93.  * @private internal PostgreSQL utility of Agents Server\r\n94.  */\r\n95. const JSON_COLUMNS_BY_TABLE = new Map<string, ReadonlySet<string>>([\r\n96.     ['Agent', new Set(['agentProfile', 'usage', 'preparedModelRequirements', 'preparedExternals'])],\r\n97.     ['AgentHistory', new Set([])],\r\n98.     ['ChatHistory', new Set(['message', 'usage'])],\r\n99.     ['LlmCache', new Set(['value'])],\r\n100.     ['VectorStoreKnowledgeSourceHashes', new Set([])],\r\n101.     ['Image', new Set([])],\r\n102.     ['File', new Set(['securityResult'])],\r\n103.     ['Message', new Set(['sender', 'recipients', 'metadata'])],\r\n104.     ['MessageSendAttempt', new Set(['raw'])],\r\n105.     ['UserChat', new Set(['messages']