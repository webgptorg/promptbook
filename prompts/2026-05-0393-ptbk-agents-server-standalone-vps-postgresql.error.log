. \n671.     if [[ -z \"$ip_address\" ]]; then\n672.         ip_address=\"localhost\"\n673.     fi\n674. \n675.     printf '%s' \"$ip_address\"\n676. }\n677. \n678. configure_install_directory() {\n679.     log \"Configuring $INSTALL_DIR.\"\n680.     \"${SUDO[@]}\" mkdir -p \"$INSTALL_DIR/.promptbook\" \"$INSTALL_DIR/.logs\"\n681.     \"${SUDO[@]}\" chown -R \"$RUN_USER:$RUN_GROUP\" \"$INSTALL_DIR\"\n682. \n683.     ENV_FILE=\"$INSTALL_DIR/.env\"\n684.     run_as_service_user touch \"$ENV_FILE\"\n685.     run_as_service_user chmod 600 \"$ENV_FILE\"\n686. }\n687. \n688. set_env_value() {\n689.     local key=\"$1\"\n690.     local value=\"$2\"\n691.     local temporary_file=\"\"\n692.     temporary_file=\"$(mktemp)\"\n693. \n694.     if [[ -f \"$ENV_FILE\" && -s \"$ENV_FILE\" ]]; then\n695.         awk -v key=\"$key\" -v value=\"$value\" '\n696.             BEGIN { isUpdated = 0 }\n697.             $0 ~ \"^\" key \"=\" {\n698.                 print key \"=\" value\n699.                 isUpdated = 1\n700.                 next\n701.             }\n702.             { print }\n703.             END {\n704.                 if (isUpdated == 0) {\n705.                     print key \"=\" value\n706.                 }\n707.             }\n708.         ' \"$ENV_FILE\" > \"$temporary_file\"\n709.     else\n710.         printf '%s=%s\\n' \"$key\" \"$value\" > \"$temporary_file\"\n711.     fi\n712. \n713.     install -m 600 -o \"$RUN_USER\" -g \"$RUN_GROUP\" \"$temporary_file\" \"$ENV_FILE\"\n714.     rm -f \"$temporary_file\"\n715. }\n716. \n717. get_env_value() {\n718.     local key=\"$1\"\n719.     local existing_env_file=\"${ENV_FILE:-$INSTALL_DIR/.env}\"\n720. \n721.     if [[ ! -r \"$existing_env_file\" ]]; then\n722.         return\n723.     fi\n724. \n725.     awk -v key=\"$key\" '\n726.         $0 ~ \"^\" key \"=\" {\n727.             value = substr($0, length(key) + 2)\n728.             isFound = 1\n729.         }\n730.         END {\n731.             if (isFound == 1) {\n732.                 print value\n733.             }\n734.         }\n735.     ' \"$existing_env_file\"\n736. }\n737. \n738. has_non_empty_env_value() {\n739.     local key=\"$1\"\n740.     [[ -f \"$ENV_FILE\" ]] && grep -Eq \"^${key}=.+\" \"$ENV_FILE\"\n741. }\n742. \n743. resolve_secret_default() {\n744.     local key=\"$1\"\n745.     local existing_value=\"\"\n746. \n747.     existing_value=\"$(get_env_value \"$key\")\"\n748. \n749.     if [[ -n \"$existing_value\" ]]; then\n750.         printf '%s' \"$existing_value\"\n751.         return\n752.     fi\n753. \n754.     printf '%s' \"${!key:-}\"\n755. }\n756. \n757. prompt_api_keys_and_admin_password() {\n758.     local default_openai_api_key=\"\"\n759.     local default_admin_password=\"\"\n760.     local openai_api_key_default_description=\"empty\"\n761.     local admin_password_default_description=\"auto-generate\"\n762. \n763.     default_openai_api_key=\"$(resolve_secret_default OPENAI_API_KEY)\"\n764.     default_admin_password=\"$(resolve_secret_default ADMIN_PASSWORD)\"\n765. \n766.     if [[ -n \"$default_openai_api_key\" ]]; then\n767.         openai_api_key_default_description=\"keep existing\"\n768.     fi\n769. \n770.     if [[ -n \"$default_admin_password\" ]]; then\n771.         admin_password_default_description=\"keep existing\"\n772.     fi\n773. \n774.     log \"Press Enter to leave the OpenAI API key empty or keep the current value.\"\n775.     REQUESTED_OPENAI_API_KEY=\"$(\n776.         prompt_secret_with_default \"OpenAI API key (optional)\" \"$openai_api_key_default_description\" \"$default_openai_api_key\"\n777.     )\"\n778. \n779.     log \"Press Enter to auto-generate the admin password or keep the current value.\"\n780.     REQUESTED_ADMIN_PASSWORD=\"$(\n781.         prompt_secret_with_default \"Admin password\" \"$admin_password_default_description\" \"$default_admin_password\"\n782.     )\"\n783. }\n784. \n785. configure_domains() {\n786.     local default_domains=\"$SERVERS\"\n787.     local existing_env_file=\"${ENV_FILE:-$INSTALL_DIR/.env}\"\n788.     local requested_domains=\"\"\n789.     local domain=\"\"\n790. \n791.     if [[ -z \"$default_domains\" && -r \"$existing_env_file\" ]]; then\n792.         default_domains=\"$(grep -E '^SERVERS=' \"$existing_env_file\" | tail -n 1 | cut -d= -f2- || true)\"\n793.     fi\n794. \n795.     requested_domains=\"$(prompt_with_default \"Primary domain (optional, comma-separated for advanced use)\" \"$default_domains\")\"\n796.     set_domains_from_csv \"$requested_domains\"\n797. \n798.     SERVERS=\"$(join_by_comma \"${DOMAINS[@]}\")\"\n799.     PUBLIC_IP_ADDRESS=\"$(resolve_public_ip_address)\"\n800. \n801.     if [[ \"${#DOMAINS[@]}\" -eq 0 ]]; then\n802.         log \"No custom domain configured. The server will be available on http://$PUBLIC_IP_ADDRESS and domains can be added later from the super admin UI.\"\n803.         return\n804.     fi\n805. \n806.     log \"Before SSL is issued, point these DNS records to this VPS:\"\n807.     for domain in \"${DOMAINS[@]}\"; do\n808.         log \"  $domain  A  $PUBLIC_IP_ADDRESS\"\n809.     done\n810.     log \"If your VPS provider gave you an IPv6 address, add matching AAAA records as well.\"\n811. \n812.     if ! prompt_yes_no \"Have the DNS records propagated and should SSL setup continue now?\" \"yes\"; then\n813.         fail \"Update DNS for $SERVERS, then run this installer again.\"\n814.     fi\n815. }\n816. \n817. configure_environment() {\n818.     local sqlite_path=\"$INSTALL_DIR/.promptbook/agents-server.sqlite\"\n819.     local default_public_url=\"\"\n820.     local public_site_url=\"\"\n821.     local first_domain=\"${DOMAINS[0]:-}\"\n822.     local table_prefix=\"\"\n823. \n824.     if [[ -n \"$first_domain\" ]]; then\n825.         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-https://${first_domain}}}\"\n826.         table_prefix=\"$(build_domain_table_prefix \"$first_domain\")\"\n827.     else\n828.         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-$(resolve_default_public_url)}}\"\n829.     fi\n830. \n831.     public_site_url=\"$(prompt_with_default \"Public Agents Server URL\" \"$default_public_url\")\"\n832. \n833.     set_env_value PTBK_AGENTS_SERVER_DATABASE sqlite\n834.     set_env_value PTBK_AGENTS_SERVER_SQLITE_PATH \"$sqlite_path\"\n835.     set_env_value NEXT_PUBLIC_SITE_URL \"$public_site_url\"\n836.     set_env_value SERVERS \"$SERVERS\"\n837.     set_env_value SUPABASE_TABLE_PREFIX \"$table_prefix\"\n838.     set_env_value SUPABASE_AUTO_MIGRATE false\n839.     set_env_value PTBK_AGENT \"$PTBK_AGENT\"\n840.     set_env_value PTBK_MODEL \"$PTBK_MODEL\"\n841.     set_env_value PTBK_THINKING_LEVEL \"$PTBK_THINKING_LEVEL\"\n842.     set_env_value PORT \"$PORT\"\n843.     set_env_value NODE_ENV production\n844.     set_env_value PTBK_HOSTNAME 127.0.0.1\n845.     set_env_value PTBK_PUBLIC_IP_ADDRESS \"$PUBLIC_IP_ADDRESS\"\n846.     set_env_value PTBK_INSTALL_DIR \"$INSTALL_DIR\"\n847.     set_env_value PTBK_REPOSITORY_DIR \"$PROMPTBOOK_REPOSITORY_DIR\"\n848.     set_env_value PTBK_VPS_INSTALL_SCRIPT \"$PROMPTBOOK_REPOSITORY_DIR/other/vps/install.sh\"\n849.     set_env_value PTBK_AGENTS_SERVER_ENV_FILE \"$ENV_FILE\"\n850.     set_env_value PTBK_PM2_APP_NAME \"$APP_NAME\"\n851.     set_env_value PTBK_NGINX_SITE_NAME \"$NGINX_SITE_NAME\"\n852.     set_env_value LETS_ENCRYPT_EMAIL \"$LETS_ENCRYPT_EMAIL\"\n853.     set_env_value OPENAI_API_KEY \"$REQUESTED_OPENAI_API_KEY\"\n854. \n855.     if [[ -n \"$REQUESTED_ADMIN_PASSWORD\" ]]; then\n856.         set_env_value ADMIN_PASSWORD \"$REQUESTED_ADMIN_PASSWORD\"\n857.     elif ! has_non_empty_env_value ADMIN_PASSWORD; then\n858.         GENERATED_ADMIN_PASSWORD=\"$(openssl rand -hex 24)\"\n859.         set_env_value ADMIN_PASSWORD \"$GENERATED_ADMIN_PASSWORD\"\n860.     fi\n861. \n862.     if [[ -n \"${COPILOT_GITHUB_TOKEN:-}\" ]]; then\n863.         set_env_value COPILOT_GITHUB_TOKEN \"$COPILOT_GITHUB_TOKEN\"\n864.     elif [[ -n \"${GH_TOKEN:-}\" ]]; then\n865.         set_env_value GH_TOKEN \"$GH_TOKEN\"\n866.     fi\n867. }\n868. \n869. initialize_promptbook_project() {\n870.     log \"Initializing Promptbook Agents Server project files.\"\n871.     run_as_service_user bash -lc \"cd $(shell_quote \"$INSTALL_DIR\") && $(shell_quote \"$PTBK_COMMAND_PATH\") agents-server init >/dev/null\"\n872.     configure_environment\n873. }\n874. \n875. configure_runner_authentication() {\n876.     if [[ \"$PTBK_AGENT\" != \"github-copilot\" ]]; then\n877.         return\n878.     fi\n879. \n880.     if [[ -n \"${COPILOT_GITHUB_TOKEN:-}\" || -n \"${GH_TOKEN:-}\" ]]; then\n881.         log \"GitHub Copilot token environment variable detected and stored in $ENV_FILE.\"\n882.         return\n883.     fi\n884. \n885.     if ! command -v copilot >/dev/null 2>&1; then\n886.         warn \"GitHub Copilot CLI is not available, skipping interactive authentication.\"\n887.         return\n888.     fi\n889. \n890.     if ! is_interactive; then\n891.         warn \"GitHub Copilot login requires an interactive VPS terminal. Run copilot as $RUN_USER and complete /login before restarting pm2.\"\n892.         return\n893.     fi\n894. \n895.     if ! prompt_yes_no \"Open GitHub Copilot CLI now for /login and project trust setup?\" \"yes\"; then\n896.         warn \"Skipping Copilot login. The runner must be authenticated before it can answer chats.\"\n897.         return\n898.     fi\n899. \n900.     log \"Starting GitHub Copilot CLI. Use /login if prompted, trust this directory, then exit Copilot to continue.\"\n901.     set +e\n902.     run_as_service_user bash -lc \"cd $(shell_quote \"$INSTALL_DIR\") && copilot\" < /dev/tty > /dev/tty\n903.     local copilot_exit_code=$?\n904.     set -e\n905. \n906.     if [[ \"$copilot_exit_code\" -ne 0 ]]; then\n907.         warn \"Copilot exited with status $copilot_exit_code. The server will still start, but the runner may need authentication.\"\n908.     fi\n909. }\n910. \n911. configure_firewall() {\n912.     if ! command -v ufw >/dev/null 2>&1; then\n913.         return\n914.     fi\n915. \n916.     if \"${SUDO[@]}\" ufw status | grep -q 'Status: active'; then\n917.         log \"Opening HTTP and HTTPS in ufw for nginx.\"\n918.         if \"${SUDO[@]}\" ufw app list | grep -q '^  Nginx Full$'; then\n919.             \"${SUDO[@]}\" ufw allow 'Nginx Full'\n920.         else\n921.             \"${SUDO[@]}\" ufw allow 80/tcp\n922.             \"${SUDO[@]}\" ufw allow 443/tcp\n923.         fi\n924.     fi\n925. }\n926. \n927. ensure_nginx_headers_more_module_is_available() {\n928.     local headers_more_package=\"libnginx-mod-http-headers-more-filter\"\n929.     local module_available_path=\"\"\n930.     local module_enabled_path=\"\"\n931. \n932.     if ! dpkg-query -W -f='${Status}' \"$headers_more_package\" 2>/dev/null | grep -q 'install ok installed'; then\n933.         log \"Installing nginx headers-more module for branded server headers.\"\n934.         \"${SUDO[@]}\" env DEBIAN_FRONTEND=noninteractive apt-get update\n935.         \"${SUDO[@]}\" env DEBIAN_FRONTEND=noninteractive apt-get install -y \"$headers_more_package\"\n936.     fi\n937. \n938.     if [[ ! -d /usr/share/nginx/modules-available ]]; then\n939.         return\n940.     fi\n941. \n942.     module_available_path=\"$(\n943.         find /usr/share/nginx/modules-available -maxdepth 1 \\\n944.             \\( -name '*headers-more*' -o -name '*headers_more*' \\) |\n945.             head -n 1\n946.     )\"\n947. \n948.     if [[ -z \"$module_available_path\" ]]; then\n949.         return\n950.     fi\n951. \n952.     \"${SUDO[@]}\" install -d -m 755 /etc/nginx/modules-enabled\n953.     module_enabled_path=\"/etc/nginx/modules-enabled/50-$(basename \"$module_available_path\")\"\n954.     if [[ ! -e \"$module_enabled_path\" ]]; then\n955.         \"${SUDO[@]}\" ln -s \"$module_available_path\" \"$module_enabled_path\"\n956.     fi\n957. }\n958. \n959. write_nginx_fallback_page() {\n960.     \"${SUDO[@]}\" install -d -m 755 \"$NGINX_FALLBACK_DIR\"\n961.     \"${SUDO[@]}\" tee \"$NGINX_FALLBACK_HTML_PATH\" >/dev/null <<'EOF'\n962. <!doctype html>\n963. <html lang=\"en\">\n964. <head>\n965.     <meta charset=\"utf-8\">\n966.     <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n967.     <title>Promptbook Agents Server</title>\n968.     <style>\n969.         :root {\n970.             color-scheme: light dark;\n971.             font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n972.             background: #f7f7f5;\n973.             color: #202124;\n974.         }\n975. \n976.         body {\n977.             min-height: 100vh;\n978.             margin: 0;\n979.             display: grid;\n980.             place-items: center;\n981.             background:\n982.                 linear-gradient(135deg, rgba(26, 115, 232, 0.08), transparent 42%),\n983.                 linear-gradient(315deg, rgba(52, 168, 83, 0.10), transparent 38%),\n984.                 #f7f7f5;\n985.         }\n986. \n987.         main {\n988.             width: min(92vw, 520px);\n989.             padding: 40px;\n990.             border: 1px solid rgba(32, 33, 36, 0.14);\n991.             border-radius: 8px;\n992.             background: rgba(255, 255, 255, 0.86);\n993.             box-shadow: 0 24px 60px rgba(32, 33, 36, 0.10);\n994.         }\n995. \n996.         .brand {\n997.             margin: 0 0 18px;\n998.             color: #1a73e8;\n999.             font-size: 14px;\n1000.             font-weight: 700;\n1001.             letter-spacing: 0;\n1002.             text-transform: uppercase;\n1003.         }\n1004. \n1005.         h1 {\n1006.             margin: 0 0 12px;\n1007.             font-size: 40px;\n1008.             line-height: 1;\n1009.             letter-spacing: 0;\n1010.         }\n1011. \n1012.         p {\n1013.             margin: 0;\n1014.             color: #4f565f;\n1015.             font-size: 16px;\n1016.             line-height: 1.6;\n1017.         }\n1018. \n1019.         @media (prefers-color-scheme: dark) {\n1020.             :root {\n1021.                 background: #111318;\n1022.                 color: #f4f7fb;\n1023.             }\n1024. \n1025.             body {\n1026.                 background:\n1027.                     linear-gradient(135deg, rgba(138, 180, 248, 0.12), transparent 42%),\n1028.                     linear-gradient(315deg, rgba(129, 201, 149, 0.10), transparent 38%),\n1029.                     #111318;\n1030.             }\n1031. \n1032.             main {\n1033.                 border-color: rgba(244, 247, 251, 0.14);\n1034.                 background: rgba(25, 28, 33, 0.88);\n1035.                 box-shadow: 0 24px 60px rgba(0, 0, 0, 0.28);\n1036.             }\n1037. \n1038.             .brand {\n1039.                 color: #8ab4f8;\n1040.             }","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/other/vps/install.sh b/C:/Users/me/work/ai/promptbook/other/vps/install.sh\nindex 0000000..0000000 100644\n--- a/C:/Users/me/work/ai/promptbook/other/vps/install.sh\n+++ b/C:/Users/me/work/ai/promptbook/other/vps/install.sh\n@@ -621,420 +621,420 @@\n             ;;\n         openai-codex)\n             if command -v codex >/dev/null 2>&1; then\n                 log \"OpenAI Codex CLI is already installed.\"\n                 return\n             fi\n \n             log \"Installing OpenAI Codex CLI.\"\n             \"${SUDO[@]}\" npm install -g @openai/codex\n             ;;\n         claude-code)\n             if command -v claude >/dev/null 2>&1; then\n                 log \"Claude Code CLI is already installed.\"\n                 return\n             fi\n \n             log \"Installing Claude Code CLI.\"\n             \"${SUDO[@]}\" npm install -g @anthropic-ai/claude-code\n             ;;\n         gemini)\n             if command -v gemini >/dev/null 2>&1; then\n                 log \"Gemini CLI is already installed.\"\n                 return\n             fi\n \n             log \"Installing Gemini CLI.\"\n             \"${SUDO[@]}\" npm install -g @google/gemini-cli\n             ;;\n         *)\n             warn \"No automatic dependency installer is defined for runner '$PTBK_AGENT'. Make sure its CLI is available on PATH.\"\n             ;;\n     esac\n }\n \n resolve_default_public_url() {\n     local ip_address=\"\"\n     ip_address=\"$(resolve_public_ip_address)\"\n \n     printf 'http://%s' \"$ip_address\"\n }\n \n resolve_public_ip_address() {\n     local ip_address=\"\"\n \n     ip_address=\"$(curl -fsS --max-time 5 https://api.ipify.org 2>/dev/null || true)\"\n \n     if [[ -z \"$ip_address\" ]]; then\n         ip_address=\"$(hostname -I 2>/dev/null | awk '{ print $1 }' || true)\"\n     fi\n \n     if [[ -z \"$ip_address\" ]]; then\n         ip_address=\"localhost\"\n     fi\n \n     printf '%s' \"$ip_address\"\n }\n \n configure_install_directory() {\n     log \"Configuring $INSTALL_DIR.\"\n     \"${SUDO[@]}\" mkdir -p \"$INSTALL_DIR/.promptbook\" \"$INSTALL_DIR/.logs\"\n     \"${SUDO[@]}\" chown -R \"$RUN_USER:$RUN_GROUP\" \"$INSTALL_DIR\"\n \n     ENV_FILE=\"$INSTALL_DIR/.env\"\n     run_as_service_user touch \"$ENV_FILE\"\n     run_as_service_user chmod 600 \"$ENV_FILE\"\n }\n \n set_env_value() {\n     local key=\"$1\"\n     local value=\"$2\"\n     local temporary_file=\"\"\n     temporary_file=\"$(mktemp)\"\n \n     if [[ -f \"$ENV_FILE\" && -s \"$ENV_FILE\" ]]; then\n         awk -v key=\"$key\" -v value=\"$value\" '\n             BEGIN { isUpdated = 0 }\n             $0 ~ \"^\" key \"=\" {\n                 print key \"=\" value\n                 isUpdated = 1\n                 next\n             }\n             { print }\n             END {\n                 if (isUpdated == 0) {\n                     print key \"=\" value\n                 }\n             }\n         ' \"$ENV_FILE\" > \"$temporary_file\"\n     else\n         printf '%s=%s\\n' \"$key\" \"$value\" > \"$temporary_file\"\n     fi\n \n     install -m 600 -o \"$RUN_USER\" -g \"$RUN_GROUP\" \"$temporary_file\" \"$ENV_FILE\"\n     rm -f \"$temporary_file\"\n }\n \n get_env_value() {\n     local key=\"$1\"\n     local existing_env_file=\"${ENV_FILE:-$INSTALL_DIR/.env}\"\n \n     if [[ ! -r \"$existing_env_file\" ]]; then\n         return\n     fi\n \n     awk -v key=\"$key\" '\n         $0 ~ \"^\" key \"=\" {\n             value = substr($0, length(key) + 2)\n             isFound = 1\n         }\n         END {\n             if (isFound == 1) {\n                 print value\n             }\n         }\n     ' \"$existing_env_file\"\n }\n \n has_non_empty_env_value() {\n     local key=\"$1\"\n     [[ -f \"$ENV_FILE\" ]] && grep -Eq \"^${key}=.+\" \"$ENV_FILE\"\n }\n \n resolve_secret_default() {\n     local key=\"$1\"\n     local existing_value=\"\"\n \n     existing_value=\"$(get_env_value \"$key\")\"\n \n     if [[ -n \"$existing_value\" ]]; then\n         printf '%s' \"$existing_value\"\n         return\n     fi\n \n     printf '%s' \"${!key:-}\"\n }\n \n prompt_api_keys_and_admin_password() {\n     local default_openai_api_key=\"\"\n     local default_admin_password=\"\"\n     local openai_api_key_default_description=\"empty\"\n     local admin_password_default_description=\"auto-generate\"\n \n     default_openai_api_key=\"$(resolve_secret_default OPENAI_API_KEY)\"\n     default_admin_password=\"$(resolve_secret_default ADMIN_PASSWORD)\"\n \n     if [[ -n \"$default_openai_api_key\" ]]; then\n         openai_api_key_default_description=\"keep existing\"\n     fi\n \n     if [[ -n \"$default_admin_password\" ]]; then\n         admin_password_default_description=\"keep existing\"\n     fi\n \n     log \"Press Enter to leave the OpenAI API key empty or keep the current value.\"\n     REQUESTED_OPENAI_API_KEY=\"$(\n         prompt_secret_with_default \"OpenAI API key (optional)\" \"$openai_api_key_default_description\" \"$default_openai_api_key\"\n     )\"\n \n     log \"Press Enter to auto-generate the admin password or keep the current value.\"\n     REQUESTED_ADMIN_PASSWORD=\"$(\n         prompt_secret_with_default \"Admin password\" \"$admin_password_default_description\" \"$default_admin_password\"\n     )\"\n }\n \n configure_domains() {\n     local default_domains=\"$SERVERS\"\n     local existing_env_file=\"${ENV_FILE:-$INSTALL_DIR/.env}\"\n     local requested_domains=\"\"\n     local domain=\"\"\n \n     if [[ -z \"$default_domains\" && -r \"$existing_env_file\" ]]; then\n         default_domains=\"$(grep -E '^SERVERS=' \"$existing_env_file\" | tail -n 1 | cut -d= -f2- || true)\"\n     fi\n \n     requested_domains=\"$(prompt_with_default \"Primary domain (optional, comma-separated for advanced use)\" \"$default_domains\")\"\n     set_domains_from_csv \"$requested_domains\"\n \n     SERVERS=\"$(join_by_comma \"${DOMAINS[@]}\")\"\n     PUBLIC_IP_ADDRESS=\"$(resolve_public_ip_address)\"\n \n     if [[ \"${#DOMAINS[@]}\" -eq 0 ]]; then\n         log \"No custom domain configured. The server will be available on http://$PUBLIC_IP_ADDRESS and domains can be added later from the super admin UI.\"\n         return\n     fi\n \n     log \"Before SSL is issued, point these DNS records to this VPS:\"\n     for domain in \"${DOMAINS[@]}\"; do\n         log \"  $domain  A  $PUBLIC_IP_ADDRESS\"\n     done\n     log \"If your VPS provider gave you an IPv6 address, add matching AAAA records as well.\"\n \n     if ! prompt_yes_no \"Have the DNS records propagated and should SSL setup continue now?\" \"yes\"; then\n         fail \"Update DNS for $SERVERS, then run this installer again.\"\n     fi\n }\n \n configure_environment() {\n     local sqlite_path=\"$INSTALL_DIR/.promptbook/agents-server.sqlite\"\n     local default_public_url=\"\"\n     local public_site_url=\"\"\n     local first_domain=\"${DOMAINS[0]:-}\"\n     local table_prefix=\"\"\n \n     if [[ -n \"$first_domain\" ]]; then\n         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-https://${first_domain}}}\"\n         table_prefix=\"$(build_domain_table_prefix \"$first_domain\")\"\n     else\n         default_public_url=\"${PTBK_PUBLIC_SITE_URL:-${NEXT_PUBLIC_SITE_URL:-$(resolve_default_public_url)}}\"\n     fi\n \n     public_site_url=\"$(prompt_with_default \"Public Agents Server URL\" \"$default_public_url\")\"\n \n     set_env_value PTBK_AGENTS_SERVER_DATABASE sqlite\n     set_env_value PTBK_AGENTS_SERVER_SQLITE_PATH \"$sqlite_path\"\n     set_env_value NEXT_PUBLIC_SITE_URL \"$public_site_url\"\n     set_env_value SERVERS \"$SERVERS\"\n     set_env_value SUPABASE_TABLE_PREFIX \"$table_prefix\"\n     set_env_value SUPABASE_AUTO_MIGRATE false\n     set_env_value PTBK_AGENT \"$PTBK_AGENT\"\n     set_env_value PTBK_MODEL \"$PTBK_MODEL\"\n     set_env_value PTBK_THINKING_LEVEL \"$PTBK_THINKING_LEVEL\"\n     set_env_value PORT \"$PORT\"\n     set_env_value NODE_ENV production\n     set_env_value PTBK_HOSTNAME 127.0.0.1\n     set_env_value PTBK_PUBLIC_IP_ADDRESS \"$PUBLIC_IP_ADDRESS\"\n     set_env_value PTBK_INSTALL_DIR \"$INSTALL_DIR\"\n     set_env_value PTBK_REPOSITORY_DIR \"$PROMPTBOOK_REPOSITORY_DIR\"\n     set_env_value PTBK_VPS_INSTALL_SCRIPT \"$PROMPTBOOK_REPOSITORY_DIR/other/vps/install.sh\"\n     set_env_value PTBK_AGENTS_SERVER_ENV_FILE \"$ENV_FILE\"\n     set_env_value PTBK_PM2_APP_NAME \"$APP_NAME\"\n     set_env_value PTBK_NGINX_SITE_NAME \"$NGINX_SITE_NAME\"\n     set_env_value LETS_ENCRYPT_EMAIL \"$LETS_ENCRYPT_EMAIL\"\n     set_env_value OPENAI_API_KEY \"$REQUESTED_OPENAI_API_KEY\"\n \n     if [[ -n \"$REQUESTED_ADMIN_PASSWORD\" ]]; then\n         set_env_value ADMIN_PASSWORD \"$REQUESTED_ADMIN_PASSWORD\"\n     elif ! has_non_empty_env_value ADMIN_PASSWORD; then\n         GENERATED_ADMIN_PASSWORD=\"$(openssl rand -hex 24)\"\n         set_env_value ADMIN_PASSWORD \"$GENERATED_ADMIN_PASSWORD\"\n     fi\n \n     i