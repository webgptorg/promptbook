n31. PROMPTBOOK_SWAP_FILE=\"${PTBK_SWAP_FILE:-/swapfile-promptbook}\"\n32. MINIMUM_REQUIRED_MEMORY_MIB=8192\n33. MINIMUM_REQUIRED_DISK_MIB=15360\n34. \n35. SUDO=()\n36. RUN_USER=\"\"\n37. RUN_GROUP=\"\"\n38. RUN_HOME=\"\"\n39. ENV_FILE=\"\"\n40. REQUESTED_OPENAI_API_KEY=\"\"\n41. REQUESTED_ADMIN_PASSWORD=\"\"\n42. GENERATED_ADMIN_PASSWORD=\"\"\n43. REQUESTED_DATABASE_MODE=\"\"\n44. REQUESTED_SQLITE_PATH=\"\"\n45. REQUESTED_POSTGRES_HOST=\"\"\n46. REQUESTED_POSTGRES_PORT=\"\"\n47. REQUESTED_POSTGRES_DATABASE=\"\"\n48. REQUESTED_POSTGRES_USER=\"\"\n49. REQUESTED_POSTGRES_PASSWORD=\"\"\n50. GENERATED_POSTGRES_PASSWORD=\"\"\n51. PUBLIC_IP_ADDRESS=\"\"\n52. DOMAINS=()\n53. \n54. log() {\n55.     printf '[promptbook-vps] %s\\n' \"$*\"\n56. }\n57. \n58. warn() {\n59.     printf '[promptbook-vps] Warning: %s\\n' \"$*\" >&2\n60. }\n61. \n62. fail() {\n63.     printf '[promptbook-vps] Error: %s\\n' \"$*\" >&2\n64.     exit 1\n65. }\n66. \n67. is_interactive() {\n68.     [[ \"$PTBK_NON_INTERACTIVE\" != \"1\" && -r /dev/tty && -w /dev/tty ]]\n69. }\n70. \n71. prompt_with_default() {\n72.     local label=\"$1\"\n73.     local default_value=\"$2\"\n74.     local answer=\"\"\n75. \n76.     if ! is_interactive; then\n77.         printf '%s' \"$default_value\"\n78.         return\n79.     fi\n80. \n81.     printf '%s [%s]: ' \"$label\" \"$default_value\" > /dev/tty\n82.     read -r answer < /dev/tty || answer=\"\"\n83.     printf '%s' \"${answer:-$default_value}\"\n84. }\n85. \n86. prompt_yes_no() {\n87.     local label=\"$1\"\n88.     local default_value=\"$2\"\n89.     local answer=\"\"\n90. \n91.     if ! is_interactive; then\n92.         [[ \"$default_value\" == \"yes\" ]]\n93.         return\n94.     fi\n95. \n96.     printf '%s [%s]: ' \"$label\" \"$default_value\" > /dev/tty\n97.     read -r answer < /dev/tty || answer=\"\"\n98.     answer=\"${answer:-$default_value}\"\n99. \n100.     [[ \"$answer\" =~ ^[Yy] ]]\n101. }\n102. \n103. prompt_secret_with_default() {\n104.     local label=\"$1\"\n105.     local default_description=\"$2\"\n106.     local default_value=\"$3\"\n107.     local answer=\"\"\n108. \n109.     if ! is_interactive; then\n110.         printf '%s' \"$default_value\"\n111.         return\n112.     fi\n113. \n114.     printf '%s [%s]: ' \"$label\" \"$default_description\" > /dev/tty\n115.     read -r -s answer < /dev/tty || answer=\"\"\n116.     printf '\\n' > /dev/tty\n117.     printf '%s' \"${answer:-$default_value}\"\n118. }\n119. \n120. format_mib() {\n121.     local value_mib=\"$1\"\n122. \n123.     if [[ \"$value_mib\" -ge 1024 ]]; then\n124.         awk -v value_mib=\"$value_mib\" 'BEGIN { printf \"%.1f GiB\", value_mib / 1024 }'\n125.         return\n126.     fi\n127. \n128.     printf '%s MiB' \"$value_mib\"\n129. }\n130. \n131. join_by_comma() {\n132.     local joined=\"\"\n133.     local item=\"\"\n134. \n135.     for item in \"$@\"; do\n136.         if [[ -n \"$joined\" ]]; then\n137.             joined+=\",\"\n138.         fi\n139.         joined+=\"$item\"\n140.     done\n141. \n142.     printf '%s' \"$joined\"\n143. }\n144. \n145. join_by_space() {\n146.     local joined=\"\"\n147.     local item=\"\"\n148. \n149.     for item in \"$@\"; do\n150.         if [[ -n \"$joined\" ]]; then\n151.             joined+=\" \"\n152.         fi\n153.         joined+=\"$item\"\n154.     done\n155. \n156.     printf '%s' \"$joined\"\n157. }\n158. \n159. shell_quote() {\n160.     printf \"'%s'\" \"$(printf '%s' \"$1\" | sed \"s/'/'\\\\\\\\''/g\")\"\n161. }\n162. \n163. sql_quote_literal() {\n164.     printf \"'%s'\" \"$(printf '%s' \"$1\" | sed \"s/'/''/g\")\"\n165. }\n166. \n167. sql_quote_identifier() {\n168.     printf '\"%s\"' \"$(printf '%s' \"$1\" | sed 's/\"/\"\"/g')\"\n169. }\n170. \n171. build_postgres_connection_string() {\n172.     local host=\"$1\"\n173.     local port=\"$2\"\n174.     local database=\"$3\"\n175.     local user=\"$4\"\n176.     local password=\"$5\"\n177. \n178.     python3 - \"$host\" \"$port\" \"$database\" \"$user\" \"$password\" <<'PY'\n179. import sys\n180. from urllib.parse import quote\n181. \n182. host, port, database, user, password = sys.argv[1:]\n183. print(f\"postgresql://{quote(user, safe='')}:{quote(password, safe='')}@{host}:{port}/{quote(database, safe='')}\")\n184. PY\n185. }\n186. \n187. normalize_domain() {\n188.     local raw_domain=\"$1\"\n189.     local normalized_domain=\"\"\n190. \n191.     normalized_domain=\"$(printf '%s' \"$raw_domain\" |\n192.         tr '[:upper:]' '[:lower:]' |\n193.         sed -E 's#^[[:space:]]+|[[:space:]]+$##g; s#^https?://##; s#/.*$##; s/[.]$//')\"\n194. \n195.     if [[ ! \"$normalized_domain\" =~ ^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$ ]]; then\n196.         printf ''\n197.         return\n198.     fi\n199. \n200.     printf '%s' \"$normalized_domain\"\n201. }\n202. \n203. build_domain_table_prefix() {\n204.     local domain=\"$1\"\n205.     local prefix_suffix=\"\"\n206. \n207.     prefix_suffix=\"$(printf '%s' \"$domain\" |\n208.         sed -E 's/-/_dash_/g; s/[.]/_/g; s/[^A-Za-z0-9_]/_/g; s/_+/_/g; s/^_+|_+$//g')\"\n209. \n210.     printf 'server_%s_' \"$prefix_suffix\"\n211. }\n212. \n213. resolve_existing_path() {\n214.     local checked_path=\"$1\"\n215. \n216.     while [[ ! -e \"$checked_path\" ]]; do\n217.         checked_path=\"$(dirname \"$checked_path\")\"\n218. \n219.         if [[ \"$checked_path\" == \"/\" ]]; then\n220.             break\n221.         fi\n222.     done\n223. \n224.     printf '%s' \"$checked_path\"\n225. }\n226. \n227. get_available_disk_space_mib() {\n228.     local checked_path=\"$1\"\n229. \n230.     df -Pm \"$checked_path\" | awk 'NR == 2 { print $4 }'\n231. }\n232. \n233. get_filesystem_source() {\n234.     local checked_path=\"$1\"\n235. \n236.     df -P \"$checked_path\" | awk 'NR == 2 { print $1 }'\n237. }\n238. \n239. get_total_memory_mib() {\n240.     awk '\n241.         /^(MemTotal|SwapTotal):/ {\n242.             totalMemoryKiB += $2\n243.         }\n244.         END {\n245.             printf \"%d\\n\", totalMemoryKiB / 1024\n246.         }\n247.     ' /proc/meminfo\n248. }\n249. \n250. get_file_size_mib() {\n251.     local file_path=\"$1\"\n252.     local file_size_bytes=0\n253. \n254.     file_size_bytes=\"$(stat -c %s \"$file_path\")\"\n255.     printf '%d\\n' $(((file_size_bytes + 1048575) / 1048576))\n256. }\n257. \n258. is_swap_file_active() {\n259.     local swap_file=\"$1\"\n260. \n261.     swapon --show=NAME --noheadings 2>/dev/null |\n262.         awk -v swap_file=\"$swap_file\" '$1 == swap_file { isActive = 1 } END { exit(isActive == 1 ? 0 : 1) }'\n263. }\n264. \n265. write_swap_file() {\n266.     local swap_file=\"$1\"\n267.     local swap_file_size_mib=\"$2\"\n268. \n269.     \"${SUDO[@]}\" install -o root -g root -m 600 /dev/null \"$swap_file\"\n270. \n271.     if command -v fallocate >/dev/null 2>&1 &&\n272.         \"${SUDO[@]}\" fallocate -l \"${swap_file_size_mib}M\" \"$swap_file\"; then\n273.         return\n274.     fi\n275. \n276.     \"${SUDO[@]}\" dd if=/dev/zero of=\"$swap_file\" bs=1M count=\"$swap_file_size_mib\" status=none\n277. }\n278. \n279. ensure_swap_file_is_persistent() {\n280.     local swap_file=\"$1\"\n281. \n282.     if awk -v swap_file=\"$swap_file\" '$1 == swap_file && $3 == \"swap\" { isConfigured = 1 } END { exit(isConfigured == 1 ? 0 : 1) }' /etc/fstab; then\n283.         return\n284.     fi\n285. \n286.     printf '%s none swap sw 0 0\\n' \"$swap_file\" |\n287.         \"${SUDO[@]}\" tee -a /etc/fstab >/dev/null\n288. }\n289. \n290. configure_swap_performance() {\n291.     \"${SUDO[@]}\" tee /etc/sysctl.d/99-promptbook-swap.conf >/dev/null <<'EOF'\n292. # Managed by the Promptbook Agents Server installer.\n293. vm.swappiness=10\n294. vm.vfs_cache_pressure=50\n295. EOF\n296.     \"${SUDO[@]}\" sysctl -p /etc/sysctl.d/99-promptbook-swap.conf >/dev/null\n297. }\n298. \n299. add_required_swap_file() {\n300.     local additional_swap_mib=\"$1\"\n301.     local swap_file=\"$PROMPTBOOK_SWAP_FILE\"\n302.     local swap_directory=\"\"\n303.     local swap_disk_check_path=\"\"\n304.     local available_swap_disk_space_mib=0\n305.     local existing_swap_file_size_mib=0\n306.     local target_swap_file_size_mib=\"$additional_swap_mib\"\n307. \n308.     swap_directory=\"$(dirname \"$swap_file\")\"\n309.     swap_disk_check_path=\"$(resolve_existing_path \"$swap_directory\")\"\n310.     available_swap_disk_space_mib=\"$(get_available_disk_space_mib \"$swap_disk_check_path\")\"\n311. \n312.     if [[ \"$available_swap_disk_space_mib\" -lt \"$additional_swap_mib\" ]]; then\n313.         fail \"Cannot add $(format_mib \"$additional_swap_mib\") of swap at $swap_file because only $(format_mib \"$available_swap_disk_space_mib\") is free on $swap_disk_check_path.\"\n314.     fi\n315. \n316.     if [[ -e \"$swap_file\" ]]; then\n317.         if ! is_swap_file_active \"$swap_file\"; then\n318.             fail \"$swap_file already exists but is not an active swap file. Remove it manually or set PTBK_SWAP_FILE to another path.\"\n319.         fi\n320. ","detailedContent":"\ndiff --git a/C:/Users/me/work/ai/promptbook/other/vps/install.sh b/C:/Users/me/work/ai/promptbook/other/vps/install.sh\nindex 0000000..0000000 100644\n--- a/C:/Users/me/work/ai/promptbook/other/vps/install.sh\n+++ b/C:/Users/me/work/ai/promptbook/other/vps/install.sh\n@@ -1,320 +1,320 @@\n #!/usr/bin/env bash\n \n set -Eeuo pipefail\n \n APP_NAME=\"${PTBK_PM2_APP_NAME:-promptbook-agents-server}\"\n INSTALL_DIR=\"${PTBK_INSTALL_DIR:-/opt/promptbook-agents-server}\"\n NODE_MAJOR_VERSION=\"${NODE_MAJOR_VERSION:-22}\"\n NODE_MINIMUM_VERSION=\"${NODE_MINIMUM_VERSION:-}\"\n PORT=\"${PORT:-${PTBK_PORT:-4440}}\"\n PROMPTBOOK_REPOSITORY_URL=\"${PROMPTBOOK_REPOSITORY_URL:-https://github.com/webgptorg/promptbook.git}\"\n PROMPTBOOK_REPOSITORY_REF=\"${PROMPTBOOK_REPOSITORY_REF:-main}\"\n PROMPTBOOK_REPOSITORY_DIR=\"${PROMPTBOOK_REPOSITORY_DIR:-$INSTALL_DIR/repos